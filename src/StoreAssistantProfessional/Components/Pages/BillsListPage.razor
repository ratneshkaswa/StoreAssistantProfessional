@page "/bills"
@layout AppShell
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Bills — Store Assistant Professional</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h5">🧾 Bills</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add" OnClick="@(() => Nav.NavigateTo("/billing"))">
            New bill
        </MudButton>
    </MudStack>

    <MudPaper Class="pa-3">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudTextField T="string" Value="_search" ValueChanged="OnSearchChanged"
                          Placeholder="Search # / customer / phone…"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Rounded.Search"
                          Margin="Margin.Dense"
                          Immediate="true"
                          DebounceInterval="250"
                          Style="min-width: 240px;" />
            <MudSelect T="string" Value="_status" ValueChanged="OnStatusChanged" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 120px;">
                <MudSelectItem Value="@("all")">All</MudSelectItem>
                <MudSelectItem Value="@("Posted")">Posted</MudSelectItem>
                <MudSelectItem Value="@("Voided")">Voided</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" Value="_period" ValueChanged="OnPeriodChanged" Label="Period" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 140px;">
                <MudSelectItem Value="@("today")">Today</MudSelectItem>
                <MudSelectItem Value="@("yesterday")">Yesterday</MudSelectItem>
                <MudSelectItem Value="@("week")">Last 7 days</MudSelectItem>
                <MudSelectItem Value="@("month")">This month</MudSelectItem>
                <MudSelectItem Value="@("all")">All time</MudSelectItem>
            </MudSelect>
            <span class="sap-statusbar-spacer"></span>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="sap-amount">
                @Filtered.Count bill(s) · ₹@Filtered.Sum(b => b.Total).ToString("N0")
            </MudText>
        </MudStack>
    </MudPaper>

    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.caption" Color="Color.Secondary">Showing @_bills.Count of @_totalForRange.</MudText>
        <MudStack Row="true" Spacing="1">
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Disabled="@(_page <= 0)" OnClick="PrevPage">‹ Prev</MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Disabled="@((_page + 1) * _pageSize >= _totalForRange)" OnClick="NextPage">Next ›</MudButton>
        </MudStack>
    </MudStack>

    @if (Filtered.Count == 0)
    {
        <MudPaper Class="pa-8" Elevation="0" Style="background: var(--mud-palette-background-grey);">
            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Color="Color.Secondary" Style="font-size: 64px;" />
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    @(_bills.Count == 0 ? "No bills yet." : "No matches in this period.")
                </MudText>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper>
            <MudSimpleTable Hover="true" Dense="true">
                <thead>
                    <tr>
                        <th>Bill #</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Cashier</th>
                        <th style="text-align: right;">Items</th>
                        <th style="text-align: right;">Total</th>
                        <th>Tender</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Filtered)
                    {
                        <tr style="cursor: pointer;" @onclick="@(() => Nav.NavigateTo($"/bills/{b.Id}"))">
                            <td><strong>@b.Number</strong></td>
                            <td><MudChip T="string" Size="Size.Small" Color="@KindColor(b.Kind)" Variant="Variant.Outlined">@KindShort(b.Kind)</MudChip></td>
                            <td>@b.At.ToLocalTime().ToString("dd MMM HH:mm")</td>
                            <td>@(b.Customer?.Name ?? "—")</td>
                            <td>@(b.Staff is null ? "—" : $"{b.Staff.Code:D2} · {b.Staff.Name}")</td>
                            <td style="text-align: right;" class="sap-amount">@b.Items.Count</td>
                            <td style="text-align: right;" class="sap-amount">₹@b.Total.ToString("N0")</td>
                            <td>
                                @foreach (var p in b.Payments.GroupBy(x => x.Method))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-0 mr-1">@p.Key ₹@p.Sum(x => x.Amount).ToString("N0")</MudChip>
                                }
                            </td>
                            <td>
                                @if (b.Status == "Posted")
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">posted</MudChip>
                                }
                                else if (b.Status == "Voided")
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">voided</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@b.Status.ToLower()</MudChip>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    }
</MudStack>

@code {
    private List<Bill> _bills = new();
    private string _search = "";
    private string _status = "all";
    private string _period = "today";
    private int _page = 0;
    private const int _pageSize = 100;
    private int _totalForRange;

    private List<Bill> Filtered => _bills;

    private async Task OnSearchChanged(string v) { _search = v ?? ""; _page = 0; await LoadAsync(); }
    private async Task OnStatusChanged(string v) { _status = v ?? "all"; _page = 0; await LoadAsync(); }
    private async Task OnPeriodChanged(string v) { _period = v ?? "today"; _page = 0; await LoadAsync(); }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private (DateTime from, DateTime to) PeriodRange()
    {
        var today = DateTime.UtcNow.Date;
        return _period switch
        {
            "today"     => (today, today.AddDays(1)),
            "yesterday" => (today.AddDays(-1), today),
            "week"      => (today.AddDays(-7), today.AddDays(1)),
            "month"     => (new DateTime(today.Year, today.Month, 1), today.AddDays(1)),
            _           => (DateTime.MinValue, DateTime.MaxValue)
        };
    }

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var (from, to) = PeriodRange();

        var q = db.Bills.AsNoTracking()
            .Include(b => b.Items)
            .Include(b => b.Payments)
            .Include(b => b.Customer)
            .Include(b => b.Staff)
            .Where(b => b.At >= from && b.At < to)
            .Where(b => _status == "all" || b.Status == _status);

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search;
            q = q.Where(b =>
                EF.Functions.Like(b.Number, $"%{s}%") ||
                (b.Customer != null && (
                    EF.Functions.Like(b.Customer.Name, $"%{s}%") ||
                    (b.Customer.Phone != null && EF.Functions.Like(b.Customer.Phone, $"%{s}%"))
                )));
        }

        _totalForRange = await q.CountAsync();
        _bills = await q.OrderByDescending(b => b.At).Skip(_page * _pageSize).Take(_pageSize).ToListAsync();
    }

    private async Task PrevPage() { if (_page > 0) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if ((_page + 1) * _pageSize < _totalForRange) { _page++; await LoadAsync(); } }

    private static string KindShort(string kind) => kind switch
    {
        "Quote" => "Quote",
        "Proforma" => "Proforma",
        "DeliveryChallan" => "Challan",
        "CashReceipt" => "Cash rcpt",
        _ => "Tax inv"
    };

    private static Color KindColor(string kind) => kind switch
    {
        "Quote" => Color.Info,
        "Proforma" => Color.Info,
        "DeliveryChallan" => Color.Warning,
        "CashReceipt" => Color.Default,
        _ => Color.Primary
    };
}
