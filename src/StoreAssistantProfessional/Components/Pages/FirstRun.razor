@page "/setup"
@using System.Globalization
@using System.Security.Cryptography
@inject ISetupService Setup
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Setup — Store Assistant Professional</PageTitle>

@if (_redirecting)
{
    <div role="status" aria-live="polite" class="sap-firstrun-redirect">
        <MudContainer Class="mt-12">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Just a moment…</MudText>
            </MudStack>
        </MudContainer>
    </div>
}
else
{
    <div class="sap-firstrun-root">
        <h1 class="sap-visually-hidden">Set up Store Assistant Professional</h1>
        <MudGrid Spacing="0">
            <MudItem xs="12" sm="6" Class="d-none d-sm-block">
                <MudPaper Elevation="0" Square="true" Class="pa-10 sap-firstrun-hero">
                    <MudIcon Icon="@Icons.Material.Rounded.ShoppingBag"
                             UserAttributes="@AriaHidden"
                             Class="sap-firstrun-hero-deco" />
                    <MudStack AlignItems="AlignItems.Center" Spacing="5" Class="sap-firstrun-hero-stack">
                        <MudText Typo="Typo.overline" Align="Align.Center" Class="sap-firstrun-hero-overline">
                            STORE ASSISTANT PROFESSIONAL
                        </MudText>

                        <MudIcon Icon="@Icons.Material.Rounded.Checkroom"
                                 UserAttributes="@AriaHidden"
                                 Class="sap-firstrun-hero-icon" />

                        <MudText Typo="Typo.h3" Align="Align.Center" Class="sap-firstrun-hero-heading">
                            @HeroHeading
                        </MudText>

                        <MudText Typo="Typo.body2" Align="Align.Center" Class="sap-firstrun-hero-next">
                            Quietly precise. Built to outlast trends.
                        </MudText>

                        <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center" Class="sap-firstrun-hero-badges">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.CloudOff" UserAttributes="@AriaHidden" Class="sap-firstrun-hero-badge-icon" />
                                <MudText Typo="Typo.caption">Offline-first</MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.MoneyOff" UserAttributes="@AriaHidden" Class="sap-firstrun-hero-badge-icon" />
                                <MudText Typo="Typo.caption">No subscription</MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.Shield" UserAttributes="@AriaHidden" Class="sap-firstrun-hero-badge-icon" />
                                <MudText Typo="Typo.caption">Private</MudText>
                            </MudStack>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" Class="sap-firstrun-form-col">
                <MudContainer MaxWidth="MaxWidth.Small" Class="pa-4 sap-firstrun-form" role="form" aria-label="First-run setup">
                    <MudStack Spacing="3">
                        @if (Setup.Status == SetupStatus.Corrupt)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Rounded.Warning">
                                An existing setup file was found but could not be read. Completing setup will replace it; the unreadable copy will be kept as <code>setup.json.bak</code> alongside it.
                            </MudAlert>
                        }
                        else if (Setup.Status == SetupStatus.Inaccessible)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Icon="@Icons.Material.Rounded.ErrorOutline">
                                Local app data is not accessible. Setup cannot be saved on this machine. Check that
                                <code>%LocalAppData%\StoreAssistantProfessional</code> is writable.
                            </MudAlert>
                        }

                        <div id="setup-blocker" class="sap-firstrun-blocker">
                            <div role="status" aria-live="polite" aria-atomic="true"
                                 class="sap-firstrun-blocker-live @(BlockingReason is null ? "" : "is-warn")">
                                @if (BlockingReason is not null)
                                {
                                    <MudIcon Icon="@Icons.Material.Rounded.EditNote"
                                             UserAttributes="@AriaHidden"
                                             Class="sap-firstrun-blocker-icon" />
                                    <MudText Typo="Typo.body2" Class="sap-firstrun-blocker-text">@BlockingReason</MudText>
                                }
                            </div>
                            @if (BlockingReason is null)
                            {
                                <div class="sap-firstrun-blocker-ready">
                                    <MudIcon Icon="@Icons.Material.Rounded.CheckCircle"
                                             UserAttributes="@AriaHidden"
                                             Class="sap-firstrun-blocker-icon" />
                                    <MudText Typo="Typo.body2" Class="sap-firstrun-blocker-text">Ready to save.</MudText>
                                </div>
                            }
                        </div>

                        <MudPaper Elevation="1" Class="pa-4 sap-firstrun-card sap-firstrun-card-firm">
                            <MudStack Spacing="3">
                                <MudText Typo="Typo.h6">Name your firm</MudText>
                                <MudTextField Value="_firmName"
                                              ValueChanged="SetFirmName"
                                              T="string"
                                              Label="Firm name"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              MaxLength="100"
                                              Immediate="true"
                                              AutoFocus="true"
                                              Disabled="@FieldsLocked"
                                              HelperText="Shown on receipts and across the app."
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(FirmNameValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                              AdornmentColor="@(FirmNameValid ? Color.Success : Color.Default)"
                                              UserAttributes="@FirmNameAttrs"
                                              OnBlur="OnFirmNameBlur"
                                              OnKeyDown="OnFirmNameKeyDown" />
                            </MudStack>
                        </MudPaper>

                        <MudPaper Elevation="1" Class="pa-4 sap-firstrun-card sap-firstrun-card-pin">
                            <MudStack Spacing="3">
                                <MudStack Row="true" Spacing="0" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.h6">Choose two PINs</MudText>
                                    <MudTooltip Text="@(_showPins ? "Hide PINs" : "Show PINs")" Placement="Placement.Top">
                                        <MudIconButton Icon="@(_showPins ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                                       Size="Size.Small"
                                                       Color="Color.Default"
                                                       Class="sap-firstrun-pin-toggle"
                                                       OnClick="TogglePins"
                                                       Disabled="@FieldsLocked"
                                                       UserAttributes="@ShowPinsAttrs" />
                                    </MudTooltip>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Default">
                                    Admin for day-to-day protected actions. Master for destructive deletions and recovery.
                                </MudText>

                                <MudStack Row="true" Spacing="2" Class="sap-firstrun-pin-row">
                                    <MudTextField @ref="_adminPinField"
                                                  Value="_adminPin"
                                                  ValueChanged="SetAdminPin"
                                                  T="string"
                                                  Label="Admin PIN"
                                                  InputType="@(_showPins ? InputType.Text : InputType.Password)"
                                                  MaxLength="4"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true"
                                                  Disabled="@FieldsLocked"
                                                  HelperText="@AdminPinHelper"
                                                  Error="@AdminPinWeak"
                                                  ErrorText="Too predictable."
                                                  Adornment="Adornment.End"
                                                  AdornmentIcon="@(AdminPinValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                  AdornmentColor="@(AdminPinValid ? Color.Success : Color.Default)"
                                                  UserAttributes="@PinAttrs"
                                                  OnKeyDown="OnKeyDown" />
                                    <MudTextField @ref="_adminPinConfirmField"
                                                  Value="_adminPinConfirm"
                                                  ValueChanged="SetAdminPinConfirm"
                                                  T="string"
                                                  Label="Confirm Admin"
                                                  InputType="@(_showPins ? InputType.Text : InputType.Password)"
                                                  MaxLength="4"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true"
                                                  Disabled="@(FieldsLocked || _adminPin.Length < 4)"
                                                  HelperText="Re-enter"
                                                  Error="@AdminConfirmMismatch"
                                                  ErrorText="Doesn't match."
                                                  Adornment="Adornment.End"
                                                  AdornmentIcon="@(AdminConfirmValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                  AdornmentColor="@(AdminConfirmValid ? Color.Success : Color.Default)"
                                                  UserAttributes="@PinAttrs"
                                                  OnKeyDown="OnKeyDown" />
                                </MudStack>

                                <MudStack Row="true" Spacing="2" Class="sap-firstrun-pin-row">
                                    <MudTextField @ref="_masterPinField"
                                                  Value="_masterPin"
                                                  ValueChanged="SetMasterPin"
                                                  T="string"
                                                  Label="Master PIN"
                                                  InputType="@(_showPins ? InputType.Text : InputType.Password)"
                                                  MaxLength="6"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true"
                                                  Disabled="@FieldsLocked"
                                                  HelperText="@MasterPinHelper"
                                                  Error="@(MasterPinWeak || MasterContainsAdmin)"
                                                  ErrorText="@MasterPinErrorText"
                                                  Adornment="Adornment.End"
                                                  AdornmentIcon="@(MasterPinValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                  AdornmentColor="@(MasterPinValid ? Color.Success : Color.Default)"
                                                  UserAttributes="@PinAttrs"
                                                  OnKeyDown="OnKeyDown" />
                                    <MudTextField @ref="_masterPinConfirmField"
                                                  Value="_masterPinConfirm"
                                                  ValueChanged="SetMasterPinConfirm"
                                                  T="string"
                                                  Label="Confirm Master"
                                                  InputType="@(_showPins ? InputType.Text : InputType.Password)"
                                                  MaxLength="6"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true"
                                                  Disabled="@(FieldsLocked || _masterPin.Length < 6)"
                                                  HelperText="Re-enter"
                                                  Error="@MasterConfirmMismatch"
                                                  ErrorText="Doesn't match."
                                                  Adornment="Adornment.End"
                                                  AdornmentIcon="@(MasterConfirmValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                  AdornmentColor="@(MasterConfirmValid ? Color.Success : Color.Default)"
                                                  UserAttributes="@PinAttrs"
                                                  OnKeyDown="OnKeyDown" />
                                </MudStack>
                            </MudStack>
                        </MudPaper>

                        <MudTooltip Text="@(BlockingReason ?? "")"
                                    Disabled="@(BlockingReason is null)"
                                    Placement="Placement.Top">
                            <MudButton OnClick="Submit"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       FullWidth="true"
                                       Disabled="@(!CanSubmit)"
                                       UserAttributes="@BlockerAriaAttrs">
                                @if (_submitting)
                                {
                                    <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                                    <span>Saving setup…</span>
                                }
                                else
                                {
                                    <span>Complete setup</span>
                                }
                            </MudButton>
                        </MudTooltip>
                    </MudStack>
                </MudContainer>
            </MudItem>
        </MudGrid>
    </div>
}

@code {
    private string _firmName = "";
    private string _adminPin = "";
    private string _adminPinConfirm = "";
    private string _masterPin = "";
    private string _masterPinConfirm = "";
    private bool _showPins;
    private bool _submitting;
    private bool _redirecting;

    private bool _adminAutoAdvanced;
    private bool _adminConfirmAutoAdvanced;
    private bool _masterAutoAdvanced;

    // Focus-after-render queue. The next-field-target is disabled in the DOM
    // until the prior field hits its required length; if we call FocusAsync
    // synchronously in the value-changed handler the call lands on a still-
    // disabled element and the browser drops it. So we record the intent and
    // run FocusAsync from OnAfterRenderAsync, after Blazor has re-rendered the
    // input with disabled=false.
    private FocusTarget _pendingFocus = FocusTarget.None;
    private enum FocusTarget { None, AdminConfirm, Master, MasterConfirm, Admin }

    private MudTextField<string>? _adminPinField;
    private MudTextField<string>? _adminPinConfirmField;
    private MudTextField<string>? _masterPinField;
    private MudTextField<string>? _masterPinConfirmField;

    private Dictionary<string, object> AriaHidden = null!;
    private Dictionary<string, object> FirmNameAttrs = null!;
    private Dictionary<string, object> PinAttrs = null!;
    private Dictionary<string, object> BlockerAriaAttrs = null!;
    private Dictionary<string, object> ShowPinsAttrs = null!;

    private bool FieldsLocked => _submitting || Setup.Status == SetupStatus.Inaccessible;

    protected override void OnInitialized()
    {
        AriaHidden = new Dictionary<string, object> { ["aria-hidden"] = "true" };
        FirmNameAttrs = new Dictionary<string, object>
        {
            ["spellcheck"] = "false",
            ["autocomplete"] = "off",
            ["aria-required"] = "true",
        };
        PinAttrs = new Dictionary<string, object>
        {
            ["autocomplete"] = "off",
            ["inputmode"] = "numeric",
            ["aria-required"] = "true",
        };
        BlockerAriaAttrs = new Dictionary<string, object> { ["aria-describedby"] = "setup-blocker" };
        ShowPinsAttrs = new Dictionary<string, object> { ["aria-label"] = "Toggle PIN visibility" };

        if (Setup.IsComplete)
        {
            _redirecting = true;
            Nav.NavigateTo("/", replace: true);
        }
    }

    private string HeroHeading
    {
        get
        {
            if (!FirmNameValid) return "Namaste";
            return $"Namaste, {TruncateGraphemes(_firmName.Trim(), 12)}";
        }
    }

    // Substring on length-by-text-element so we never split a UTF-16 surrogate pair
    // (e.g. emoji) or a multi-codepoint grapheme cluster.
    private static string TruncateGraphemes(string s, int maxGraphemes)
    {
        var enumerator = StringInfo.GetTextElementEnumerator(s);
        var count = 0;
        var endIndex = 0;
        while (enumerator.MoveNext())
        {
            count++;
            if (count > maxGraphemes - 1)
            {
                endIndex = enumerator.ElementIndex;
                break;
            }
        }
        return count <= maxGraphemes ? s : s[..endIndex] + "…";
    }

    private bool AdminPinWeak => _adminPin.Length == 4 && PinRules.IsWeak(_adminPin);
    private bool MasterPinWeak => _masterPin.Length == 6 && PinRules.IsWeak(_masterPin);
    private bool AdminConfirmMismatch => _adminPinConfirm.Length == 4 && _adminPinConfirm != _adminPin;
    private bool MasterConfirmMismatch => _masterPinConfirm.Length == 6 && _masterPinConfirm != _masterPin;
    private bool MasterContainsAdmin =>
        _masterPin.Length == 6 && _adminPin.Length == 4 &&
        _masterPin.Contains(_adminPin, StringComparison.Ordinal);

    private bool FirmNameValid => _firmName.Trim().Length >= SetupService.MinFirmNameLength;
    private bool AdminPinValid => _adminPin.Length == 4 && !PinRules.IsWeak(_adminPin);
    private bool AdminConfirmValid => _adminPinConfirm.Length == 4 && _adminPinConfirm == _adminPin;
    private bool MasterPinValid => _masterPin.Length == 6 && !PinRules.IsWeak(_masterPin) && !MasterContainsAdmin;
    private bool MasterConfirmValid => _masterPinConfirm.Length == 6 && _masterPinConfirm == _masterPin;

    private string MasterPinErrorText => MasterContainsAdmin
        ? "Contains the Admin PIN."
        : "Too predictable.";

    private string AdminPinHelper => PinRules.IsStrong(_adminPin) ? "4 digits · OK" : "4 digits";
    private string MasterPinHelper => PinRules.IsStrong(_masterPin) ? "6 digits · OK" : "6 digits";

    private bool CanSubmit =>
        !FieldsLocked &&
        FirmNameValid &&
        AdminPinValid &&
        _adminPinConfirm == _adminPin &&
        MasterPinValid &&
        _masterPinConfirm == _masterPin;

    private string? BlockingReason
    {
        get
        {
            if (Setup.Status == SetupStatus.Inaccessible)
                return "Local app data is not accessible — setup cannot be saved.";
            if (!FirmNameValid)
                return _firmName.Length == 0
                    ? "Start by naming your firm."
                    : "Firm name must be at least 2 characters.";
            if (_adminPin.Length < 4) return "Set a 4-digit Admin PIN.";
            if (PinRules.IsWeak(_adminPin)) return "Admin PIN is too predictable — try something less obvious.";
            if (_adminPinConfirm.Length < 4) return "Re-enter the Admin PIN to confirm it.";
            if (_adminPinConfirm != _adminPin) return "Admin PIN confirmation doesn't match.";
            if (_masterPin.Length < 6) return "Set a 6-digit Master PIN.";
            if (MasterContainsAdmin) return "Master PIN must not contain the Admin PIN.";
            if (PinRules.IsWeak(_masterPin)) return "Master PIN is too predictable — try something less obvious.";
            if (_masterPinConfirm.Length < 6) return "Re-enter the Master PIN to confirm it.";
            if (_masterPinConfirm != _masterPin) return "Master PIN confirmation doesn't match.";
            return null;
        }
    }

    private void SetFirmName(string v)
    {
        _firmName = v ?? "";
    }

    private void SetAdminPin(string v)
    {
        var was = _adminPin.Length;
        _adminPin = AsciiDigitsOnly(v, 4);

        // If admin shrinks below the required length, the confirm value is no longer
        // meaningful — clear it so the user retypes against the new admin.
        if (_adminPin.Length < 4 && _adminPinConfirm.Length > 0)
        {
            _adminPinConfirm = "";
            _adminConfirmAutoAdvanced = false;
        }

        if (was < 4 && _adminPin.Length == 4 && AdminPinValid &&
            !_adminAutoAdvanced && _adminPinConfirm.Length == 0)
        {
            _adminAutoAdvanced = true;
            _pendingFocus = FocusTarget.AdminConfirm;
        }
        if (_adminPin.Length < 4) _adminAutoAdvanced = false;
    }

    private void SetAdminPinConfirm(string v)
    {
        var was = _adminPinConfirm.Length;
        _adminPinConfirm = AsciiDigitsOnly(v, 4);
        if (was < 4 && _adminPinConfirm.Length == 4 && AdminConfirmValid &&
            !_adminConfirmAutoAdvanced && _masterPin.Length == 0)
        {
            _adminConfirmAutoAdvanced = true;
            _pendingFocus = FocusTarget.Master;
        }
        if (_adminPinConfirm.Length < 4) _adminConfirmAutoAdvanced = false;
    }

    private void SetMasterPin(string v)
    {
        var was = _masterPin.Length;
        _masterPin = AsciiDigitsOnly(v, 6);

        if (_masterPin.Length < 6 && _masterPinConfirm.Length > 0)
        {
            _masterPinConfirm = "";
            _masterAutoAdvanced = false;
        }

        if (was < 6 && _masterPin.Length == 6 && MasterPinValid &&
            !_masterAutoAdvanced && _masterPinConfirm.Length == 0)
        {
            _masterAutoAdvanced = true;
            _pendingFocus = FocusTarget.MasterConfirm;
        }
        if (_masterPin.Length < 6) _masterAutoAdvanced = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingFocus == FocusTarget.None) return;
        var target = _pendingFocus;
        _pendingFocus = FocusTarget.None;

        var field = target switch
        {
            FocusTarget.Admin         => _adminPinField,
            FocusTarget.AdminConfirm  => _adminPinConfirmField,
            FocusTarget.Master        => _masterPinField,
            FocusTarget.MasterConfirm => _masterPinConfirmField,
            _ => null,
        };
        if (field is null) return;
        try { await field.FocusAsync(); }
        catch { /* WebView2 can be mid-teardown during navigation; ignore */ }
    }

    private void SetMasterPinConfirm(string v)
    {
        _masterPinConfirm = AsciiDigitsOnly(v, 6);
    }

    private static string AsciiDigitsOnly(string s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "";
        Span<char> buf = stackalloc char[Math.Min(s.Length, max)];
        var n = 0;
        for (var i = 0; i < s.Length && n < max; i++)
            if (s[i] is >= '0' and <= '9') buf[n++] = s[i];
        return new string(buf[..n]);
    }

    private static string StripParamSuffix(string message)
    {
        var i = message.IndexOf(" (Parameter ", StringComparison.Ordinal);
        return i >= 0 ? message[..i] : message;
    }

    private void TogglePins()
    {
        // Swapping InputType (Password ↔ Text) tears down and rebuilds the
        // <input> element, which kicks the caret out of the field. Restore
        // focus to whichever PIN field the user is currently editing so they
        // can keep typing without reaching for the mouse.
        _showPins = !_showPins;
        _pendingFocus = ActivePinField();
    }

    // Best-guess "which field is the user on right now" — the first one with
    // remaining capacity, in entry order. Good enough for the eye-toggle case.
    private FocusTarget ActivePinField()
    {
        if (_adminPin.Length < 4) return FocusTarget.Admin;
        if (_adminPinConfirm.Length < 4) return FocusTarget.AdminConfirm;
        if (_masterPin.Length < 6) return FocusTarget.Master;
        if (_masterPinConfirm.Length < 6) return FocusTarget.MasterConfirm;
        return FocusTarget.MasterConfirm;
    }

    private void OnFirmNameBlur()
    {
        _firmName = _firmName.Trim();
    }

    private void OnFirmNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (FirmNameValid) _pendingFocus = FocusTarget.Admin;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (CanSubmit)
        {
            await Submit();
        }
        else if (BlockingReason is { } reason)
        {
            // Keyboard users don't see the disabled-button tooltip — surface the reason here.
            Snackbar.Add(reason, Severity.Info, config => config.VisibleStateDuration = 4000);
        }
    }

    private async Task Submit()
    {
        if (_submitting) return;
        _submitting = true;
        try
        {
            // Snapshot field values so a thread-pool Task.Run can't read mutated state
            // if anything (test, late event) changes them during PBKDF2.
            var name = _firmName.Trim();
            var admin = _adminPin;
            var master = _masterPin;

            try
            {
                await Task.Run(() => Setup.Save(name, admin, master));
            }
            catch (ArgumentException ex)
            {
                ShowError(StripParamSuffix(ex.Message));
                return;
            }
            catch (IOException ex)
            {
                ShowError($"Could not save setup: {ex.Message}");
                return;
            }
            catch (UnauthorizedAccessException ex)
            {
                ShowError($"Could not save setup: {ex.Message}");
                return;
            }
            catch (CryptographicException ex)
            {
                ShowError($"Could not secure your PINs: {ex.Message}");
                return;
            }
            catch (Exception ex)
            {
                ShowError($"Setup failed: {ex.Message}");
                return;
            }

            _adminPin = _adminPinConfirm = _masterPin = _masterPinConfirm = "";

            _redirecting = true;
            Nav.NavigateTo("/", replace: true);
        }
        finally
        {
            if (!_redirecting) _submitting = false;
        }
    }

    private void ShowError(string message) =>
        Snackbar.Add(message, Severity.Error, config =>
        {
            config.ShowCloseIcon = true;
            config.VisibleStateDuration = 10000;
        });
}
