@page "/setup"
@inject ISetupService Setup
@inject NavigationManager Nav

<PageTitle>Setup — Store Assistant Professional</PageTitle>

@if (!_redirecting)
{
    <MudGrid Spacing="0" Style="min-height: 100vh;">
        <MudItem xs="12" md="5">
            <MudPaper Elevation="0"
                      Square="true"
                      Class="mud-theme-primary pa-12 d-flex flex-column justify-center align-center"
                      Style="min-height: 100vh;">
                <MudStack AlignItems="AlignItems.Center" Spacing="5" Class="mt-8">
                    <MudIcon Icon="@Icons.Material.Rounded.Storefront"
                             Size="Size.Large"
                             Style="font-size: 96px;" />
                    <MudText Typo="Typo.h3" Align="Align.Center">
                        @(StoreNameValid ? $"Welcome, {_storeName.Trim()}" : "Welcome")
                    </MudText>
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="opacity: 0.9;">
                        Let's set up your store.
                    </MudText>
                    <MudDivider Style="width: 60px; border-color: rgba(255,255,255,0.5); border-width: 2px;" />
                    <MudText Typo="Typo.body1" Align="Align.Center" Style="opacity: 0.85; max-width: 320px;">
                        A quick one-time setup: give your store a name and pick two PINs. Takes under a minute.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudContainer MaxWidth="MaxWidth.Small" Class="pa-8 d-flex flex-column justify-center" Style="min-height: 100vh;">
                <MudStack Spacing="4">
                    @if (Setup.Status == SetupStatus.Corrupt)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Rounded.Warning">
                            An existing setup file was found but could not be read. Completing setup will replace it.
                        </MudAlert>
                    }

                    <MudText Typo="Typo.h5">Tell us about your store</MudText>

                    <MudTextField @bind-Value="_storeName"
                                  Label="Store name"
                                  Variant="Variant.Outlined"
                                  MaxLength="100"
                                  Immediate="true"
                                  AutoFocus="true"
                                  HelperText="Shown on receipts and across the app."
                                  Error="@(_submitAttempted && string.IsNullOrWhiteSpace(_storeName))"
                                  ErrorText="Store name is required."
                                  Adornment="@(StoreNameValid ? Adornment.End : Adornment.None)"
                                  AdornmentIcon="@Icons.Material.Rounded.CheckCircle"
                                  AdornmentColor="Color.Success"
                                  OnKeyDown="OnKeyDown" />

                    <MudDivider />

                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h6">Choose two PINs</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Admin for day-to-day protected actions. Master for destructive deletions and recovery.
                        </MudText>
                    </MudStack>

                    <MudStack Row="true" Spacing="2">
                        <MudTextField Value="_adminPin"
                                      ValueChanged="SetAdminPin"
                                      T="string"
                                      Label="Admin PIN"
                                      InputType="@(_showAdminPin ? InputType.Text : InputType.Password)"
                                      MaxLength="4"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      HelperText="4 digits"
                                      Error="@AdminPinWeak"
                                      ErrorText="Too predictable."
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(_showAdminPin ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                      AdornmentColor="@(AdminPinValid ? Color.Success : Color.Default)"
                                      OnAdornmentClick="ToggleShowAdmin"
                                      OnKeyDown="OnKeyDown" />
                        <MudTextField Value="_adminPinConfirm"
                                      ValueChanged="SetAdminPinConfirm"
                                      T="string"
                                      Label="Confirm"
                                      InputType="@(_showAdminPin ? InputType.Text : InputType.Password)"
                                      MaxLength="4"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      HelperText="Re-enter"
                                      Error="@AdminConfirmMismatch"
                                      ErrorText="Doesn't match."
                                      Adornment="@(AdminConfirmValid ? Adornment.End : Adornment.None)"
                                      AdornmentIcon="@Icons.Material.Rounded.CheckCircle"
                                      AdornmentColor="Color.Success"
                                      OnKeyDown="OnKeyDown" />
                    </MudStack>

                    <MudStack Row="true" Spacing="2">
                        <MudTextField Value="_masterPin"
                                      ValueChanged="SetMasterPin"
                                      T="string"
                                      Label="Master PIN"
                                      InputType="@(_showMasterPin ? InputType.Text : InputType.Password)"
                                      MaxLength="6"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      HelperText="6 digits"
                                      Error="@(MasterPinWeak || MasterStartsWithAdmin)"
                                      ErrorText="@MasterPinErrorText"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(_showMasterPin ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                      AdornmentColor="@(MasterPinValid ? Color.Success : Color.Default)"
                                      OnAdornmentClick="ToggleShowMaster"
                                      OnKeyDown="OnKeyDown" />
                        <MudTextField Value="_masterPinConfirm"
                                      ValueChanged="SetMasterPinConfirm"
                                      T="string"
                                      Label="Confirm"
                                      InputType="@(_showMasterPin ? InputType.Text : InputType.Password)"
                                      MaxLength="6"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      HelperText="Re-enter"
                                      Error="@MasterConfirmMismatch"
                                      ErrorText="Doesn't match."
                                      Adornment="@(MasterConfirmValid ? Adornment.End : Adornment.None)"
                                      AdornmentIcon="@Icons.Material.Rounded.CheckCircle"
                                      AdornmentColor="Color.Success"
                                      OnKeyDown="OnKeyDown" />
                    </MudStack>

                    <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Rounded.Key" Variant="Variant.Outlined">
                        Save the Master PIN somewhere safe — it's your recovery key and the only way to delete major records.
                    </MudAlert>

                    <MudCheckBox T="bool"
                                 @bind-Value="_acknowledgedMaster"
                                 Color="Color.Tertiary"
                                 Dense="true">
                        I have saved the Master PIN somewhere safe.
                    </MudCheckBox>

                    <MudStack Spacing="1" Class="pl-1">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@(StoreNameValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                     Color="@(StoreNameValid ? Color.Success : Color.Default)"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.body2" Color="@(StoreNameValid ? Color.Default : Color.Secondary)">
                                Store name
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@((AdminPinValid && AdminConfirmValid) ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                     Color="@((AdminPinValid && AdminConfirmValid) ? Color.Success : Color.Default)"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.body2" Color="@((AdminPinValid && AdminConfirmValid) ? Color.Default : Color.Secondary)">
                                Admin PIN set
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@((MasterPinValid && MasterConfirmValid) ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                     Color="@((MasterPinValid && MasterConfirmValid) ? Color.Success : Color.Default)"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.body2" Color="@((MasterPinValid && MasterConfirmValid) ? Color.Default : Color.Secondary)">
                                Master PIN set
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@(_acknowledgedMaster ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                     Color="@(_acknowledgedMaster ? Color.Success : Color.Default)"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.body2" Color="@(_acknowledgedMaster ? Color.Default : Color.Secondary)">
                                Master PIN saved somewhere safe
                            </MudText>
                        </MudStack>
                    </MudStack>

                    @if (_error is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                    }

                    <MudButton OnClick="Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               FullWidth="true"
                               EndIcon="@Icons.Material.Rounded.ArrowForward"
                               Disabled="@(!CanSubmit)">
                        Complete setup
                    </MudButton>
                </MudStack>
            </MudContainer>
        </MudItem>
    </MudGrid>
}

@code {
    private string _storeName = "";
    private string _adminPin = "";
    private string _adminPinConfirm = "";
    private string _masterPin = "";
    private string _masterPinConfirm = "";
    private bool _showAdminPin;
    private bool _showMasterPin;
    private bool _acknowledgedMaster;
    private bool _submitAttempted;
    private string? _error;
    private bool _redirecting;

    protected override void OnInitialized()
    {
        if (Setup.IsComplete)
        {
            _redirecting = true;
            Nav.NavigateTo("/", replace: true);
        }
    }

    private bool AdminPinWeak => _adminPin.Length == 4 && PinRules.IsWeak(_adminPin);
    private bool MasterPinWeak => _masterPin.Length == 6 && PinRules.IsWeak(_masterPin);
    private bool AdminConfirmMismatch => _adminPinConfirm.Length == 4 && _adminPinConfirm != _adminPin;
    private bool MasterConfirmMismatch => _masterPinConfirm.Length == 6 && _masterPinConfirm != _masterPin;
    private bool MasterStartsWithAdmin =>
        _masterPin.Length == 6 && _adminPin.Length == 4 &&
        _masterPin.StartsWith(_adminPin, StringComparison.Ordinal);

    private bool StoreNameValid => !string.IsNullOrWhiteSpace(_storeName);
    private bool AdminPinValid => _adminPin.Length == 4 && !PinRules.IsWeak(_adminPin);
    private bool AdminConfirmValid => _adminPinConfirm.Length == 4 && _adminPinConfirm == _adminPin;
    private bool MasterPinValid => _masterPin.Length == 6 && !PinRules.IsWeak(_masterPin) && !MasterStartsWithAdmin;
    private bool MasterConfirmValid => _masterPinConfirm.Length == 6 && _masterPinConfirm == _masterPin;

    private string MasterPinErrorText => MasterStartsWithAdmin
        ? "Must not start with the Admin PIN."
        : "Too predictable.";

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(_storeName) &&
        _adminPin.Length == 4 && !PinRules.IsWeak(_adminPin) &&
        _adminPinConfirm == _adminPin &&
        _masterPin.Length == 6 && !PinRules.IsWeak(_masterPin) &&
        !MasterStartsWithAdmin &&
        _masterPinConfirm == _masterPin &&
        _acknowledgedMaster;

    private void SetAdminPin(string v) => _adminPin = DigitsOnly(v, 4);
    private void SetAdminPinConfirm(string v) => _adminPinConfirm = DigitsOnly(v, 4);
    private void SetMasterPin(string v) => _masterPin = DigitsOnly(v, 6);
    private void SetMasterPinConfirm(string v) => _masterPinConfirm = DigitsOnly(v, 6);

    private static string DigitsOnly(string s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "";
        var filtered = new string(s.Where(char.IsDigit).ToArray());
        return filtered.Length > max ? filtered[..max] : filtered;
    }

    private void ToggleShowAdmin() => _showAdminPin = !_showAdminPin;
    private void ToggleShowMaster() => _showMasterPin = !_showMasterPin;

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && CanSubmit) Submit();
    }

    private void Submit()
    {
        _submitAttempted = true;
        _error = null;

        var name = _storeName.Trim();
        if (string.IsNullOrEmpty(name)) { _error = "Store name is required."; return; }

        try
        {
            Setup.Save(name, _adminPin, _masterPin);
        }
        catch (IOException ex)
        {
            _error = $"Could not save setup: {ex.Message}";
            return;
        }
        catch (UnauthorizedAccessException ex)
        {
            _error = $"Could not save setup: {ex.Message}";
            return;
        }

        _redirecting = true;
        Nav.NavigateTo("/", replace: true);
    }
}
