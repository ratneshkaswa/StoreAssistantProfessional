@page "/setup"
@using StoreAssistantProfessional.Theme
@inject ISetupService Setup
@inject NavigationManager Nav

<PageTitle>Setup — Store Assistant Professional</PageTitle>

@if (!_redirecting)
{
    <main>
        <MudGrid Spacing="0" Style="min-height: 100vh;">
            <MudItem xs="12" md="6">
                <MudPaper Elevation="0"
                          Square="true"
                          Class="pa-10 d-flex flex-column align-center"
                          Style="@HeroStyle">
                    <MudIcon Icon="@Icons.Material.Rounded.ShoppingBag"
                             UserAttributes="@AriaHidden"
                             Style="position: absolute; bottom: -60px; right: -60px; font-size: 320px; opacity: 0.1; pointer-events: none;" />
                    <MudStack AlignItems="AlignItems.Center" Spacing="3" Style="position: relative; z-index: 1;">
                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.overline" Align="Align.Center" Style="letter-spacing: 2px; opacity: 0.9;">
                                STORE ASSISTANT PROFESSIONAL
                            </MudText>
                            <MudText Typo="Typo.caption" Align="Align.Center" Style="letter-spacing: 2px; opacity: 0.65;">
                                MADE IN INDIA · EST. 2026
                            </MudText>
                        </MudStack>

                        <div style="position: relative; width: 120px; height: 120px;">
                            <svg width="120" height="120" style="position: absolute; inset: 0; transform: rotate(-90deg);">
                                <circle cx="60" cy="60" r="52" stroke="rgba(74,47,26,0.18)" stroke-width="4" fill="none" />
                                <circle cx="60" cy="60" r="52" stroke="@BrandTheme.HeroTextColor" stroke-width="4" fill="none"
                                        stroke-dasharray="@RingCircumference.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                        stroke-dashoffset="@ProgressDashOffset.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                        stroke-linecap="round" />
                            </svg>
                            @if (StoreNameValid)
                            {
                                <MudText Align="Align.Center"
                                         Style="font-family: Georgia, 'Times New Roman', serif; font-weight: 600; font-size: 44px; letter-spacing: 2px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                                    @StoreInitials
                                </MudText>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Rounded.Storefront"
                                         UserAttributes="@AriaHidden"
                                         Style="font-size: 56px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);" />
                            }
                        </div>

                        <MudText Typo="Typo.h4"
                                 Align="Align.Center"
                                 Style="font-family: Georgia, 'Times New Roman', serif; line-height: 1.15; max-width: 480px; word-break: break-word;">
                            @HeroHeading
                        </MudText>
                        <MudText Typo="Typo.h6" Align="Align.Center" Style="opacity: 0.85; font-style: italic;">
                            @(_completed ? "Opening your store…" : "A quieter POS for menswear and garment retail.")
                        </MudText>

                        <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center" Class="mt-3">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@(StoreNameValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.Storefront)"
                                         Color="@(StoreNameValid ? Color.Success : Color.Inherit)"
                                         UserAttributes="@AriaHidden"
                                         Style="font-size: 20px;" />
                                <MudText Typo="Typo.caption">1. Name</MudText>
                            </MudStack>
                            <MudIcon Icon="@Icons.Material.Rounded.ChevronRight"
                                     UserAttributes="@AriaHidden"
                                     Style="font-size: 16px; opacity: 0.35;" />
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@(AllPinsSet ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.Key)"
                                         Color="@(AllPinsSet ? Color.Success : Color.Tertiary)"
                                         UserAttributes="@AriaHidden"
                                         Style="font-size: 20px;" />
                                <MudText Typo="Typo.caption">2. PINs</MudText>
                            </MudStack>
                            <MudIcon Icon="@Icons.Material.Rounded.ChevronRight"
                                     UserAttributes="@AriaHidden"
                                     Style="font-size: 16px; opacity: 0.35;" />
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@(_acknowledgedMaster ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.BookmarkBorder)"
                                         Color="@(_acknowledgedMaster ? Color.Success : Color.Inherit)"
                                         UserAttributes="@AriaHidden"
                                         Style="font-size: 20px;" />
                                <MudText Typo="Typo.caption">3. Save</MudText>
                            </MudStack>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudContainer MaxWidth="MaxWidth.Small" Class="pa-8 d-flex flex-column" Style="min-height: 100vh; justify-content: safe center;">
                    @if (_completed)
                    {
                        <MudStack AlignItems="AlignItems.Center" Spacing="4">
                            <MudIcon Icon="@Icons.Material.Rounded.CheckCircle"
                                     Color="Color.Success"
                                     Style="font-size: 120px;" />
                            <MudText Typo="Typo.h4" Align="Align.Center">You're all set!</MudText>
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center">
                                Opening your store…
                            </MudText>
                        </MudStack>
                    }
                    else
                    {
                        <MudStack Spacing="3">
                            @if (Setup.Status == SetupStatus.Corrupt)
                            {
                                <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Rounded.Warning">
                                    An existing setup file was found but could not be read. Completing setup will replace it.
                                </MudAlert>
                            }

                            <MudPaper Elevation="1" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-primary);">
                                <MudStack Spacing="3">
                                    <MudText Typo="Typo.h6">Name your store</MudText>
                                    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                                        <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Medium" Style="flex: 0 0 40px; margin-top: 16px;">
                                            <MudIcon Icon="@Icons.Material.Rounded.Storefront" UserAttributes="@AriaHidden" Style="font-size: 22px;" />
                                        </MudAvatar>
                                        <div style="flex: 1;">
                                            <MudTextField @bind-Value="_storeName"
                                                          Label="Store name"
                                                          Variant="Variant.Outlined"
                                                          MaxLength="100"
                                                          Immediate="true"
                                                          AutoFocus="true"
                                                          HelperText="Shown on receipts and across the app."
                                                          Error="@(_submitAttempted && !StoreNameValid)"
                                                          ErrorText="@StoreNameErrorText"
                                                          Adornment="@(StoreNameValid ? Adornment.End : Adornment.None)"
                                                          AdornmentIcon="@Icons.Material.Rounded.CheckCircle"
                                                          AdornmentColor="Color.Success"
                                                          OnKeyDown="OnKeyDown" />
                                        </div>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>

                            <MudPaper Elevation="1" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-secondary);">
                                <MudStack Spacing="3">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.h6">Choose two PINs</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Admin for day-to-day protected actions. Master for destructive deletions and recovery.
                                        </MudText>
                                    </MudStack>

                                    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Style="flex: 0 0 40px; margin-top: 16px;">
                                            <MudIcon Icon="@Icons.Material.Rounded.Lock" UserAttributes="@AriaHidden" Style="font-size: 22px;" />
                                        </MudAvatar>
                                        <MudStack Row="true" Spacing="2" Style="flex: 1;">
                                            <MudTextField @ref="_adminPinField"
                                                          Value="_adminPin"
                                                          ValueChanged="SetAdminPin"
                                                          T="string"
                                                          Label="Admin PIN"
                                                          InputType="@(_showAdminPin ? InputType.Text : InputType.Password)"
                                                          MaxLength="4"
                                                          Variant="Variant.Outlined"
                                                          Immediate="true"
                                                          Disabled="@(!StoreNameValid)"
                                                          HelperText="4 digits"
                                                          Error="@AdminPinWeak"
                                                          ErrorText="Too predictable."
                                                          Adornment="Adornment.End"
                                                          AdornmentIcon="@(_showAdminPin ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                                          AdornmentColor="@(AdminPinValid ? Color.Success : Color.Default)"
                                                          OnAdornmentClick="ToggleShowAdmin"
                                                          OnKeyDown="OnKeyDown" />
                                            <MudTextField @ref="_adminPinConfirmField"
                                                          Value="_adminPinConfirm"
                                                          ValueChanged="SetAdminPinConfirm"
                                                          T="string"
                                                          Label="Confirm"
                                                          InputType="@(_showAdminPin ? InputType.Text : InputType.Password)"
                                                          MaxLength="4"
                                                          Variant="Variant.Outlined"
                                                          Immediate="true"
                                                          Disabled="@(!StoreNameValid)"
                                                          HelperText="Re-enter"
                                                          Error="@AdminConfirmMismatch"
                                                          ErrorText="Doesn't match the PIN above."
                                                          Adornment="@(AdminConfirmValid ? Adornment.End : Adornment.None)"
                                                          AdornmentIcon="@Icons.Material.Rounded.CheckCircle"
                                                          AdornmentColor="Color.Success"
                                                          OnKeyDown="OnKeyDown" />
                                        </MudStack>
                                    </MudStack>

                                    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                                        <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Medium" Style="flex: 0 0 40px; margin-top: 16px;">
                                            <MudIcon Icon="@Icons.Material.Rounded.Key" UserAttributes="@AriaHidden" Style="font-size: 22px;" />
                                        </MudAvatar>
                                        <MudStack Row="true" Spacing="2" Style="flex: 1;">
                                            <MudTextField @ref="_masterPinField"
                                                          Value="_masterPin"
                                                          ValueChanged="SetMasterPin"
                                                          T="string"
                                                          Label="Master PIN"
                                                          InputType="@(_showMasterPin ? InputType.Text : InputType.Password)"
                                                          MaxLength="6"
                                                          Variant="Variant.Outlined"
                                                          Immediate="true"
                                                          Disabled="@(!StoreNameValid)"
                                                          HelperText="6 digits"
                                                          Error="@(MasterPinWeak || MasterStartsWithAdmin)"
                                                          ErrorText="@MasterPinErrorText"
                                                          Adornment="Adornment.End"
                                                          AdornmentIcon="@(_showMasterPin ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                                          AdornmentColor="@(MasterPinValid ? Color.Success : Color.Default)"
                                                          OnAdornmentClick="ToggleShowMaster"
                                                          OnKeyDown="OnKeyDown" />
                                            <MudTextField @ref="_masterPinConfirmField"
                                                          Value="_masterPinConfirm"
                                                          ValueChanged="SetMasterPinConfirm"
                                                          T="string"
                                                          Label="Confirm"
                                                          InputType="@(_showMasterPin ? InputType.Text : InputType.Password)"
                                                          MaxLength="6"
                                                          Variant="Variant.Outlined"
                                                          Immediate="true"
                                                          Disabled="@(!StoreNameValid)"
                                                          HelperText="Re-enter"
                                                          Error="@MasterConfirmMismatch"
                                                          ErrorText="Doesn't match the PIN above."
                                                          Adornment="@(MasterConfirmValid ? Adornment.End : Adornment.None)"
                                                          AdornmentIcon="@Icons.Material.Rounded.CheckCircle"
                                                          AdornmentColor="Color.Success"
                                                          OnKeyDown="OnKeyDown" />
                                        </MudStack>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>

                            <MudPaper Elevation="1" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-tertiary);">
                                <MudStack Spacing="3">
                                    <MudText Typo="Typo.h6">Confirm &amp; continue</MudText>

                                    <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Rounded.Key">
                                        Save the Master PIN somewhere safe — it's your recovery key and the only way to delete major records.
                                    </MudAlert>

                                    <MudCheckBox T="bool"
                                                 @bind-Value="_acknowledgedMaster"
                                                 Color="Color.Primary"
                                                 Disabled="@(!AllPinsSet)">
                                        I have saved the Master PIN somewhere safe.
                                    </MudCheckBox>

                                    @if (_error is not null)
                                    {
                                        <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                                    }

                                    <MudButton OnClick="Submit"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Large"
                                               FullWidth="true"
                                               Disabled="@(!CanSubmit)">
                                        Complete setup
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        </MudStack>
                    }
                </MudContainer>
            </MudItem>
        </MudGrid>
    </main>
}

@code {
    private const double RingCircumference = 326.73;

    private string _storeName = "";
    private string _adminPin = "";
    private string _adminPinConfirm = "";
    private string _masterPin = "";
    private string _masterPinConfirm = "";
    private bool _showAdminPin;
    private bool _showMasterPin;
    private bool _acknowledgedMaster;
    private bool _submitAttempted;
    private bool _completed;
    private string? _error;
    private bool _redirecting;

    private bool _advancedFromAdminPin;
    private bool _advancedFromAdminConfirm;
    private bool _advancedFromMasterPin;

    private MudTextField<string>? _adminPinField;
    private MudTextField<string>? _adminPinConfirmField;
    private MudTextField<string>? _masterPinField;
    private MudTextField<string>? _masterPinConfirmField;

    private static readonly Dictionary<string, object?> AriaHidden = new() { ["aria-hidden"] = "true" };

    private static readonly string HeroStyle =
        $"min-height: 100vh; position: relative; overflow: hidden; " +
        $"justify-content: safe center; " +
        $"background: linear-gradient(315deg, #F5D4B5 0%, #E8B584 45%, #D9A5A5 100%); " +
        $"color: {BrandTheme.HeroTextColor};";

    protected override void OnInitialized()
    {
        if (Setup.IsComplete)
        {
            _redirecting = true;
            Nav.NavigateTo("/", replace: true);
        }
    }

    private string HeroHeading => _completed
        ? $"You're all set, {_storeName.Trim()}"
        : StoreNameValid
            ? $"Namaste, {_storeName.Trim()}"
            : "Namaste";

    private string StoreInitials
    {
        get
        {
            var trimmed = _storeName.Trim();
            if (trimmed.Length == 0) return "";
            var words = trimmed.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (words.Length == 0) return "";
            if (words.Length == 1)
                return words[0].Length >= 2
                    ? words[0][..2].ToUpperInvariant()
                    : words[0][..1].ToUpperInvariant();
            return $"{char.ToUpperInvariant(words[0][0])}{char.ToUpperInvariant(words[1][0])}";
        }
    }

    private bool AdminPinWeak => _adminPin.Length == 4 && PinRules.IsWeak(_adminPin);
    private bool MasterPinWeak => _masterPin.Length == 6 && PinRules.IsWeak(_masterPin);
    private bool AdminConfirmMismatch => _adminPinConfirm.Length == 4 && _adminPinConfirm != _adminPin;
    private bool MasterConfirmMismatch => _masterPinConfirm.Length == 6 && _masterPinConfirm != _masterPin;
    private bool MasterStartsWithAdmin =>
        _masterPin.Length == 6 && _adminPin.Length == 4 &&
        _masterPin.StartsWith(_adminPin, StringComparison.Ordinal);

    private bool StoreNameValid => _storeName.Trim().Length >= 2;
    private bool AdminPinValid => _adminPin.Length == 4 && !PinRules.IsWeak(_adminPin);
    private bool AdminConfirmValid => _adminPinConfirm.Length == 4 && _adminPinConfirm == _adminPin;
    private bool MasterPinValid => _masterPin.Length == 6 && !PinRules.IsWeak(_masterPin) && !MasterStartsWithAdmin;
    private bool MasterConfirmValid => _masterPinConfirm.Length == 6 && _masterPinConfirm == _masterPin;
    private bool AllPinsSet => AdminPinValid && AdminConfirmValid && MasterPinValid && MasterConfirmValid;

    private int ProgressSteps =>
        (StoreNameValid ? 1 : 0) +
        ((AdminPinValid && AdminConfirmValid) ? 1 : 0) +
        ((MasterPinValid && MasterConfirmValid) ? 1 : 0) +
        (_acknowledgedMaster ? 1 : 0);

    private double ProgressDashOffset =>
        RingCircumference * (1.0 - ProgressSteps / 4.0);

    private string StoreNameErrorText =>
        string.IsNullOrWhiteSpace(_storeName)
            ? "Store name is required."
            : "Store name must be at least 2 characters.";

    private string MasterPinErrorText => MasterStartsWithAdmin
        ? "Must not start with the Admin PIN."
        : "Too predictable.";

    private bool CanSubmit =>
        StoreNameValid &&
        _adminPin.Length == 4 && !PinRules.IsWeak(_adminPin) &&
        _adminPinConfirm == _adminPin &&
        _masterPin.Length == 6 && !PinRules.IsWeak(_masterPin) &&
        !MasterStartsWithAdmin &&
        _masterPinConfirm == _masterPin &&
        _acknowledgedMaster;

    private async Task SetAdminPin(string v)
    {
        _adminPin = DigitsOnly(v, 4);
        if (!_advancedFromAdminPin && AdminPinValid && _adminPinConfirm.Length == 0 && _adminPinConfirmField is not null)
        {
            _advancedFromAdminPin = true;
            await _adminPinConfirmField.FocusAsync();
        }
    }

    private async Task SetAdminPinConfirm(string v)
    {
        _adminPinConfirm = DigitsOnly(v, 4);
        if (!_advancedFromAdminConfirm && AdminConfirmValid && _masterPin.Length == 0 && _masterPinField is not null)
        {
            _advancedFromAdminConfirm = true;
            await _masterPinField.FocusAsync();
        }
    }

    private async Task SetMasterPin(string v)
    {
        _masterPin = DigitsOnly(v, 6);
        if (!_advancedFromMasterPin && MasterPinValid && _masterPinConfirm.Length == 0 && _masterPinConfirmField is not null)
        {
            _advancedFromMasterPin = true;
            await _masterPinConfirmField.FocusAsync();
        }
    }

    private void SetMasterPinConfirm(string v) => _masterPinConfirm = DigitsOnly(v, 6);

    private static string DigitsOnly(string s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "";
        var filtered = new string(s.Where(char.IsDigit).ToArray());
        return filtered.Length > max ? filtered[..max] : filtered;
    }

    private void ToggleShowAdmin() => _showAdminPin = !_showAdminPin;
    private void ToggleShowMaster() => _showMasterPin = !_showMasterPin;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && CanSubmit) await Submit();
    }

    private async Task Submit()
    {
        _submitAttempted = true;
        _error = null;

        try
        {
            Setup.Save(_storeName.Trim(), _adminPin, _masterPin);
        }
        catch (ArgumentException ex)
        {
            _error = ex.Message;
            return;
        }
        catch (IOException ex)
        {
            _error = $"Could not save setup: {ex.Message}";
            return;
        }
        catch (UnauthorizedAccessException ex)
        {
            _error = $"Could not save setup: {ex.Message}";
            return;
        }

        _completed = true;
        await Task.Delay(700);

        _redirecting = true;
        Nav.NavigateTo("/", replace: true);
    }
}
