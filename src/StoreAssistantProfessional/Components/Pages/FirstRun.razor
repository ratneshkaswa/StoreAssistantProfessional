@page "/setup"
@inject ISetupService Setup
@inject NavigationManager Nav

<PageTitle>Setup — Store Assistant Professional</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 mb-8">
    @if (!_redirecting)
    {
        <MudStack Spacing="4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Rounded.Storefront" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h4">First-run setup</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Welcome. Give your store a name and set two PINs to get started.
            </MudText>

            @if (Setup.Status == SetupStatus.Corrupt)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Rounded.Warning">
                    An existing setup file was found but could not be read. Completing setup will replace it.
                </MudAlert>
            }

            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.h6">Store</MudText>
                    <MudTextField @bind-Value="_storeName"
                                  Label="Store name"
                                  Variant="Variant.Outlined"
                                  MaxLength="100"
                                  Immediate="true"
                                  AutoFocus="true"
                                  HelperText="Shown on receipts and across the app."
                                  Error="@(_submitAttempted && string.IsNullOrWhiteSpace(_storeName))"
                                  ErrorText="Store name is required."
                                  OnKeyDown="OnKeyDown" />
                </MudStack>
            </MudPaper>

            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Spacing="4">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h6">Security</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Two PINs protect the app. Pick numbers you will remember but others will not guess.
                        </MudText>
                    </MudStack>

                    <MudStack Spacing="2">
                        <MudText Typo="Typo.subtitle2">Admin PIN</MudText>
                        <MudStack Row="true" Spacing="2">
                            <MudTextField Value="_adminPin"
                                          ValueChanged="SetAdminPin"
                                          T="string"
                                          Label="PIN"
                                          InputType="@(_showAdminPin ? InputType.Text : InputType.Password)"
                                          InputMode="InputMode.numeric"
                                          MaxLength="4"
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          HelperText="4 digits. Protected actions (refunds, stock edits, cancellations)."
                                          Error="@AdminPinWeak"
                                          ErrorText="Avoid repeating patterns like 1234, 1111, or 1212."
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showAdminPin ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                          OnAdornmentClick="ToggleShowAdmin"
                                          @onfocusin="OnAdminPinFocus"
                                          OnKeyDown="OnKeyDown" />
                            <MudTextField Value="_adminPinConfirm"
                                          ValueChanged="SetAdminPinConfirm"
                                          T="string"
                                          Label="Confirm"
                                          InputType="@(_showAdminPin ? InputType.Text : InputType.Password)"
                                          InputMode="InputMode.numeric"
                                          MaxLength="4"
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          HelperText="Re-enter to confirm."
                                          Error="@AdminConfirmMismatch"
                                          ErrorText="Doesn't match."
                                          @onfocusin="OnAdminConfirmFocus"
                                          OnKeyDown="OnKeyDown" />
                        </MudStack>
                        <PinNumpad OnAppend="AdminAppend"
                                   OnBackspace="AdminBackspace"
                                   OnClear="AdminClear" />
                    </MudStack>

                    <MudDivider />

                    <MudStack Spacing="2">
                        <MudText Typo="Typo.subtitle2">Master PIN</MudText>
                        <MudStack Row="true" Spacing="2">
                            <MudTextField Value="_masterPin"
                                          ValueChanged="SetMasterPin"
                                          T="string"
                                          Label="PIN"
                                          InputType="@(_showMasterPin ? InputType.Text : InputType.Password)"
                                          InputMode="InputMode.numeric"
                                          MaxLength="6"
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          HelperText="6 digits. Required to delete major records (vendors, bills) and to recover access if the Admin PIN is lost."
                                          Error="@MasterPinWeak"
                                          ErrorText="Avoid repeating patterns like 123456, 111111, or 121212."
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showMasterPin ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                          OnAdornmentClick="ToggleShowMaster"
                                          @onfocusin="OnMasterPinFocus"
                                          OnKeyDown="OnKeyDown" />
                            <MudTextField Value="_masterPinConfirm"
                                          ValueChanged="SetMasterPinConfirm"
                                          T="string"
                                          Label="Confirm"
                                          InputType="@(_showMasterPin ? InputType.Text : InputType.Password)"
                                          InputMode="InputMode.numeric"
                                          MaxLength="6"
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          HelperText="Re-enter to confirm."
                                          Error="@MasterConfirmMismatch"
                                          ErrorText="Doesn't match."
                                          @onfocusin="OnMasterConfirmFocus"
                                          OnKeyDown="OnKeyDown" />
                        </MudStack>
                        <PinNumpad OnAppend="MasterAppend"
                                   OnBackspace="MasterBackspace"
                                   OnClear="MasterClear" />
                    </MudStack>

                    <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Rounded.Key">
                        Write down the Master PIN and keep it somewhere safe. Without it, you cannot delete major records or recover access if the Admin PIN is lost.
                    </MudAlert>

                    <MudCheckBox T="bool"
                                 @bind-Value="_acknowledgedMaster"
                                 Color="Color.Primary">
                        I have saved the Master PIN somewhere safe.
                    </MudCheckBox>

                    @if (_error is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                    }

                    <MudButton OnClick="Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               EndIcon="@Icons.Material.Rounded.ArrowForward"
                               Disabled="@(!CanSubmit)">
                        Complete setup
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudStack>
    }
</MudContainer>

@code {
    private enum PinPairField { Pin, Confirm }

    private string _storeName = "";
    private string _adminPin = "";
    private string _adminPinConfirm = "";
    private string _masterPin = "";
    private string _masterPinConfirm = "";
    private bool _showAdminPin;
    private bool _showMasterPin;
    private bool _acknowledgedMaster;
    private bool _submitAttempted;
    private string? _error;
    private bool _redirecting;

    private PinPairField _adminActiveField = PinPairField.Pin;
    private PinPairField _masterActiveField = PinPairField.Pin;

    protected override void OnInitialized()
    {
        if (Setup.IsComplete)
        {
            _redirecting = true;
            Nav.NavigateTo("/", replace: true);
        }
    }

    private bool AdminPinWeak => _adminPin.Length == 4 && PinRules.IsWeak(_adminPin);
    private bool MasterPinWeak => _masterPin.Length == 6 && PinRules.IsWeak(_masterPin);
    private bool AdminConfirmMismatch => _adminPinConfirm.Length == 4 && _adminPinConfirm != _adminPin;
    private bool MasterConfirmMismatch => _masterPinConfirm.Length == 6 && _masterPinConfirm != _masterPin;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(_storeName) &&
        _adminPin.Length == 4 && !PinRules.IsWeak(_adminPin) &&
        _adminPinConfirm == _adminPin &&
        _masterPin.Length == 6 && !PinRules.IsWeak(_masterPin) &&
        _masterPinConfirm == _masterPin &&
        _acknowledgedMaster;

    private void SetAdminPin(string v) => _adminPin = DigitsOnly(v, 4);
    private void SetAdminPinConfirm(string v) => _adminPinConfirm = DigitsOnly(v, 4);
    private void SetMasterPin(string v) => _masterPin = DigitsOnly(v, 6);
    private void SetMasterPinConfirm(string v) => _masterPinConfirm = DigitsOnly(v, 6);

    private static string DigitsOnly(string s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "";
        var filtered = new string(s.Where(char.IsDigit).ToArray());
        return filtered.Length > max ? filtered[..max] : filtered;
    }

    private void ToggleShowAdmin() => _showAdminPin = !_showAdminPin;
    private void ToggleShowMaster() => _showMasterPin = !_showMasterPin;

    private void OnAdminPinFocus() => _adminActiveField = PinPairField.Pin;
    private void OnAdminConfirmFocus() => _adminActiveField = PinPairField.Confirm;
    private void OnMasterPinFocus() => _masterActiveField = PinPairField.Pin;
    private void OnMasterConfirmFocus() => _masterActiveField = PinPairField.Confirm;

    private void AdminAppend(string d)
    {
        if (_adminActiveField == PinPairField.Pin)
            _adminPin = DigitsOnly(_adminPin + d, 4);
        else
            _adminPinConfirm = DigitsOnly(_adminPinConfirm + d, 4);
    }

    private void AdminBackspace()
    {
        if (_adminActiveField == PinPairField.Pin && _adminPin.Length > 0)
            _adminPin = _adminPin[..^1];
        else if (_adminActiveField == PinPairField.Confirm && _adminPinConfirm.Length > 0)
            _adminPinConfirm = _adminPinConfirm[..^1];
    }

    private void AdminClear()
    {
        if (_adminActiveField == PinPairField.Pin) _adminPin = "";
        else _adminPinConfirm = "";
    }

    private void MasterAppend(string d)
    {
        if (_masterActiveField == PinPairField.Pin)
            _masterPin = DigitsOnly(_masterPin + d, 6);
        else
            _masterPinConfirm = DigitsOnly(_masterPinConfirm + d, 6);
    }

    private void MasterBackspace()
    {
        if (_masterActiveField == PinPairField.Pin && _masterPin.Length > 0)
            _masterPin = _masterPin[..^1];
        else if (_masterActiveField == PinPairField.Confirm && _masterPinConfirm.Length > 0)
            _masterPinConfirm = _masterPinConfirm[..^1];
    }

    private void MasterClear()
    {
        if (_masterActiveField == PinPairField.Pin) _masterPin = "";
        else _masterPinConfirm = "";
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && CanSubmit) Submit();
    }

    private void Submit()
    {
        _submitAttempted = true;
        _error = null;

        var name = _storeName.Trim();
        if (string.IsNullOrEmpty(name)) { _error = "Store name is required."; return; }
        if (_masterPin.StartsWith(_adminPin, StringComparison.Ordinal))
        {
            _error = "Master PIN must not start with the Admin PIN.";
            return;
        }

        try
        {
            Setup.Save(name, _adminPin, _masterPin);
        }
        catch (IOException ex)
        {
            _error = $"Could not save setup: {ex.Message}";
            return;
        }
        catch (UnauthorizedAccessException ex)
        {
            _error = $"Could not save setup: {ex.Message}";
            return;
        }

        _redirecting = true;
        Nav.NavigateTo("/", replace: true);
    }
}
