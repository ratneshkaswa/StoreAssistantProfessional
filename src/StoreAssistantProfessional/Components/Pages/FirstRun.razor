@page "/setup"
@using System.Security.Cryptography
@using StoreAssistantProfessional.Theme
@inject ISetupService Setup
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Setup — Store Assistant Professional</PageTitle>

@if (!_redirecting)
{
    <main>
        <MudGrid Spacing="0" Style="min-height: 100vh;">
            <MudItem xs="12" md="6">
                <MudPaper Elevation="0"
                          Square="true"
                          Class="pa-10 d-flex flex-column align-center"
                          Style="@HeroStyle">
                    <MudIcon Icon="@Icons.Material.Rounded.ShoppingBag"
                             UserAttributes="@AriaHidden"
                             Style="position: absolute; bottom: -60px; right: -60px; font-size: 320px; opacity: 0.1; pointer-events: none;" />
                    <MudStack AlignItems="AlignItems.Center" Spacing="5" Style="position: relative; z-index: 1;">
                        <MudText Typo="Typo.overline" Align="Align.Center" Style="letter-spacing: 3px; opacity: 0.85;">
                            STORE ASSISTANT PROFESSIONAL
                        </MudText>

                        <MudIcon Icon="@Icons.Material.Rounded.Checkroom"
                                 UserAttributes="@AriaHidden"
                                 Style="font-size: 88px; opacity: 0.9;" />


                        <MudText Typo="Typo.h3"
                                 Align="Align.Center"
                                 Style="font-family: Georgia, 'Times New Roman', serif; font-weight: 400; line-height: 1.15; max-width: 520px; overflow-wrap: break-word; hyphens: auto;">
                            @HeroHeading
                        </MudText>

                        <MudStack Row="true" Spacing="5" AlignItems="AlignItems.Center" Style="opacity: 0.8;">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.TouchApp" UserAttributes="@AriaHidden" Style="font-size: 18px;" />
                                <MudText Typo="Typo.caption">Fewer clicks</MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.Bolt" UserAttributes="@AriaHidden" Style="font-size: 18px;" />
                                <MudText Typo="Typo.caption">Faster bills</MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.Analytics" UserAttributes="@AriaHidden" Style="font-size: 18px;" />
                                <MudText Typo="Typo.caption">Cleaner reports</MudText>
                            </MudStack>
                        </MudStack>

                        <MudText Typo="Typo.caption" Align="Align.Center"
                                 Style="font-family: Georgia, 'Times New Roman', serif; font-style: italic; opacity: 0.85; letter-spacing: 1px;">
                            Crafted for Indian retail · Est. @DateTime.UtcNow.Year
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudContainer MaxWidth="MaxWidth.Small" Class="pa-8 d-flex flex-column" Style="min-height: 100vh; justify-content: safe center;">
                    <form onsubmit="return false" aria-label="First-run setup" style="display: contents">
                    <MudStack Spacing="4">
                        @if (Setup.Status == SetupStatus.Corrupt)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Rounded.Warning">
                                An existing setup file was found but could not be read. Completing setup will replace it; the unreadable copy will be kept as <code>setup.json.bak</code> alongside it.
                            </MudAlert>
                        }

                        <div id="setup-blocker" role="status" aria-live="polite" style="min-height: 24px;">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 24px;">
                                @if (BlockingReason is not null)
                                {
                                    <MudIcon Icon="@Icons.Material.Rounded.Info"
                                             UserAttributes="@AriaHidden"
                                             Color="Color.Secondary"
                                             Style="font-size: 16px;" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @BlockingReason
                                    </MudText>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Rounded.CheckCircle"
                                             UserAttributes="@AriaHidden"
                                             Color="Color.Success"
                                             Style="font-size: 16px;" />
                                    <MudText Typo="Typo.caption" Color="Color.Success">
                                        Ready to save.
                                    </MudText>
                                }
                            </MudStack>
                        </div>

                        <MudPaper Elevation="1" Class="pa-4" Style="box-shadow: inset 4px 0 0 var(--mud-palette-primary), 0 2px 4px rgba(0,0,0,0.08);">
                            <MudStack Spacing="3">
                                <MudText Typo="Typo.h6">Name your store</MudText>
                                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                                    <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Style="flex: 0 0 32px; width: 32px; height: 32px; min-width: 32px; margin-top: 20px;">
                                        <MudIcon Icon="@Icons.Material.Rounded.Storefront" UserAttributes="@AriaHidden" Style="font-size: 22px;" />
                                    </MudAvatar>
                                    <div style="flex: 1;">
                                        <MudTextField @bind-Value="_storeName"
                                                      Label="Store name"
                                                      Variant="Variant.Outlined"
                                                      MaxLength="100"
                                                      Immediate="true"
                                                      AutoFocus="true"
                                                      HelperText="Shown on receipts and across the app."
                                                      Error="@(_storeNameTouched && !StoreNameValid)"
                                                      ErrorText="@StoreNameErrorText"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(StoreNameValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                      AdornmentColor="@(StoreNameValid ? Color.Success : Color.Default)"
                                                      UserAttributes="@StoreNameAttrs"
                                                      OnBlur="OnStoreNameBlur"
                                                      OnKeyDown="OnStoreNameKeyDown" />
                                    </div>
                                </MudStack>
                            </MudStack>
                        </MudPaper>

                        <MudPaper Elevation="1" Class="pa-4" Style="box-shadow: inset 4px 0 0 var(--mud-palette-secondary), 0 2px 4px rgba(0,0,0,0.08);">
                            <MudStack Spacing="3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.h6">Choose two PINs</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Admin for day-to-day protected actions. Master for destructive deletions and recovery.
                                    </MudText>
                                </MudStack>

                                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Style="flex: 0 0 32px; width: 32px; height: 32px; min-width: 32px; margin-top: 20px;">
                                        <MudIcon Icon="@Icons.Material.Rounded.Lock" UserAttributes="@AriaHidden" Style="font-size: 22px;" />
                                    </MudAvatar>
                                    <MudStack Row="true" Spacing="2" Style="flex: 1;">
                                        <MudTextField @ref="_adminPinField"
                                                      Value="_adminPin"
                                                      ValueChanged="SetAdminPin"
                                                      T="string"
                                                      Label="Admin PIN"
                                                      InputType="@(_showAdminPin ? InputType.Text : InputType.Password)"
                                                      MaxLength="4"
                                                      Variant="Variant.Outlined"
                                                      Immediate="true"
                                                      HelperText="@AdminPinHelper"
                                                      Error="@AdminPinWeak"
                                                      ErrorText="Too predictable."
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(_showAdminPin ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                                      AdornmentColor="@(AdminPinValid ? Color.Success : Color.Default)"
                                                      UserAttributes="@PinAttrs"
                                                      OnAdornmentClick="ToggleShowAdmin"
                                                      OnKeyDown="OnKeyDown" />
                                        <MudTextField @ref="_adminPinConfirmField"
                                                      Value="_adminPinConfirm"
                                                      ValueChanged="SetAdminPinConfirm"
                                                      T="string"
                                                      Label="Confirm"
                                                      InputType="@(_showAdminPin ? InputType.Text : InputType.Password)"
                                                      MaxLength="4"
                                                      Variant="Variant.Outlined"
                                                      Immediate="true"
                                                      HelperText="Re-enter"
                                                      Error="@AdminConfirmMismatch"
                                                      ErrorText="Doesn't match the PIN above."
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(AdminConfirmValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                      AdornmentColor="@(AdminConfirmValid ? Color.Success : Color.Default)"
                                                      UserAttributes="@PinAttrs"
                                                      OnKeyDown="OnKeyDown" />
                                    </MudStack>
                                </MudStack>

                                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                                    <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Small" Style="flex: 0 0 32px; width: 32px; height: 32px; min-width: 32px; margin-top: 20px;">
                                        <MudIcon Icon="@Icons.Material.Rounded.Key" UserAttributes="@AriaHidden" Style="font-size: 22px;" />
                                    </MudAvatar>
                                    <MudStack Row="true" Spacing="2" Style="flex: 1;">
                                        <MudTextField @ref="_masterPinField"
                                                      Value="_masterPin"
                                                      ValueChanged="SetMasterPin"
                                                      T="string"
                                                      Label="Master PIN"
                                                      InputType="@(_showMasterPin ? InputType.Text : InputType.Password)"
                                                      MaxLength="6"
                                                      Variant="Variant.Outlined"
                                                      Immediate="true"
                                                      HelperText="@MasterPinHelper"
                                                      Error="@(MasterPinWeak || MasterStartsWithAdmin)"
                                                      ErrorText="@MasterPinErrorText"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(_showMasterPin ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                                      AdornmentColor="@(MasterPinValid ? Color.Success : Color.Default)"
                                                      UserAttributes="@PinAttrs"
                                                      OnAdornmentClick="ToggleShowMaster"
                                                      OnKeyDown="OnKeyDown" />
                                        <MudTextField @ref="_masterPinConfirmField"
                                                      Value="_masterPinConfirm"
                                                      ValueChanged="SetMasterPinConfirm"
                                                      T="string"
                                                      Label="Confirm"
                                                      InputType="@(_showMasterPin ? InputType.Text : InputType.Password)"
                                                      MaxLength="6"
                                                      Variant="Variant.Outlined"
                                                      Immediate="true"
                                                      HelperText="Re-enter"
                                                      Error="@MasterConfirmMismatch"
                                                      ErrorText="Doesn't match the PIN above."
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(MasterConfirmValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                      AdornmentColor="@(MasterConfirmValid ? Color.Success : Color.Default)"
                                                      UserAttributes="@PinAttrs"
                                                      OnKeyDown="OnKeyDown" />
                                    </MudStack>
                                </MudStack>
                            </MudStack>
                        </MudPaper>

                        <MudButton OnClick="Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   FullWidth="true"
                                   Disabled="@(!CanSubmit)"
                                   UserAttributes="@BlockerAriaAttrs">
                            @if (_submitting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Securing your PINs…</span>
                            }
                            else
                            {
                                <span>Complete setup</span>
                            }
                        </MudButton>
                    </MudStack>
                    </form>
                </MudContainer>
            </MudItem>
        </MudGrid>
    </main>
}

@code {
    private string _storeName = "";
    private string _adminPin = "";
    private string _adminPinConfirm = "";
    private string _masterPin = "";
    private string _masterPinConfirm = "";
    private bool _showAdminPin;
    private bool _showMasterPin;
    private bool _storeNameTouched;
    private bool _submitting;
    private bool _redirecting;

    private MudTextField<string>? _adminPinField;
    private MudTextField<string>? _adminPinConfirmField;
    private MudTextField<string>? _masterPinField;
    private MudTextField<string>? _masterPinConfirmField;

    private static readonly Dictionary<string, object?> AriaHidden = new() { ["aria-hidden"] = "true" };
    private static readonly Dictionary<string, object?> StoreNameAttrs = new() { ["spellcheck"] = "false", ["autocomplete"] = "off" };
    private static readonly Dictionary<string, object?> PinAttrs = new() { ["autocomplete"] = "off", ["inputmode"] = "numeric" };
    private static readonly Dictionary<string, object?> BlockerAriaAttrs = new() { ["aria-describedby"] = "setup-blocker" };

    private static readonly string HeroStyle =
        $"min-height: 100vh; position: relative; overflow: hidden; " +
        $"justify-content: safe center; " +
        $"background: linear-gradient(315deg, {BrandTheme.HeroGradientStart} 0%, {BrandTheme.HeroGradientMiddle} 45%, {BrandTheme.HeroGradientEnd} 100%); " +
        $"color: {BrandTheme.HeroTextColor};";

    protected override void OnInitialized()
    {
        if (Setup.IsComplete)
        {
            _redirecting = true;
            Nav.NavigateTo("/", replace: true);
        }
    }

    private string HeroHeading => StoreNameValid
        ? $"Namaste, {_storeName.Trim()}"
        : "Namaste";

    private bool AdminPinWeak => _adminPin.Length == 4 && PinRules.IsWeak(_adminPin);
    private bool MasterPinWeak => _masterPin.Length == 6 && PinRules.IsWeak(_masterPin);
    private bool AdminConfirmMismatch => _adminPinConfirm.Length == 4 && _adminPinConfirm != _adminPin;
    private bool MasterConfirmMismatch => _masterPinConfirm.Length == 6 && _masterPinConfirm != _masterPin;
    private bool MasterStartsWithAdmin =>
        _masterPin.Length == 6 && _adminPin.Length == 4 &&
        _masterPin.StartsWith(_adminPin, StringComparison.Ordinal);

    private bool StoreNameValid => _storeName.Trim().Length >= 2;
    private bool AdminPinValid => _adminPin.Length == 4 && !PinRules.IsWeak(_adminPin);
    private bool AdminConfirmValid => _adminPinConfirm.Length == 4 && _adminPinConfirm == _adminPin;
    private bool MasterPinValid => _masterPin.Length == 6 && !PinRules.IsWeak(_masterPin) && !MasterStartsWithAdmin;
    private bool MasterConfirmValid => _masterPinConfirm.Length == 6 && _masterPinConfirm == _masterPin;

    private string StoreNameErrorText =>
        string.IsNullOrWhiteSpace(_storeName)
            ? "Store name is required."
            : "Store name must be at least 2 characters.";

    private string MasterPinErrorText => MasterStartsWithAdmin
        ? "Must not start with the Admin PIN."
        : "Avoid repeats, sequences, and palindromes.";

    private string AdminPinHelper => PinRules.IsStrong(_adminPin) ? "4 digits · Strong" : "4 digits";
    private string MasterPinHelper => PinRules.IsStrong(_masterPin) ? "6 digits · Strong" : "6 digits";

    private bool CanSubmit =>
        !_submitting &&
        StoreNameValid &&
        _adminPin.Length == 4 && !PinRules.IsWeak(_adminPin) &&
        _adminPinConfirm == _adminPin &&
        _masterPin.Length == 6 && !PinRules.IsWeak(_masterPin) &&
        !MasterStartsWithAdmin &&
        _masterPinConfirm == _masterPin;

    private string? BlockingReason
    {
        get
        {
            if (!StoreNameValid)
                return _storeName.Length == 0
                    ? "Start by naming your store."
                    : "Store name must be at least 2 characters.";
            if (_adminPin.Length < 4) return "Set a 4-digit Admin PIN.";
            if (PinRules.IsWeak(_adminPin)) return "Admin PIN is too predictable — try something less obvious.";
            if (_adminPinConfirm.Length < 4) return "Re-enter the Admin PIN to confirm it.";
            if (_adminPinConfirm != _adminPin) return "Admin PIN confirmation doesn't match.";
            if (_masterPin.Length < 6) return "Set a 6-digit Master PIN.";
            if (MasterStartsWithAdmin) return "Master PIN must not start with the Admin PIN.";
            if (PinRules.IsWeak(_masterPin)) return "Master PIN is too predictable — try something less obvious.";
            if (_masterPinConfirm.Length < 6) return "Re-enter the Master PIN to confirm it.";
            if (_masterPinConfirm != _masterPin) return "Master PIN confirmation doesn't match.";
            return null;
        }
    }

    private async Task SetAdminPin(string v)
    {
        _adminPin = DigitsOnly(v, 4);
        if (AdminPinValid && _adminPinConfirm.Length == 0 && _adminPinConfirmField is not null)
            await _adminPinConfirmField.FocusAsync();
    }

    private async Task SetAdminPinConfirm(string v)
    {
        _adminPinConfirm = DigitsOnly(v, 4);
        if (AdminConfirmValid && _masterPin.Length == 0 && _masterPinField is not null)
            await _masterPinField.FocusAsync();
    }

    private async Task SetMasterPin(string v)
    {
        _masterPin = DigitsOnly(v, 6);
        if (MasterPinValid && _masterPinConfirm.Length == 0 && _masterPinConfirmField is not null)
            await _masterPinConfirmField.FocusAsync();
    }

    private void SetMasterPinConfirm(string v)
    {
        _masterPinConfirm = DigitsOnly(v, 6);
    }

    private static string DigitsOnly(string s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "";
        var filtered = new string(s.Where(char.IsDigit).ToArray());
        return filtered.Length > max ? filtered[..max] : filtered;
    }

    private static string StripParamSuffix(string message)
    {
        var i = message.IndexOf(" (Parameter ", StringComparison.Ordinal);
        return i >= 0 ? message[..i] : message;
    }

    private void ToggleShowAdmin() => _showAdminPin = !_showAdminPin;
    private void ToggleShowMaster() => _showMasterPin = !_showMasterPin;

    private void OnStoreNameBlur()
    {
        _storeNameTouched = true;
        _storeName = _storeName.Trim();
    }

    private async Task OnStoreNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        _storeNameTouched = true;
        if (StoreNameValid && _adminPinField is not null)
            await _adminPinField.FocusAsync();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && CanSubmit) await Submit();
    }

    private async Task Submit()
    {
        if (_submitting) return;
        _submitting = true;

        try
        {
            await Task.Run(() => Setup.Save(_storeName.Trim(), _adminPin, _masterPin));
        }
        catch (ArgumentException ex)
        {
            ShowError(StripParamSuffix(ex.Message));
            _submitting = false;
            return;
        }
        catch (IOException ex)
        {
            ShowError($"Could not save setup: {ex.Message}");
            _submitting = false;
            return;
        }
        catch (UnauthorizedAccessException ex)
        {
            ShowError($"Could not save setup: {ex.Message}");
            _submitting = false;
            return;
        }
        catch (CryptographicException ex)
        {
            ShowError($"Could not secure your PINs: {ex.Message}");
            _submitting = false;
            return;
        }

        _adminPin = _adminPinConfirm = _masterPin = _masterPinConfirm = "";

        _redirecting = true;
        Nav.NavigateTo("/", replace: true);
    }

    private void ShowError(string message) =>
        Snackbar.Add(message, Severity.Error, config =>
        {
            config.ShowCloseIcon = true;
            config.VisibleStateDuration = 10000;
        });
}
