@page "/setup"
@using System.Globalization
@using System.Security.Cryptography
@using Microsoft.Extensions.Logging
@implements IDisposable
@inject ISetupService Setup
@inject ISessionService Session
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<FirstRun> Logger

<PageTitle>Setup — Store Assistant Professional</PageTitle>

@if (_redirecting)
{
    <div role="status" aria-live="polite" class="sap-firstrun-redirect">
        <MudContainer Class="mt-12">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_redirectingMessage</MudText>
            </MudStack>
        </MudContainer>
    </div>
}
else
{
    <div class="sap-firstrun-root">
        <h1 class="sap-visually-hidden">Set up Store Assistant Professional</h1>
        <MudGrid Spacing="0">
            <MudItem xs="12" sm="6" Class="d-none d-sm-block">
                <MudPaper Elevation="0" Square="true" Class="pa-10 sap-firstrun-hero">
                    <MudIcon Icon="@Icons.Material.Rounded.ShoppingBag"
                             UserAttributes="@AriaHidden"
                             Class="sap-firstrun-hero-deco" />
                    <MudStack AlignItems="AlignItems.Center" Spacing="5" Class="sap-firstrun-hero-stack">
                        <MudText Typo="Typo.overline" Align="Align.Center" Class="sap-firstrun-hero-overline">
                            STORE ASSISTANT PROFESSIONAL
                        </MudText>

                        <MudIcon Icon="@Icons.Material.Rounded.Checkroom"
                                 UserAttributes="@AriaHidden"
                                 Class="sap-firstrun-hero-icon" />

                        <MudText Typo="Typo.h3" Align="Align.Center" Class="sap-firstrun-hero-heading">
                            @HeroHeading
                        </MudText>

                        <MudText Typo="Typo.body2" Align="Align.Center" Class="sap-firstrun-hero-next">
                            Quietly precise. Built to outlast trends.
                        </MudText>

                        <MudText Typo="Typo.caption" Align="Align.Center" Class="sap-firstrun-hero-next">
                            After this: a four-step setup of firm, taxes, products, vendors.
                        </MudText>

                        <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center" Class="sap-firstrun-hero-badges">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.CloudOff" UserAttributes="@AriaHidden" Class="sap-firstrun-hero-badge-icon" />
                                <MudText Typo="Typo.caption">Offline-first</MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.MoneyOff" UserAttributes="@AriaHidden" Class="sap-firstrun-hero-badge-icon" />
                                <MudText Typo="Typo.caption">No subscription</MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.Shield" UserAttributes="@AriaHidden" Class="sap-firstrun-hero-badge-icon" />
                                <MudText Typo="Typo.caption">Private</MudText>
                            </MudStack>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" Class="sap-firstrun-form-col">
                <MudContainer MaxWidth="MaxWidth.Small" Class="pa-4 sap-firstrun-form" aria-label="First-run setup">
                    <MudStack Spacing="3">
                        @if (_setupStatusSnapshot == SetupStatus.Corrupt)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Rounded.Warning">
                                An existing setup file was found but could not be read. Completing setup will replace it; the unreadable copy will be kept as <code>setup.json.bak</code> alongside it.
                            </MudAlert>
                        }
                        else if (_setupStatusSnapshot == SetupStatus.Inaccessible)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Icon="@Icons.Material.Rounded.ErrorOutline">
                                Local app data is not accessible. Setup cannot be saved on this machine. Check that
                                <code>%LocalAppData%\StoreAssistantProfessional</code> is writable.
                            </MudAlert>
                        }

                        @if (_pageMode == PageMode.AlreadyConfigured)
                        {
                            <MudPaper Elevation="1" Class="pa-4 sap-firstrun-card">
                                <MudStack Spacing="3">
                                    <MudText Typo="Typo.h6">Already configured</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        This device is already set up for <strong>@(Setup.Current?.FirmName ?? "an unknown firm")</strong>.
                                    </MudText>
                                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                                        <MudButton Variant="Variant.Text" OnClick="ShowResetConfirm" Color="Color.Error">
                                            Reset PINs
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoHome">
                                            Continue to app
                                        </MudButton>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                        else if (_pageMode == PageMode.ResetConfirm)
                        {
                            <MudPaper Elevation="1" Class="pa-4 sap-firstrun-card">
                                <MudStack Spacing="3">
                                    <MudText Typo="Typo.h6" Color="Color.Error">Reset PINs?</MudText>
                                    <MudText Typo="Typo.body2">
                                        This wipes <code>setup.json</code> and lets you set new PINs. Your firm data
                                        and bills are <em>not</em> affected — they live in a separate database file.
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Note: anyone with access to this Windows account can reset the PIN file
                                        (or delete it manually) — the file is encrypted to your account, not gated
                                        by PIN entry. Reset only undoes the lock, not the data.
                                    </MudText>
                                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                                        <MudButton Variant="Variant.Text" OnClick="CancelReset">Cancel</MudButton>
                                        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DoReset">
                                            Yes, reset
                                        </MudButton>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                        else
                        {
                            <div id="setup-blocker" class="sap-firstrun-blocker">
                                <div role="status" aria-live="polite" aria-atomic="true"
                                     class="sap-firstrun-blocker-live @(BlockingReason is null ? "" : "is-warn")">
                                    @if (BlockingReason is not null)
                                    {
                                        <MudIcon Icon="@Icons.Material.Rounded.EditNote"
                                                 UserAttributes="@AriaHidden"
                                                 Class="sap-firstrun-blocker-icon" />
                                        <MudText Typo="Typo.body2" Class="sap-firstrun-blocker-text">@BlockingReason</MudText>
                                    }
                                </div>
                                @if (BlockingReason is null)
                                {
                                    <div class="sap-firstrun-blocker-ready">
                                        <MudIcon Icon="@Icons.Material.Rounded.CheckCircle"
                                                 UserAttributes="@AriaHidden"
                                                 Class="sap-firstrun-blocker-icon" />
                                        <MudText Typo="Typo.body2" Class="sap-firstrun-blocker-text">Ready to save.</MudText>
                                    </div>
                                }
                            </div>

                            <MudPaper Elevation="1" Class="pa-4 sap-firstrun-card">
                                <MudStack Spacing="3">
                                    <MudText Typo="Typo.h6">Name your firm</MudText>
                                    <MudTextField @ref="_firmNameField"
                                                  @bind-Value="_firmName"
                                                  Label="Firm name"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  MaxLength="@SetupService.MaxFirmNameLength"
                                                  Immediate="true"
                                                  Disabled="@FieldsLocked"
                                                  HelperText="Shown on receipts and across the app."
                                                  Adornment="Adornment.End"
                                                  AdornmentIcon="@(FirmNameValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                  AdornmentColor="@(FirmNameValid ? Color.Success : Color.Default)"
                                                  UserAttributes="@FirmNameAttrs"
                                                  OnBlur="OnFirmNameBlur"
                                                  OnKeyDown="OnFirmNameKeyDown" />
                                </MudStack>
                            </MudPaper>

                            <MudPaper Elevation="1" Class="pa-4 sap-firstrun-card">
                                <MudStack Spacing="3">
                                    <MudStack Row="true" Spacing="0" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.h6">Choose two PINs</MudText>
                                        <MudTooltip Text="@PinVisibilityTooltip" Placement="Placement.Top">
                                            <MudIconButton Icon="@(_showPins ? Icons.Material.Rounded.VisibilityOff : Icons.Material.Rounded.Visibility)"
                                                           Size="Size.Small"
                                                           Color="Color.Default"
                                                           Class="sap-firstrun-pin-toggle"
                                                           OnClick="TogglePins"
                                                           Disabled="@FieldsLocked"
                                                           UserAttributes="@PinVisibilityAttrs" />
                                        </MudTooltip>
                                    </MudStack>
                                    <MudText Typo="Typo.caption" Color="Color.Default">
                                        Admin for day-to-day protected actions. Master for destructive deletions and recovery.
                                    </MudText>

                                    <MudStack Row="true" Spacing="2" Class="sap-firstrun-pin-row">
                                        <MudTextField @ref="_adminPinField"
                                                      Value="_adminPin"
                                                      ValueChanged="SetAdminPin"
                                                      T="string"
                                                      Label="Admin PIN"
                                                      InputType="@(_showPins ? InputType.Text : InputType.Password)"
                                                      MaxLength="@SetupService.AdminPinLength"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true"
                                                      Disabled="@FieldsLocked"
                                                      HelperText="@AdminPinHelper"
                                                      Error="@AdminPinWeak"
                                                      ErrorText="@AdminPinErrorText"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(AdminPinValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                      AdornmentColor="@(AdminPinValid ? Color.Success : Color.Default)"
                                                      UserAttributes="@PinAttrs"
                                                      OnKeyDown="OnPinKeyDown" />
                                        <MudTextField @ref="_adminPinConfirmField"
                                                      Value="_adminPinConfirm"
                                                      ValueChanged="SetAdminPinConfirm"
                                                      T="string"
                                                      Label="Confirm Admin PIN"
                                                      InputType="@(_showPins ? InputType.Text : InputType.Password)"
                                                      MaxLength="@SetupService.AdminPinLength"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true"
                                                      Disabled="@(FieldsLocked || _adminPin.Length < SetupService.AdminPinLength)"
                                                      HelperText="Re-enter"
                                                      Error="@AdminConfirmShowsError"
                                                      ErrorText="Doesn't match."
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(AdminConfirmValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                      AdornmentColor="@(AdminConfirmValid ? Color.Success : Color.Default)"
                                                      UserAttributes="@PinAttrs"
                                                      OnKeyDown="OnPinKeyDown" />
                                    </MudStack>

                                    <MudStack Row="true" Spacing="2" Class="sap-firstrun-pin-row">
                                        <MudTextField @ref="_masterPinField"
                                                      Value="_masterPin"
                                                      ValueChanged="SetMasterPin"
                                                      T="string"
                                                      Label="Master PIN"
                                                      InputType="@(_showPins ? InputType.Text : InputType.Password)"
                                                      MaxLength="@SetupService.MasterPinLength"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true"
                                                      Disabled="@FieldsLocked"
                                                      HelperText="@MasterPinHelper"
                                                      Error="@(MasterPinWeak || MasterContainsAdmin)"
                                                      ErrorText="@MasterPinErrorText"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(MasterPinValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                      AdornmentColor="@(MasterPinValid ? Color.Success : Color.Default)"
                                                      UserAttributes="@PinAttrs"
                                                      OnKeyDown="OnPinKeyDown" />
                                        <MudTextField @ref="_masterPinConfirmField"
                                                      Value="_masterPinConfirm"
                                                      ValueChanged="SetMasterPinConfirm"
                                                      T="string"
                                                      Label="Confirm Master PIN"
                                                      InputType="@(_showPins ? InputType.Text : InputType.Password)"
                                                      MaxLength="@SetupService.MasterPinLength"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true"
                                                      Disabled="@(FieldsLocked || _masterPin.Length < SetupService.MasterPinLength)"
                                                      HelperText="Re-enter"
                                                      Error="@MasterConfirmShowsError"
                                                      ErrorText="Doesn't match."
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(MasterConfirmValid ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                                      AdornmentColor="@(MasterConfirmValid ? Color.Success : Color.Default)"
                                                      UserAttributes="@PinAttrs"
                                                      OnKeyDown="OnPinKeyDown" />
                                    </MudStack>
                                </MudStack>
                            </MudPaper>

                            <MudButton OnClick="Submit"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       FullWidth="true"
                                       Disabled="@(!CanSubmit)"
                                       UserAttributes="@BlockerAriaAttrs">
                                @if (_submitting)
                                {
                                    <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                                    <span>Saving setup…</span>
                                }
                                else
                                {
                                    <span>Complete setup</span>
                                }
                            </MudButton>
                        }
                    </MudStack>
                </MudContainer>
            </MudItem>
        </MudGrid>
    </div>
}

@code {
    private string _firmName = "";
    private string _adminPin = "";
    private string _adminPinConfirm = "";
    private string _masterPin = "";
    private string _masterPinConfirm = "";
    private bool _showPins;
    private bool _submitting;
    private bool _redirecting;
    private string _redirectingMessage = "Just a moment…";

    private bool _adminAutoAdvanced;
    private bool _adminConfirmAutoAdvanced;
    private bool _masterAutoAdvanced;

    private bool _firmNameVisited;          // Set on first blur. Drives the hero
                                            // greeting reveal, so the firm name
                                            // doesn't echo back in 96px serif as
                                            // the user types it the first time.

    private SetupStatus _setupStatusSnapshot = SetupStatus.NotSetup;
    private PageMode _pageMode = PageMode.NewSetup;

    private CancellationTokenSource? _pinHideCts;

    private enum PageMode { NewSetup, AlreadyConfigured, ResetConfirm }

    // Focus-after-render queue. The next-field-target is disabled in the DOM
    // until the prior field hits its required length; if we call FocusAsync
    // synchronously in the value-changed handler the call lands on a still-
    // disabled element and the browser drops it. So we record the intent and
    // run FocusAsync from OnAfterRenderAsync, after Blazor has re-rendered the
    // input with disabled=false.
    private FocusTarget _pendingFocus = FocusTarget.None;
    private enum FocusTarget { None, FirmName, AdminConfirm, Master, MasterConfirm, Admin }

    private MudTextField<string>? _firmNameField;
    private MudTextField<string>? _adminPinField;
    private MudTextField<string>? _adminPinConfirmField;
    private MudTextField<string>? _masterPinField;
    private MudTextField<string>? _masterPinConfirmField;

    private static readonly Dictionary<string, object> AriaHidden =
        new() { ["aria-hidden"] = "true" };
    private static readonly Dictionary<string, object> FirmNameAttrs =
        new() { ["spellcheck"] = "false", ["autocomplete"] = "off", ["aria-required"] = "true" };
    private static readonly Dictionary<string, object> PinAttrs =
        new() { ["autocomplete"] = "off", ["inputmode"] = "numeric", ["aria-required"] = "true" };
    private static readonly Dictionary<string, object> BlockerAriaAttrs =
        new() { ["aria-describedby"] = "setup-blocker" };

    // State-aware aria-label for the visibility toggle. The icon and tooltip
    // both flip with `_showPins`; aria-label needs to match.
    private Dictionary<string, object> PinVisibilityAttrs =>
        new() { ["aria-label"] = _showPins ? "Hide PINs" : "Show PINs" };

    private string PinVisibilityTooltip => _showPins ? "Hide PINs" : "Show PINs";

    private bool FieldsLocked => _submitting || _setupStatusSnapshot == SetupStatus.Inaccessible;

    protected override void OnInitialized()
    {
        _setupStatusSnapshot = Setup.Status;
        _pageMode = _setupStatusSnapshot == SetupStatus.Valid
            ? PageMode.AlreadyConfigured
            : PageMode.NewSetup;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingFocus == FocusTarget.None) return;
        var target = _pendingFocus;
        _pendingFocus = FocusTarget.None;

        var field = target switch
        {
            FocusTarget.FirmName      => _firmNameField,
            FocusTarget.Admin         => _adminPinField,
            FocusTarget.AdminConfirm  => _adminPinConfirmField,
            FocusTarget.Master        => _masterPinField,
            FocusTarget.MasterConfirm => _masterPinConfirmField,
            _ => null,
        };
        if (field is null) return;
        try { await field.FocusAsync(); }
        catch { /* WebView2 can be mid-teardown during navigation; ignore */ }
    }

    private string HeroHeading
    {
        get
        {
            // Don't echo the firm name back until the user has committed it
            // (blurred the field). Avoids shoulder-surf exposure of the name
            // in 96px serif while the user is still typing it.
            if (!_firmNameVisited || !FirmNameValid) return "Namaste";
            return $"Namaste, {TruncateGraphemes(_firmName.Trim(), 12)}";
        }
    }

    // Substring on length-by-text-element so we never split a UTF-16 surrogate pair
    // (e.g. emoji) or a multi-codepoint grapheme cluster.
    private static string TruncateGraphemes(string s, int maxGraphemes)
    {
        var enumerator = StringInfo.GetTextElementEnumerator(s);
        var count = 0;
        var endIndex = 0;
        while (enumerator.MoveNext())
        {
            count++;
            if (count > maxGraphemes - 1)
            {
                endIndex = enumerator.ElementIndex;
                break;
            }
        }
        return count <= maxGraphemes ? s : s[..endIndex] + "…";
    }

    private bool AdminPinWeak => _adminPin.Length == SetupService.AdminPinLength && PinRules.IsWeak(_adminPin);
    private bool MasterPinWeak => _masterPin.Length == SetupService.MasterPinLength && PinRules.IsWeak(_masterPin);

    // Progressive mismatch — the confirm field flags a divergence as soon as
    // the typed-so-far doesn't match the same prefix of the source PIN, not
    // only when the confirm is at full length. Catches typos earlier.
    private bool AdminConfirmShowsError =>
        _adminPinConfirm.Length > 0 && !_adminPin.StartsWith(_adminPinConfirm, StringComparison.Ordinal);
    private bool MasterConfirmShowsError =>
        _masterPinConfirm.Length > 0 && !_masterPin.StartsWith(_masterPinConfirm, StringComparison.Ordinal);

    private bool MasterContainsAdmin =>
        _masterPin.Length == SetupService.MasterPinLength &&
        _adminPin.Length == SetupService.AdminPinLength &&
        _masterPin.Contains(_adminPin, StringComparison.Ordinal);

    private bool FirmNameValid => _firmName.Trim().Length >= SetupService.MinFirmNameLength;
    private bool AdminPinValid => _adminPin.Length == SetupService.AdminPinLength && !PinRules.IsWeak(_adminPin);
    private bool AdminConfirmValid => _adminPinConfirm.Length == SetupService.AdminPinLength && _adminPinConfirm == _adminPin;
    private bool MasterPinValid => _masterPin.Length == SetupService.MasterPinLength && !PinRules.IsWeak(_masterPin) && !MasterContainsAdmin;
    private bool MasterConfirmValid => _masterPinConfirm.Length == SetupService.MasterPinLength && _masterPinConfirm == _masterPin;

    private string MasterPinErrorText => MasterContainsAdmin
        ? "Contains the Admin PIN."
        : "Too predictable.";

    private string AdminPinErrorText => "Too predictable.";

    private string AdminPinHelper => PinRules.IsStrong(_adminPin) ? "4 digits · OK" : "4 digits";
    private string MasterPinHelper => PinRules.IsStrong(_masterPin) ? "6 digits · OK" : "6 digits";

    private bool CanSubmit =>
        !FieldsLocked &&
        FirmNameValid &&
        AdminPinValid &&
        _adminPinConfirm == _adminPin &&
        MasterPinValid &&
        _masterPinConfirm == _masterPin;

    private string? BlockingReason
    {
        get
        {
            if (_setupStatusSnapshot == SetupStatus.Inaccessible)
                return "Local app data is not accessible — setup cannot be saved.";
            if (!FirmNameValid)
                return _firmName.Length == 0
                    ? "Start by naming your firm."
                    : "Firm name must be at least 2 characters.";
            if (_adminPin.Length < SetupService.AdminPinLength) return "Set a 4-digit Admin PIN.";
            if (PinRules.IsWeak(_adminPin)) return "Admin PIN is too predictable — try something less obvious.";
            if (_adminPinConfirm.Length < SetupService.AdminPinLength) return "Re-enter the Admin PIN to confirm it.";
            if (_adminPinConfirm != _adminPin) return "Admin PIN confirmation doesn't match.";
            if (_masterPin.Length < SetupService.MasterPinLength) return "Set a 6-digit Master PIN.";
            if (MasterContainsAdmin) return "Master PIN must not contain the Admin PIN.";
            if (PinRules.IsWeak(_masterPin)) return "Master PIN is too predictable — try something less obvious.";
            if (_masterPinConfirm.Length < SetupService.MasterPinLength) return "Re-enter the Master PIN to confirm it.";
            if (_masterPinConfirm != _masterPin) return "Master PIN confirmation doesn't match.";
            return null;
        }
    }

    private void SetAdminPin(string v)
    {
        var was = _adminPin.Length;
        _adminPin = AsciiDigitsOnly(v, SetupService.AdminPinLength);

        if (_adminPin.Length < SetupService.AdminPinLength && _adminPinConfirm.Length > 0)
        {
            _adminPinConfirm = "";
            _adminConfirmAutoAdvanced = false;
        }

        if (was < SetupService.AdminPinLength && _adminPin.Length == SetupService.AdminPinLength &&
            AdminPinValid && !_adminAutoAdvanced && _adminPinConfirm.Length == 0)
        {
            _adminAutoAdvanced = true;
            _pendingFocus = FocusTarget.AdminConfirm;
        }
        if (_adminPin.Length < SetupService.AdminPinLength)
        {
            _adminAutoAdvanced = false;
            // If a backspace lands inside the same render cycle as the auto-
            // advance trigger, the queued focus would still fire and yank the
            // caret to the (now-meaningless) confirm field. Clear it.
            if (_pendingFocus == FocusTarget.AdminConfirm) _pendingFocus = FocusTarget.None;
        }
    }

    private void SetAdminPinConfirm(string v)
    {
        var was = _adminPinConfirm.Length;
        _adminPinConfirm = AsciiDigitsOnly(v, SetupService.AdminPinLength);
        if (was < SetupService.AdminPinLength && _adminPinConfirm.Length == SetupService.AdminPinLength &&
            AdminConfirmValid && !_adminConfirmAutoAdvanced && _masterPin.Length == 0)
        {
            _adminConfirmAutoAdvanced = true;
            _pendingFocus = FocusTarget.Master;
        }
        if (_adminPinConfirm.Length < SetupService.AdminPinLength)
        {
            _adminConfirmAutoAdvanced = false;
            if (_pendingFocus == FocusTarget.Master) _pendingFocus = FocusTarget.None;
        }
    }

    private void SetMasterPin(string v)
    {
        var was = _masterPin.Length;
        _masterPin = AsciiDigitsOnly(v, SetupService.MasterPinLength);

        if (_masterPin.Length < SetupService.MasterPinLength && _masterPinConfirm.Length > 0)
        {
            _masterPinConfirm = "";
            _masterAutoAdvanced = false;
        }

        if (was < SetupService.MasterPinLength && _masterPin.Length == SetupService.MasterPinLength &&
            MasterPinValid && !_masterAutoAdvanced && _masterPinConfirm.Length == 0)
        {
            _masterAutoAdvanced = true;
            _pendingFocus = FocusTarget.MasterConfirm;
        }
        if (_masterPin.Length < SetupService.MasterPinLength)
        {
            _masterAutoAdvanced = false;
            if (_pendingFocus == FocusTarget.MasterConfirm) _pendingFocus = FocusTarget.None;
        }
    }

    private void SetMasterPinConfirm(string v) =>
        _masterPinConfirm = AsciiDigitsOnly(v, SetupService.MasterPinLength);

    private static string AsciiDigitsOnly(string s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "";
        Span<char> buf = stackalloc char[Math.Min(s.Length, max)];
        var n = 0;
        for (var i = 0; i < s.Length && n < max; i++)
            if (s[i] is >= '0' and <= '9') buf[n++] = s[i];
        return new string(buf[..n]);
    }

    private static string StripParamSuffix(string message)
    {
        // .NET's ArgumentException.Message appends "(Parameter '...')" in the
        // current culture (en-IN here). Strip that for cleaner UI display.
        var i = message.IndexOf(" (Parameter ", StringComparison.Ordinal);
        return i >= 0 ? message[..i] : message;
    }

    private void TogglePins()
    {
        // Swapping InputType (Password ↔ Text) tears down and rebuilds the
        // <input> element, which kicks the caret out of the field. Restore
        // focus to whichever PIN field the user is currently editing so they
        // can keep typing without reaching for the mouse.
        _showPins = !_showPins;
        _pendingFocus = ActivePinField();

        // Cancel any prior auto-hide and start a fresh one when the toggle
        // turns visibility on. Limits the window where someone glancing at
        // the screen can read the PIN.
        _pinHideCts?.Cancel();
        _pinHideCts?.Dispose();
        _pinHideCts = null;

        if (_showPins)
        {
            var cts = new CancellationTokenSource();
            _pinHideCts = cts;
            _ = AutoHideAfterAsync(TimeSpan.FromSeconds(60), cts.Token);
        }
    }

    private async Task AutoHideAfterAsync(TimeSpan delay, CancellationToken token)
    {
        try
        {
            await Task.Delay(delay, token);
            await InvokeAsync(() =>
            {
                if (_showPins)
                {
                    _showPins = false;
                    StateHasChanged();
                }
            });
        }
        catch (OperationCanceledException) { /* expected on toggle-off */ }
    }

    // Best-guess "which field is the user on right now" — the first one with
    // remaining capacity, in entry order. If everything's full we leave focus
    // alone (the user is most likely glancing at one of the earlier fields).
    private FocusTarget ActivePinField()
    {
        if (_adminPin.Length < SetupService.AdminPinLength) return FocusTarget.Admin;
        if (_adminPinConfirm.Length < SetupService.AdminPinLength) return FocusTarget.AdminConfirm;
        if (_masterPin.Length < SetupService.MasterPinLength) return FocusTarget.Master;
        if (_masterPinConfirm.Length < SetupService.MasterPinLength) return FocusTarget.MasterConfirm;
        return FocusTarget.None;
    }

    private void OnFirmNameBlur()
    {
        _firmName = _firmName.Trim();
        _firmNameVisited = true;
    }

    private void OnFirmNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (FirmNameValid)
        {
            _firmNameVisited = true;
            _pendingFocus = FocusTarget.Admin;
        }
        else if (BlockingReason is { } reason)
        {
            Snackbar.Add(reason, Severity.Info, c => c.VisibleStateDuration = 4000);
        }
    }

    private async Task OnPinKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (CanSubmit)
        {
            await Submit();
        }
        else if (BlockingReason is { } reason)
        {
            // Keyboard users can't focus the disabled submit button — surface
            // the reason here so they aren't left wondering why Enter is inert.
            Snackbar.Add(reason, Severity.Info, c => c.VisibleStateDuration = 4000);
        }
    }

    private async Task Submit()
    {
        if (_submitting) return;
        // Defence in depth: the button's Disabled gate is the primary check,
        // OnPinKeyDown also gates on CanSubmit, but Submit itself trusts neither.
        if (!CanSubmit) return;

        _submitting = true;
        try
        {
            // Snapshot field values so a thread-pool Task.Run can't read mutated state
            // if anything (test, late event) changes them during PBKDF2.
            var name = _firmName.Trim();
            var admin = _adminPin;
            var master = _masterPin;

            try
            {
                await Task.Run(() => Setup.Save(name, admin, master));
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Setup save failed");
                ShowError(MessageFor(ex));
                return;
            }

            // Owner just typed and confirmed both PINs — we have proof of physical
            // possession. Skip the immediate-after-setup unlock prompt.
            Session.EnterAdmin();
            Logger.LogInformation("Setup completed for firm {Firm}", name);

            _adminPin = _adminPinConfirm = _masterPin = _masterPinConfirm = "";

            ShowOk("Setup complete.");
            _redirectingMessage = "Setup complete — taking you to your firm…";
            _redirecting = true;
            Nav.NavigateTo("/", replace: true);
        }
        finally
        {
            if (!_redirecting) _submitting = false;
        }
    }

    private static string MessageFor(Exception ex) => ex switch
    {
        ArgumentException a => StripParamSuffix(a.Message),
        IOException                   => "Could not save setup. The setup file may be locked or the disk full.",
        UnauthorizedAccessException   => "Could not save setup. The application doesn't have permission to write to LocalAppData.",
        CryptographicException        => "Could not secure your PINs. The system's cryptography services are unavailable.",
        _                             => "Setup failed unexpectedly. Please try again."
    };

    private void GoHome()
    {
        _redirectingMessage = "Taking you to your firm…";
        _redirecting = true;
        Nav.NavigateTo("/", replace: true);
    }

    private void ShowResetConfirm() => _pageMode = PageMode.ResetConfirm;

    private void CancelReset() => _pageMode = PageMode.AlreadyConfigured;

    private void DoReset()
    {
        try
        {
            Setup.Reset();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Setup reset failed");
            ShowError("Could not reset setup. Please try again.");
            return;
        }

        _setupStatusSnapshot = Setup.Status;
        _pageMode = PageMode.NewSetup;
        // Ask for focus on the now-revealed firm-name field.
        _pendingFocus = FocusTarget.FirmName;
        ShowOk("Setup file removed. Set new PINs to continue.");
    }

    private void ShowOk(string message) =>
        Snackbar.Add(message, Severity.Success, config => config.VisibleStateDuration = 3000);

    private void ShowError(string message) =>
        Snackbar.Add(message, Severity.Error, config =>
        {
            config.ShowCloseIcon = true;
            config.VisibleStateDuration = 10000;
        });

    public void Dispose()
    {
        _pinHideCts?.Cancel();
        _pinHideCts?.Dispose();
    }
}
