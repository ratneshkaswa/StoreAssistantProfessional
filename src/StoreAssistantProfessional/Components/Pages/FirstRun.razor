@page "/"

<PageTitle>Welcome — Store Assistant Professional</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudStack Spacing="6" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Rounded.Storefront" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h3" Align="Align.Center">Store Assistant Professional</MudText>
        <MudText Typo="Typo.subtitle1" Align="Align.Center" Color="Color.Secondary">
            Welcome. Let's get your store set up.
        </MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   EndIcon="@Icons.Material.Rounded.ArrowForward">
            Get Started
        </MudButton>
    </MudStack>
</MudContainer>
