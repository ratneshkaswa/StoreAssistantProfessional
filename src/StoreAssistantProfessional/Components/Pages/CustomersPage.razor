@page "/customers"
@layout AppShell
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Customers — Store Assistant Professional</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h5">👥 Customers</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add" OnClick="StartNew">
            Add customer
        </MudButton>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-3" Style="box-shadow: inset 4px 0 0 var(--mud-palette-primary), 0 2px 4px rgba(0,0,0,0.08); min-height: 600px;">
                <MudStack Spacing="2">
                    <MudTextField @bind-Value="_search"
                                  Placeholder="Search by phone or name…"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Rounded.Search"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  DebounceInterval="200" />

                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Filtered.Count of @_customers.Count</MudText>
                    <MudDivider />

                    @if (Filtered.Count == 0)
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                            <MudIcon Icon="@Icons.Material.Rounded.PeopleOutline" Color="Color.Secondary" Style="font-size: 48px;" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                @(_customers.Count == 0 ? "No customers yet. Click Add customer to start." : "No matches.")
                            </MudText>
                        </MudStack>
                    }
                    else
                    {
                        <MudStack Spacing="1">
                            @foreach (var c in Filtered)
                            {
                                var isSel = _editing?.Id == c.Id;
                                <MudPaper Elevation="0"
                                          Class="pa-2"
                                          Style="@(isSel ? "border-left: 3px solid var(--mud-palette-primary); cursor: pointer;" : "cursor: pointer;")"
                                          @onclick="@(() => SelectExisting(c))">
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@c.Name</MudText>
                                            @if (c.LoyaltyPoints > 0)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">⭐ @c.LoyaltyPoints</MudChip>
                                            }
                                        </MudStack>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @(string.IsNullOrEmpty(c.Phone) ? "—" : c.Phone)
                                            @if (c.Balance != 0)
                                            {
                                                <span class="ml-2 sap-amount">· ₹@c.Balance.ToString("N0")</span>
                                            }
                                        </MudText>
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4" Style="box-shadow: inset 4px 0 0 var(--mud-palette-secondary), 0 2px 4px rgba(0,0,0,0.08); min-height: 600px;">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.h6">@(_isNew ? "➕ Add customer" : $"Edit · {_form.Name}")</MudText>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="8">
                            <MudTextField @bind-Value="_form.Name"
                                          Label="Name *"
                                          Variant="Variant.Outlined"
                                          MaxLength="200"
                                          Immediate="true"
                                          Error="@(_attempted && string.IsNullOrWhiteSpace(_form.Name))"
                                          ErrorText="Name is required." />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudCheckBox T="bool" @bind-Value="_form.IsActive" Color="Color.Primary">Active</MudCheckBox>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_form.Phone" Label="Phone (primary)" Variant="Variant.Outlined" MaxLength="15" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_form.AltPhone" Label="Alt phone" Variant="Variant.Outlined" MaxLength="15" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_form.Email" Label="Email" Variant="Variant.Outlined" MaxLength="200" />
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudTextField @bind-Value="_form.Gstin" Label="GSTIN (B2B)" Variant="Variant.Outlined" MaxLength="15" />
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudTextField @bind-Value="_form.Pan" Label="PAN" Variant="Variant.Outlined" MaxLength="10" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_form.Address" Label="Address" Variant="Variant.Outlined" MaxLength="300" />
                        </MudItem>
                        <MudItem xs="12" md="5">
                            <MudTextField @bind-Value="_form.City" Label="City" Variant="Variant.Outlined" MaxLength="100" />
                        </MudItem>
                        <MudItem xs="12" md="5">
                            <MudTextField @bind-Value="_form.State" Label="State" Variant="Variant.Outlined" MaxLength="100" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudTextField @bind-Value="_form.Pincode" Label="PIN" Variant="Variant.Outlined" MaxLength="6" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudDatePicker @bind-Date="_form.Birthday" Label="Birthday" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker @bind-Date="_form.Anniversary" Label="Anniversary" Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12"><MudText Typo="Typo.caption" Color="Color.Secondary">Credit &amp; loyalty</MudText></MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField T="decimal" @bind-Value="_form.Balance" Label="Outstanding ₹" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField T="decimal" @bind-Value="_form.CreditLimit" Label="Credit limit ₹" Variant="Variant.Outlined" Min="0" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField T="int" @bind-Value="_form.LoyaltyPoints" Label="Loyalty points" Variant="Variant.Outlined" Min="0" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_form.Notes" Label="Notes" Variant="Variant.Outlined" MaxLength="500" Lines="2"
                                          HelperText="e.g. fabric preferences, sizes, family connections" />
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                        @if (!_isNew)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="DeleteCurrent">Deactivate</MudButton>
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.OpenInNew" OnClick="@(() => Nav.NavigateTo($"/customers/{_form.Id}"))">Open ledger</MudButton>
                        }
                        <MudButton Variant="Variant.Text" OnClick="Reset">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">Save</MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private List<Customer> _customers = new();
    private Customer _form = new();
    private Customer? _editing;
    private bool _isNew = true;
    private bool _attempted;
    private bool _saving;
    private string _search = "";

    private List<Customer> Filtered =>
        string.IsNullOrWhiteSpace(_search)
            ? _customers.OrderBy(c => c.Name).ToList()
            : _customers.Where(c =>
                (c.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (c.Phone?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
              .OrderBy(c => c.Name)
              .ToList();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _customers = await db.Customers.AsNoTracking().Where(c => c.IsActive).OrderBy(c => c.Name).ToListAsync();
    }

    private void StartNew()
    {
        _form = new Customer { IsActive = true };
        _editing = null;
        _isNew = true;
        _attempted = false;
    }

    private void SelectExisting(Customer c)
    {
        _editing = c;
        _form = new Customer
        {
            Id = c.Id, Name = c.Name, Phone = c.Phone, AltPhone = c.AltPhone, Email = c.Email,
            Gstin = c.Gstin, Pan = c.Pan, Address = c.Address, City = c.City, State = c.State, Pincode = c.Pincode,
            Birthday = c.Birthday, Anniversary = c.Anniversary,
            Balance = c.Balance, CreditLimit = c.CreditLimit, LoyaltyPoints = c.LoyaltyPoints,
            Notes = c.Notes, IsActive = c.IsActive, CreatedAt = c.CreatedAt
        };
        _isNew = false;
        _attempted = false;
    }

    private void Reset() => StartNew();

    private async Task Save()
    {
        _attempted = true;
        if (string.IsNullOrWhiteSpace(_form.Name)) return;
        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (_isNew || _form.Id == 0)
            {
                _form.CreatedAt = DateTime.UtcNow;
                _form.UpdatedAt = DateTime.UtcNow;
                db.Customers.Add(_form);
            }
            else
            {
                var existing = await db.Customers.FirstOrDefaultAsync(c => c.Id == _form.Id);
                if (existing is null) { Snackbar.Add("Record was deleted elsewhere.", Severity.Warning); await LoadAsync(); return; }
                _form.UpdatedAt = DateTime.UtcNow;
                db.Entry(existing).CurrentValues.SetValues(_form);
            }
            await db.SaveChangesAsync();
            await LoadAsync();
            StartNew();
            Snackbar.Add("Customer saved.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Could not save: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task DeleteCurrent()
    {
        if (_editing is null) return;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Customers.FirstOrDefaultAsync(c => c.Id == _editing.Id);
            if (existing is not null)
            {
                existing.IsActive = false;
                existing.UpdatedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
            }
            await LoadAsync();
            StartNew();
            Snackbar.Add("Customer deactivated.", Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add($"Could not deactivate: {ex.Message}", Severity.Error); }
    }
}
