@page "/stocktake"
@layout AppShell
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<PageTitle>Stock take — Store Assistant Professional</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h5">📋 Stock take</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.Refresh" OnClick="LoadAsync">Refresh</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Save" OnClick="ApplyAdjustments" Disabled="@(_busy || !HasAnyDiff)">
                Apply adjustments
            </MudButton>
        </MudStack>
    </MudStack>

    <MudPaper Class="pa-3">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="_search"
                          Placeholder="Filter products…"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Rounded.Search"
                          Margin="Margin.Dense"
                          Immediate="true"
                          DebounceInterval="200"
                          Style="min-width: 280px;" />
            <MudCheckBox T="bool" @bind-Value="_onlyDiff" Color="Color.Primary">Show only changed</MudCheckBox>
            <span class="sap-statusbar-spacer"></span>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @ChangedCount changed · net adjustment ₹<span class="sap-amount">@NetAdjustment.ToString("N0")</span>
            </MudText>
        </MudStack>
    </MudPaper>

    @if (Filtered.Count == 0)
    {
        <MudPaper Class="pa-8" Elevation="0" Style="background: var(--mud-palette-background-grey);">
            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Rounded.Inventory2" Color="Color.Secondary" Style="font-size: 64px;" />
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    @(_rows.Count == 0 ? "No active products to count." : "No matches.")
                </MudText>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-0" Style="overflow: hidden;">
            <MudSimpleTable Hover="true" Dense="true">
                <thead>
                    <tr>
                        <th>SKU</th>
                        <th>Product</th>
                        <th style="text-align: right; width: 110px;">System</th>
                        <th style="text-align: right; width: 130px;">Counted</th>
                        <th style="text-align: right; width: 90px;">Diff</th>
                        <th style="width: 180px;">Reason</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Filtered)
                    {
                        <tr>
                            <td><MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: Consolas, monospace;">@(r.Product.Sku ?? "—")</MudText></td>
                            <td>
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2">@r.Product.Name</MudText>
                                    @if (!string.IsNullOrEmpty(r.Product.Category))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@r.Product.Category</MudText>
                                    }
                                </MudStack>
                            </td>
                            <td style="text-align: right;" class="sap-amount">@r.Product.StockQty.ToString("0.###")</td>
                            <td>
                                <MudNumericField T="decimal" Value="r.Counted" ValueChanged="@(v => { r.Counted = v; })"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                            </td>
                            <td style="text-align: right;">
                                @if (r.Diff != 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="@(r.Diff > 0 ? Color.Success : Color.Error)" Variant="Variant.Outlined" Class="sap-amount">
                                        @(r.Diff > 0 ? "+" : "")@r.Diff.ToString("0.###")
                                    </MudChip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                                }
                            </td>
                            <td>
                                @if (r.Diff != 0)
                                {
                                    <MudSelect T="string" Value="r.Reason" ValueChanged="@(v => { r.Reason = v; })"
                                               Variant="Variant.Outlined" Margin="Margin.Dense">
                                        <MudSelectItem Value="@("Counted")">Counted</MudSelectItem>
                                        <MudSelectItem Value="@("Damage")">Damage</MudSelectItem>
                                        <MudSelectItem Value="@("Theft")">Theft</MudSelectItem>
                                        <MudSelectItem Value="@("Correction")">Correction</MudSelectItem>
                                        <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                                    </MudSelect>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    }
</MudStack>

@code {
    private class Row
    {
        public Product Product { get; set; } = default!;
        public decimal Counted { get; set; }
        public decimal Diff => Counted - Product.StockQty;
        public string Reason { get; set; } = "Counted";
    }

    private List<Row> _rows = new();
    private string _search = "";
    private bool _onlyDiff;
    private bool _busy;

    private List<Row> Filtered => _rows
        .Where(r => string.IsNullOrWhiteSpace(_search) ||
                    (r.Product.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (r.Product.Sku?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (r.Product.Barcode?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(r => !_onlyDiff || r.Diff != 0)
        .OrderBy(r => r.Product.Name)
        .ToList();

    private int ChangedCount => _rows.Count(r => r.Diff != 0);
    private bool HasAnyDiff => ChangedCount > 0;

    private decimal NetAdjustment =>
        _rows.Where(r => r.Diff != 0)
             .Sum(r => r.Diff * (r.Product.Cost > 0 ? r.Product.Cost : r.Product.SalePrice));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var products = await db.Products.AsNoTracking().Where(p => p.IsActive).OrderBy(p => p.Name).ToListAsync();
        _rows = products.Select(p => new Row { Product = p, Counted = p.StockQty }).ToList();
    }

    private async Task ApplyAdjustments()
    {
        if (!HasAnyDiff) return;
        _busy = true;
        var batch = $"ST-{DateTime.UtcNow:yyyyMMddHHmmss}";
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            foreach (var r in _rows.Where(r => r.Diff != 0))
            {
                var product = await db.Products.FirstOrDefaultAsync(p => p.Id == r.Product.Id);
                if (product is null) continue;
                product.StockQty = r.Counted;
                product.UpdatedAt = DateTime.UtcNow;

                db.StockAdjustments.Add(new StockAdjustment
                {
                    ProductId = product.Id,
                    At = DateTime.UtcNow,
                    SystemQty = r.Product.StockQty,
                    CountedQty = r.Counted,
                    Diff = r.Diff,
                    Kind = "StockTake",
                    Reason = r.Reason,
                    BatchTag = batch
                });
            }
            await db.SaveChangesAsync();
            Snackbar.Add($"Applied {ChangedCount} adjustment(s).", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not apply: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }
}
