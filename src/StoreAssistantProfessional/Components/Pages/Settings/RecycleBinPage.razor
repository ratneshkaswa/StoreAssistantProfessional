@page "/settings/recycle"
@layout AppShell
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<PageTitle>Recycle bin — Settings</PageTitle>

<MudStack Spacing="3">
    <SettingsBackBar Title="Recycle bin" />

    <MudPaper Class="pa-5" Style="box-shadow: inset 4px 0 0 var(--mud-palette-primary), 0 2px 4px rgba(0,0,0,0.08);">
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Records you deactivated. Reactivate any to bring it back into active lists.
            Records that have transactions can never be deleted permanently — only deactivated and reactivated.
        </MudText>
    </MudPaper>

    <MudTabs Outlined="true" Position="Position.Top" Rounded="true" Border="true">
        <MudTabPanel Text="@($"Vendors ({_vendors.Count})")" Icon="@Icons.Material.Rounded.Handshake">
            @if (_vendors.Count == 0) { @EmptyHint }
            else
            {
                <MudPaper Class="pa-2">
                    <MudSimpleTable Dense="true">
                        <thead><tr><th>Name</th><th>Phone</th><th>Updated</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var v in _vendors)
                            {
                                <tr>
                                    <td>@v.Name</td>
                                    <td>@(v.Phone ?? "—")</td>
                                    <td>@v.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                    <td><MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Rounded.Restore" OnClick="@(() => Reactivate<Vendor>(v.Id, e => e.IsActive = true))">Reactivate</MudButton></td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            }
        </MudTabPanel>
        <MudTabPanel Text="@($"Customers ({_customers.Count})")" Icon="@Icons.Material.Rounded.People">
            @if (_customers.Count == 0) { @EmptyHint }
            else
            {
                <MudPaper Class="pa-2">
                    <MudSimpleTable Dense="true">
                        <thead><tr><th>Name</th><th>Phone</th><th>Updated</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var c in _customers)
                            {
                                <tr>
                                    <td>@c.Name</td>
                                    <td>@(c.Phone ?? "—")</td>
                                    <td>@c.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                    <td><MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Rounded.Restore" OnClick="@(() => Reactivate<Customer>(c.Id, e => e.IsActive = true))">Reactivate</MudButton></td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            }
        </MudTabPanel>
        <MudTabPanel Text="@($"Staff ({_staff.Count})")" Icon="@Icons.Material.Rounded.Badge">
            @if (_staff.Count == 0) { @EmptyHint }
            else
            {
                <MudPaper Class="pa-2">
                    <MudSimpleTable Dense="true">
                        <thead><tr><th>Name</th><th>Code</th><th>Updated</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var s in _staff)
                            {
                                <tr>
                                    <td>@s.Name</td>
                                    <td>@s.Code.ToString("D2")</td>
                                    <td>@s.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                    <td><MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Rounded.Restore" OnClick="@(() => Reactivate<Staff>(s.Id, e => e.IsActive = true))">Reactivate</MudButton></td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            }
        </MudTabPanel>
        <MudTabPanel Text="@($"Products ({_products.Count})")" Icon="@Icons.Material.Rounded.Inventory2">
            @if (_products.Count == 0) { @EmptyHint }
            else
            {
                <MudPaper Class="pa-2">
                    <MudSimpleTable Dense="true">
                        <thead><tr><th>Name</th><th>SKU</th><th>Updated</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var p in _products)
                            {
                                <tr>
                                    <td>@p.Name</td>
                                    <td>@(p.Sku ?? "—")</td>
                                    <td>@p.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                    <td><MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Rounded.Restore" OnClick="@(() => Reactivate<Product>(p.Id, e => e.IsActive = true))">Reactivate</MudButton></td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            }
        </MudTabPanel>
        <MudTabPanel Text="@($"Tax rates ({_taxes.Count})")" Icon="@Icons.Material.Rounded.Percent">
            @if (_taxes.Count == 0) { @EmptyHint }
            else
            {
                <MudPaper Class="pa-2">
                    <MudSimpleTable Dense="true">
                        <thead><tr><th>Name</th><th>Rate</th><th>Created</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var t in _taxes)
                            {
                                <tr>
                                    <td>@t.Name</td>
                                    <td>@t.Rate.ToString("0.##")%</td>
                                    <td>@t.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                    <td><MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Rounded.Restore" OnClick="@(() => Reactivate<TaxRate>(t.Id, e => e.IsActive = true))">Reactivate</MudButton></td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            }
        </MudTabPanel>
    </MudTabs>
</MudStack>

@code {
    private List<Vendor> _vendors = new();
    private List<Customer> _customers = new();
    private List<Staff> _staff = new();
    private List<Product> _products = new();
    private List<TaxRate> _taxes = new();

    private RenderFragment EmptyHint => @<MudPaper Class="pa-6" Elevation="0" Style="background: var(--mud-palette-background-grey);">
        <MudStack AlignItems="AlignItems.Center"><MudIcon Icon="@Icons.Material.Rounded.Delete" Color="Color.Secondary" Style="font-size: 48px;" /><MudText Typo="Typo.body2" Color="Color.Secondary">Empty.</MudText></MudStack>
    </MudPaper>;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _vendors = await db.Vendors.AsNoTracking().Where(v => !v.IsActive).OrderByDescending(v => v.UpdatedAt).ToListAsync();
        _customers = await db.Customers.AsNoTracking().Where(c => !c.IsActive).OrderByDescending(c => c.UpdatedAt).ToListAsync();
        _staff = await db.Staff.AsNoTracking().Where(s => !s.IsActive).OrderByDescending(s => s.UpdatedAt).ToListAsync();
        _products = await db.Products.AsNoTracking().Where(p => !p.IsActive).OrderByDescending(p => p.UpdatedAt).ToListAsync();
        _taxes = await db.TaxRates.AsNoTracking().Where(t => !t.IsActive).OrderByDescending(t => t.CreatedAt).ToListAsync();
    }

    private async Task Reactivate<T>(int id, Action<T> apply) where T : class
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.Set<T>().FindAsync(id);
            if (entity is null) return;

            if (await WouldCollide(db, entity))
            {
                Snackbar.Add($"Cannot reactivate: another active {typeof(T).Name} already uses this name / code / SKU. Rename one first.", Severity.Warning);
                return;
            }

            apply(entity);
            await db.SaveChangesAsync();
            Snackbar.Add($"{typeof(T).Name} reactivated.", Severity.Success);
            await LoadAsync();
        }
        catch (DbUpdateException ex) when (ex.InnerException?.Message?.Contains("UNIQUE", StringComparison.OrdinalIgnoreCase) == true)
        {
            Snackbar.Add("Cannot reactivate — a unique field collides with an existing record.", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not reactivate: {ex.Message}", Severity.Error);
        }
    }

    private static async Task<bool> WouldCollide<T>(AppDbContext db, T entity) where T : class
    {
        switch (entity)
        {
            case TaxRate tr:
                return await db.TaxRates.AnyAsync(x => x.IsActive && x.Name == tr.Name && x.Id != tr.Id);
            case Staff s:
                return await db.Staff.AnyAsync(x => x.IsActive && x.Code == s.Code && x.Id != s.Id);
            case Product p when !string.IsNullOrEmpty(p.Sku):
                return await db.Products.AnyAsync(x => x.IsActive && x.Sku == p.Sku && x.Id != p.Id);
            default:
                return false;
        }
    }
}
