@page "/settings/firm"
@layout AppShell
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<PageTitle>Firm — Settings</PageTitle>

<MudStack Spacing="3">
    <SettingsBackBar Title="Firm details" />

    <MudPaper Class="pa-5" Style="box-shadow: inset 4px 0 0 var(--mud-palette-primary), 0 2px 4px rgba(0,0,0,0.08);">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Identity</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudTextField @bind-Value="_firm.Name" Label="Firm name *" Variant="Variant.Outlined" MaxLength="200" />
                </MudItem>
                <MudItem xs="12">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudSwitch T="bool" @bind-Value="_firm.HasGstRegistration" Color="Color.Primary">
                            GST registered
                        </MudSwitch>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Turn on if your firm has a GSTIN.
                        </MudText>
                    </MudStack>
                </MudItem>
                @if (_firm.HasGstRegistration)
                {
                    <MudItem xs="12" md="6">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.End">
                            <MudTextField @bind-Value="_firm.Gstin" Label="GSTIN" Variant="Variant.Outlined" MaxLength="15" />
                            <HelpHint Text="15-digit GST identification number. Format: 2-digit state code + 10-digit PAN + 1-digit entity + Z + checksum." />
                        </MudStack>
                    </MudItem>
                }
                <MudItem xs="12" md="@(_firm.HasGstRegistration ? 6 : 12)">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.End">
                        <MudTextField @bind-Value="_firm.Pan" Label="PAN" Variant="Variant.Outlined" MaxLength="10" />
                        <HelpHint Text="10-character Permanent Account Number issued by Income Tax Dept. Format: AAAAA9999A." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="8"><MudTextField @bind-Value="_firm.StateName" Label="State" Variant="Variant.Outlined" MaxLength="100" /></MudItem>
                <MudItem xs="12" md="4"><MudTextField @bind-Value="_firm.StateCode" Label="State code" Variant="Variant.Outlined" MaxLength="2" /></MudItem>
            </MudGrid>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-5" Style="box-shadow: inset 4px 0 0 var(--mud-palette-secondary), 0 2px 4px rgba(0,0,0,0.08);">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Financial year</MudText>
            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                <MudText>FY starts on</MudText>
                <MudSelect T="int" @bind-Value="_firm.FyStartDay" Variant="Variant.Outlined" Dense="true" Style="width: 100px;">
                    @for (var d = 1; d <= 31; d++) { var dd = d; <MudSelectItem Value="dd">@dd</MudSelectItem> }
                </MudSelect>
                <MudSelect T="int" @bind-Value="_firm.FyStartMonth" Variant="Variant.Outlined" Dense="true" Style="width: 160px;">
                    @for (var m = 1; m <= 12; m++) { var mm = m; <MudSelectItem Value="mm">@_monthNames[mm - 1]</MudSelectItem> }
                </MudSelect>
            </MudStack>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Current FY based on today: @CurrentFyLabel</MudText>
            <MudText Typo="Typo.caption" Color="Color.Warning">
                ⚠ Changing FY start mid-year will affect how reports group historical data.
            </MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-5" Style="box-shadow: inset 4px 0 0 var(--mud-palette-tertiary), 0 2px 4px rgba(0,0,0,0.08);">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Contact &amp; address</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.Phone" Label="Phone" Variant="Variant.Outlined" MaxLength="20" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.Email" Label="Email" Variant="Variant.Outlined" MaxLength="200" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_firm.AddressLine1" Label="Address" Variant="Variant.Outlined" MaxLength="300" /></MudItem>
                <MudItem xs="12" md="8"><MudTextField @bind-Value="_firm.City" Label="City" Variant="Variant.Outlined" MaxLength="100" /></MudItem>
                <MudItem xs="12" md="4"><MudTextField @bind-Value="_firm.Pincode" Label="Pincode" Variant="Variant.Outlined" MaxLength="6" /></MudItem>
            </MudGrid>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-5" Style="box-shadow: inset 4px 0 0 var(--mud-palette-info), 0 2px 4px rgba(0,0,0,0.08);">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Bank (for receipts)</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.BankName" Label="Bank name" Variant="Variant.Outlined" MaxLength="200" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.AccountHolderName" Label="Account holder" Variant="Variant.Outlined" MaxLength="100" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.AccountNumber" Label="Account no." Variant="Variant.Outlined" MaxLength="20" /></MudItem>
                <MudItem xs="12" md="6">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.End">
                        <MudTextField @bind-Value="_firm.IfscCode" Label="IFSC" Variant="Variant.Outlined" MaxLength="11" />
                        <HelpHint Text="Indian Financial System Code — 11-character bank-branch identifier. Format: 4 letters + 0 + 6 alphanumeric." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.BranchName" Label="Branch" Variant="Variant.Outlined" MaxLength="200" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.UpiId" Label="UPI ID" Variant="Variant.Outlined" MaxLength="100" /></MudItem>
            </MudGrid>
        </MudStack>
    </MudPaper>

    @* Invoice numbering is fixed (DD-MMM-YY-NNN) — no settings UI. *@
    <MudPaper Class="pa-5" Outlined="true">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Color="Color.Default" Size="Size.Small" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.body2">Invoice numbering: <strong>@SampleInvoiceFormat</strong></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Date + daily counter. No configuration.
                </MudText>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudStack Row="true" Justify="Justify.FlexEnd">
        <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Disabled="@_busy">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> <span>Saving…</span> }
            else { <span>Save</span> }
        </MudButton>
    </MudStack>
</MudStack>

@code {
    private Firm _firm = new();
    private bool _busy;

    private static readonly string[] _monthNames =
    [
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
    ];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.Firms.FirstOrDefaultAsync();
        _firm = existing ?? new Firm();
    }

    private string CurrentFyLabel
    {
        get
        {
            var today = DateTime.Today;
            var startThisYear = new DateTime(today.Year, _firm.FyStartMonth, Math.Min(_firm.FyStartDay, DateTime.DaysInMonth(today.Year, _firm.FyStartMonth)));
            var fyStart = today >= startThisYear ? startThisYear : startThisYear.AddYears(-1);
            var fyEnd = fyStart.AddYears(1).AddDays(-1);
            return $"FY {fyStart.Year}-{(fyEnd.Year % 100):D2} ({fyStart:dd MMM yyyy} → {fyEnd:dd MMM yyyy})";
        }
    }

    private static string SampleInvoiceFormat => $"{DateTime.Today:dd-MMM-yy}-001";

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_firm.Name)) { Snackbar.Add("Firm name is required.", Severity.Warning); return; }

        _busy = true;
        try
        {
            // Honour the GST toggle: blank Gstin if the toggle is off so we
            // don't persist orphan data the user can't see.
            if (!_firm.HasGstRegistration)
            {
                _firm.Gstin = null;
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Firms.FirstOrDefaultAsync();
            if (existing is null)
            {
                _firm.Id = Firm.SingletonId;
                _firm.CreatedAt = DateTime.UtcNow;
                _firm.UpdatedAt = DateTime.UtcNow;
                db.Firms.Add(_firm);
            }
            else
            {
                _firm.Id = existing.Id;
                _firm.CreatedAt = existing.CreatedAt;
                _firm.UpdatedAt = DateTime.UtcNow;
                db.Entry(existing).CurrentValues.SetValues(_firm);
            }
            await db.SaveChangesAsync();
            Snackbar.Add("Firm saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not save: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }
}
