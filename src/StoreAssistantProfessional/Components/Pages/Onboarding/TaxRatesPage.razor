@page "/onboarding/tax"
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Logging
@using StoreAssistantProfessional.Components.Shared
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISetupService Setup
@inject IOnboardingService Onboarding
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<TaxRatesPage> Logger

<PageTitle>Taxes — Setup</PageTitle>

<OnboardingShell Current="OnboardingStep.Tax"
                 HeroIcon="@Icons.Material.Rounded.ReceiptLong"
                 DecoIcon="@Icons.Material.Rounded.ReceiptLong"
                 HeroHeading="Set your tax rates"
                 NextHint="Next: list your products."
                 BlockingReason="@BlockingReason"
                 ReadyMessage="Tax rates set — click Next."
                 HideHero="true">

    @* Composition scheme toggle — moved here from the Firm step because it's
       a tax-classification choice, not a firm-identity field. Persists to
       Firm.IsCompositionScheme on toggle (immediate, no separate save).
       Cross-validation: composition requires GST registration; the toggle
       is disabled with a helper message when the firm is not GST-registered. *@
    <MudPaper Class="pa-3 mb-3" Outlined="true">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudSwitch T="bool"
                           Value="_isCompositionScheme"
                           ValueChanged="OnCompositionToggled"
                           Color="Color.Primary"
                           Disabled="@(!_firmHasGst || _savingComposition)">
                    Firm is on Composition scheme
                </MudSwitch>
                <HelpHint Text="Composition firms issue 'Bill of Supply' (no tax broken out on receipts) and have a turnover cap. Toggle on only if registered." />
            </MudStack>
            @if (!_firmHasGst)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Composition requires GST registration (set on the Firm step).
                </MudText>
            }
            else if (_savingComposition)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 sap-step-card" Style="min-height: 480px;">
                    <MudStack Spacing="3">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">Tax rates (@_taxes.Count)</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Rounded.Add" OnClick="StartNew">Add</MudButton>
                        </MudStack>

                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Quick add</MudText>
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                @foreach (var preset in _quickAddPresets)
                                {
                                    var p = preset;
                                    var exists = _taxes.Any(t => string.Equals(t.Name, p.Name, StringComparison.OrdinalIgnoreCase));
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Outlined"
                                               Disabled="@(exists || _saving)"
                                               OnClick="@(() => QuickAdd(p))">
                                        @(exists ? $"{p.Label} ✓" : p.Label)
                                    </MudButton>
                                }
                            </MudStack>
                        </MudStack>

                        <MudDivider />

                        @if (_loading)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                            </MudStack>
                        }
                        else if (_loadError is not null)
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                                Could not load tax rates. @_loadError
                                <MudButton Class="ml-2" Size="Size.Small" Variant="Variant.Text" OnClick="ReloadAsync">Retry</MudButton>
                            </MudAlert>
                        }
                        else if (_taxes.Count == 0)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                                <MudIcon Icon="@Icons.Material.Rounded.Receipt" Color="Color.Secondary" Style="font-size: 48px;" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                    No tax rates yet. Use a quick-add chip above or click Add to create one.
                                </MudText>
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Spacing="1">
                                @foreach (var t in _taxes)
                                {
                                    var isSel = _editing?.Id == t.Id;
                                    var item = t;
                                    <div class="@(isSel ? "sap-list-row sap-list-row-active" : "sap-list-row")"
                                         tabindex="0"
                                         role="button"
                                         aria-pressed="@(isSel ? "true" : "false")"
                                         @onclick="@(() => SelectExisting(item))"
                                         @onkeydown="@((KeyboardEventArgs e) => OnRowKey(e, item))">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudStack Spacing="0">
                                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@item.Name</MudText>
                                                    @if (item.IsDefault)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">default</MudChip>
                                                    }
                                                </MudStack>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @item.Rate.ToString("0.##")% · HSN @(string.IsNullOrEmpty(item.HsnCode) ? "—" : item.HsnCode) · @item.SlabDisplay
                                                </MudText>
                                            </MudStack>
                                        </MudStack>
                                    </div>
                                }
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 sap-step-card" Style="min-height: 480px;">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.h6">@(_isNew ? "➕ Add tax rate" : $"Edit · {_form.Name}")</MudText>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="8">
                                <MudTextField @bind-Value="_form.Name"
                                              Label="Name *"
                                              Variant="Variant.Outlined"
                                              MaxLength="100"
                                              Immediate="true"
                                              AutoFocus="true"
                                              Error="@(_attempted && string.IsNullOrWhiteSpace(_form.Name))"
                                              ErrorText="Name is required."
                                              OnKeyDown="OnEnter" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudCheckBox T="bool" @bind-Value="_form.IsDefault" Color="Color.Primary">
                                    Default rate
                                </MudCheckBox>
                            </MudItem>

                            <MudItem xs="6" md="3">
                                <MudNumericField T="decimal?" @bind-Value="_form.RateNullable"
                                                 Label="Rate (%) *" Variant="Variant.Outlined"
                                                 Min="0" Max="50" Step="0.25m"
                                                 Error="@(_attempted && !RateValid)"
                                                 ErrorText="@RateError" />
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudNumericField T="decimal?" @bind-Value="_form.CessRateNullable"
                                                 Label="Cess (%)" Variant="Variant.Outlined"
                                                 Min="0" Max="100" Step="0.25m"
                                                 Error="@(_attempted && !CessConsistent)"
                                                 ErrorText="Cess rate and Cess type must be set together." />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudSelect T="string" @bind-Value="_form.CessType" Label="Cess type" Variant="Variant.Outlined" Clearable="true">
                                    <MudSelectItem Value="@((string?)null)">—</MudSelectItem>
                                    <MudSelectItem Value="@("Compensation")">Compensation</MudSelectItem>
                                    <MudSelectItem Value="@("State")">State</MudSelectItem>
                                    <MudSelectItem Value="@("GST")">GST</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudCheckBox T="bool" @bind-Value="_form.IsTaxInclusive" Color="Color.Primary">
                                        Tax inclusive
                                    </MudCheckBox>
                                    <HelpHint Text="When ticked, the unit price you enter on a bill already includes this tax. The bill's tax line is computed by extracting the tax from that price instead of adding tax on top." />
                                </MudStack>
                            </MudItem>

                            <MudItem xs="12">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Optional price slab — leave blank for "any price".</MudText>
                            </MudItem>
                            <MudItem xs="6" md="4">
                                <MudNumericField T="decimal?" @bind-Value="_form.MinPrice" Label="Min ₹" Variant="Variant.Outlined" Min="0" />
                            </MudItem>
                            <MudItem xs="6" md="4">
                                <MudNumericField T="decimal?" @bind-Value="_form.MaxPrice" Label="Max ₹ (blank = & above)" Variant="Variant.Outlined" Min="0"
                                                 Error="@(_attempted && !SlabOrderValid)"
                                                 ErrorText="Max must be greater than Min." />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="_form.HsnCode"
                                              Label="HSN code" Variant="Variant.Outlined" MaxLength="8" Immediate="true"
                                              Error="@(_attempted && !IndianFormats.IsHsn(_form.HsnCode))"
                                              ErrorText="2–8 digits." />
                            </MudItem>
                            @if (SlabIsDegenerate)
                            {
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Color="Color.Warning">
                                        Min=0 with blank Max isn't a slab — leave both blank if this rate covers all prices.
                                    </MudText>
                                </MudItem>
                            }

                            <MudItem xs="12">
                                <MudSelect T="string" @bind-Value="_form.TaxCategory" Label="Tax category" Variant="Variant.Outlined">
                                    <MudSelectItem Value="@("Taxable")">Taxable</MudSelectItem>
                                    <MudSelectItem Value="@("NilRated")">Nil rated</MudSelectItem>
                                    <MudSelectItem Value="@("Exempt")">Exempt</MudSelectItem>
                                    <MudSelectItem Value="@("ZeroRated")">Zero rated</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                        </MudGrid>

                        @if (_form.Rate > 0)
                        {
                            var sample = 600m;
                            var cgst = sample * _form.CgstRate / 100m;
                            var sgst = sample * _form.SgstRate / 100m;
                            <MudPaper Class="pa-2" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                                <MudText Typo="Typo.caption">
                                    Sample on ₹@sample.ToString("0") base · CGST @($"{_form.CgstRate:0.##}%") = ₹@($"{cgst:0.##}") + SGST @($"{_form.SgstRate:0.##}%") = ₹@($"{sgst:0.##}") · Total tax ₹@($"{(cgst + sgst):0.##}")
                                </MudText>
                            </MudPaper>
                        }

                        <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                            @if (!_isNew)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="DeleteCurrent" Disabled="@_saving">Delete</MudButton>
                            }
                            <MudButton Variant="Variant.Text" OnClick="Reset" Disabled="@_saving">Cancel</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">
                                @if (_saving)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Saving…</span>
                                }
                                else
                                {
                                    <span>Save tax rate</span>
                                }
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
        <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo(Onboarding.RouteFor(OnboardingStep.Firm)))">‹ Back</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   OnClick="GoNext"
                   Disabled="@(_taxes.Count == 0)">Next ›</MudButton>
    </MudStack>
</OnboardingShell>

@code {
    private List<TaxRate> _taxes = new();
    private TaxVm _form = new();
    // Snapshot of the form at edit-start, so Cancel reverts changes to the
    // currently-edited row instead of discarding the row entirely (X3 / T14).
    private TaxVm? _formOriginal;
    private TaxRate? _editing;
    private bool _isNew = true;
    private bool _attempted;
    private bool _saving;
    private bool _loading = true;
    private string? _loadError;

    // Firm.IsCompositionScheme is edited from this page (moved from the Firm
    // step). _firmHasGst gates the toggle — composition without GST is
    // legally meaningless. Both are loaded from the firm row in LoadAsync.
    private bool _isCompositionScheme;
    private bool _firmHasGst;
    private bool _savingComposition;

    private record QuickAddPreset(string Label, string Name, decimal Rate, string Category);

    private static readonly QuickAddPreset[] _quickAddPresets =
    [
        new("GST 5%",  "GST 5%",  5m,  "Taxable"),
        new("GST 12%", "GST 12%", 12m, "Taxable"),
        new("GST 18%", "GST 18%", 18m, "Taxable"),
        new("GST 28%", "GST 28%", 28m, "Taxable"),
        new("Exempt 0%", "Exempt", 0m, "Exempt"),
    ];

    private string? BlockingReason
    {
        get
        {
            if (_loading) return null;
            if (_taxes.Count == 0) return "Add at least one tax rate to continue.";
            return null;
        }
    }

    private bool RateValid => _form.Rate >= 0 && _form.Rate <= 50 && CategoryRateConsistent;
    private bool CategoryRateConsistent =>
        _form.TaxCategory == "Taxable" ? _form.Rate > 0 : _form.Rate == 0;
    private bool CessConsistent =>
        (string.IsNullOrWhiteSpace(_form.CessType) && _form.CessRate == 0) ||
        (!string.IsNullOrWhiteSpace(_form.CessType) && _form.CessRate > 0);
    private bool SlabOrderValid =>
        !_form.MinPrice.HasValue || !_form.MaxPrice.HasValue || _form.MaxPrice > _form.MinPrice;

    // T11 / T19: Min=0 with blank Max means "all prices" — that's the absence
    // of a slab, not a slab. If the user intended "no slab", they should leave
    // both blank; "0..∞" is a configuration mistake we surface explicitly.
    private bool SlabIsDegenerate =>
        _form.MinPrice is 0m && _form.MaxPrice is null;

    private string RateError =>
        _form.TaxCategory == "Taxable" && _form.Rate == 0
            ? "Taxable rate must be greater than 0%."
            : !CategoryRateConsistent
                ? $"Rate must be 0 for category '{_form.TaxCategory}'."
                : "Rate must be 0–50%.";

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_form.Name) &&
        _form.Name.Length <= 100 &&
        RateValid &&
        CessConsistent &&
        // T5 / T17: server-side cess upper-clamp — paste of 200 bypasses MudNumericField.
        _form.CessRate is >= 0m and <= 100m &&
        SlabOrderValid &&
        !SlabIsDegenerate &&
        IndianFormats.IsHsn(_form.HsnCode);

    protected override async Task OnInitializedAsync()
    {
        if (!Setup.IsComplete) { Nav.NavigateTo("/setup", replace: true); return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            // SQLite stores decimal as TEXT and refuses to ORDER BY it; sort
            // by the indexed integer SortOrder server-side and break ties on
            // Rate client-side so the table-wide order is still stable.
            var rows = await db.TaxRates.AsNoTracking().Where(t => t.IsActive)
                .OrderBy(t => t.SortOrder).ToListAsync();
            _taxes = rows.OrderBy(t => t.SortOrder).ThenBy(t => t.Rate).ToList();

            // Load firm-level composition + GST flags so the top toggle
            // reflects current state and gates correctly.
            var firm = await db.Firms.AsNoTracking().FirstOrDefaultAsync();
            _isCompositionScheme = firm?.IsCompositionScheme ?? false;
            _firmHasGst = firm?.HasGstRegistration ?? false;
        }
        catch (Exception ex)
        {
            // T7: don't let a DB load error crash the WebView. Surface it inline
            // and keep the page renderable so the user can retry.
            Logger.LogError(ex, "Failed to load tax rates");
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Task ReloadAsync() => LoadAsync();

    // Persists the composition flag immediately on toggle — there's no
    // "save firm" button on this page. Concurrency-wise: a tap on the toggle
    // mid-flight (e.g. user double-clicks) gets gated by `_savingComposition`.
    private async Task OnCompositionToggled(bool value)
    {
        if (_savingComposition) return;
        // Defensive: composition without GST is meaningless. The toggle is
        // already disabled in that case via the markup; this is a backstop.
        if (!_firmHasGst && value) return;

        _savingComposition = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var firm = await db.Firms.FirstOrDefaultAsync();
            if (firm is null)
            {
                Snackbar.Add("Firm not found. Complete the Firm step first.", Severity.Warning);
                return;
            }
            firm.IsCompositionScheme = value;
            firm.UpdatedAt = DateTime.UtcNow;
            await db.SaveChangesAsync();
            _isCompositionScheme = value;
            Snackbar.Add(value ? "Composition scheme on." : "Composition scheme off.",
                Severity.Success, c => c.VisibleStateDuration = 2000);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to toggle composition scheme");
            Snackbar.Add($"Could not update: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingComposition = false;
        }
    }

    private void StartNew()
    {
        _form = new TaxVm { TaxCategory = "Taxable", IsActive = true };
        _formOriginal = null;   // new row has no "original" to revert to
        _editing = null;
        _isNew = true;
        _attempted = false;
    }

    private void SelectExisting(TaxRate t)
    {
        _editing = t;
        _form = TaxVm.From(t);
        _formOriginal = TaxVm.From(t);   // pristine snapshot for Cancel-revert
        _isNew = false;
        _attempted = false;
    }

    private void OnRowKey(KeyboardEventArgs e, TaxRate t)
    {
        if (e.Key is "Enter" or " ") SelectExisting(t);
    }

    private async Task QuickAdd(QuickAddPreset preset)
    {
        if (_taxes.Any(t => string.Equals(t.Name, preset.Name, StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add($"{preset.Name} already exists.", Severity.Info);
            return;
        }
        _form = new TaxVm
        {
            Name = preset.Name,
            Rate = preset.Rate,
            TaxCategory = preset.Category,
            IsActive = true,
        };
        _editing = null;
        _isNew = true;
        await Save();
    }

    private void Reset()
    {
        // X3 / T14: Cancel reverts an in-progress edit to the original row data
        // instead of discarding the row entirely. For a new (unsaved) row,
        // there's nothing to revert to, so we fall back to a fresh form.
        if (_formOriginal is not null && !_isNew)
        {
            _form = _formOriginal;
            _formOriginal = TaxVm.From(_editing!);   // re-snapshot for next Cancel
            _attempted = false;
        }
        else
        {
            StartNew();
        }
    }

    private async Task OnEnter(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (!_saving && IsValid) await Save();
    }

    private async Task Save()
    {
        _attempted = true;
        if (!IsValid)
        {
            // T2: don't fail silently when invalid — surface the first issue
            // so the user knows what's blocking the save.
            Snackbar.ShowWarning(FirstInvalidReason());
            return;
        }

        _form.Name = _form.Name.Trim();
        _form.HsnCode = string.IsNullOrWhiteSpace(_form.HsnCode) ? null : _form.HsnCode.Trim();

        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // T1: case-insensitive uniqueness pre-check. The DB column has
            // NOCASE collation so `==` is case-insensitive on a fresh DB; on
            // older DBs we add an explicit ToLower comparison for safety.
            var formNameLower = _form.Name.ToLowerInvariant();
            var nameTaken = await db.TaxRates
                .Where(t => t.IsActive && t.Id != _form.Id)
                .AnyAsync(t => t.Name.ToLower() == formNameLower);
            if (nameTaken)
            {
                Snackbar.ShowError("A tax rate with that name already exists.");
                return;
            }

            if (_form.IsDefault)
            {
                var existingDefaults = await db.TaxRates
                    .Where(t => t.IsDefault && t.Id != _form.Id).ToListAsync();
                foreach (var d in existingDefaults) d.IsDefault = false;
            }

            int newId = _form.Id;
            if (_isNew || _form.Id == 0)
            {
                var entity = _form.ToEntity();
                entity.CreatedAt = DateTime.UtcNow;
                db.TaxRates.Add(entity);
                await db.SaveChangesAsync();
                newId = entity.Id;
            }
            else
            {
                var existing = await db.TaxRates.FirstOrDefaultAsync(t => t.Id == _form.Id);
                if (existing is null)
                {
                    Snackbar.Add("Record was deleted elsewhere.", Severity.Warning);
                    await LoadAsync();
                    StartNew();
                    return;
                }
                _form.ApplyTo(existing);
                await db.SaveChangesAsync();
            }

            await LoadAsync();
            // Keep the just-saved row selected so the user sees confirmation.
            var saved = _taxes.FirstOrDefault(t => t.Id == newId);
            if (saved is not null) SelectExisting(saved);
            else StartNew();
            _attempted = false;   // X2: clear sticky errors after a clean save
            Snackbar.ShowOk("Tax rate saved.");
        }
        catch (DbUpdateException ex) when (ex.InnerException?.Message?.Contains("UNIQUE", StringComparison.OrdinalIgnoreCase) == true)
        {
            Snackbar.ShowError("A tax rate with that name already exists.");
        }
        catch (DbUpdateException ex)
        {
            Logger.LogError(ex, "Failed to save tax rate (DB)");
            Snackbar.ShowError($"Could not save: {ex.InnerException?.Message ?? ex.Message}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save tax rate");
            Snackbar.ShowError($"Could not save: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    // T2: walk validators in priority order to surface the most actionable
    // reason in the snackbar. Mirrors BlockingReason but per-form-row.
    private string FirstInvalidReason()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) return "Tax rate name is required.";
        if (_form.Name.Length > 100) return "Tax rate name is too long (100 chars max).";
        if (!RateValid) return RateError;
        if (!CessConsistent) return "Cess rate and Cess type must be set together.";
        if (_form.CessRate is < 0m or > 100m) return "Cess rate must be 0–100%.";
        if (!SlabOrderValid) return "Slab Max must be greater than Min.";
        if (SlabIsDegenerate) return "Min=0 with blank Max isn't a slab — leave both blank for any-price.";
        if (!IndianFormats.IsHsn(_form.HsnCode)) return "HSN must be 2–8 digits.";
        return "Form has errors — fix the highlighted fields.";
    }

    private async Task DeleteCurrent()
    {
        if (_editing is null) return;

        await using var db = await DbFactory.CreateDbContextAsync();

        // T3: refuse to delete a tax rate that active products point to —
        // those products would end up with a dangling TaxRateId that the
        // dropdown can't render. Tell the user how many products are affected
        // so they can reassign before retrying.
        var inUseCount = await db.Products.AsNoTracking()
            .CountAsync(p => p.IsActive && p.TaxRateId == _editing.Id);
        if (inUseCount > 0)
        {
            Snackbar.ShowWarning(
                $"\"{_editing.Name}\" is used by {inUseCount} product{(inUseCount == 1 ? "" : "s")}. " +
                "Reassign them first, then delete.");
            return;
        }

        var ok = await Confirm($"Delete tax rate \"{_editing.Name}\"?",
            "It will be soft-deleted and won't appear in lists.", "Delete");
        if (!ok) return;

        try
        {
            var existing = await db.TaxRates.FirstOrDefaultAsync(t => t.Id == _editing.Id);
            if (existing is null) { await LoadAsync(); StartNew(); return; }

            var wasDefault = existing.IsDefault;
            existing.IsActive = false;
            existing.IsDefault = false;

            // T4: if we just removed the default, auto-promote another active
            // tax rate so downstream forms (e.g. Products) keep getting a
            // sensible default value. Pick the lowest-rate Taxable row.
            if (wasDefault)
            {
                var others = await db.TaxRates
                    .Where(t => t.IsActive && t.Id != existing.Id).ToListAsync();
                var promote = others
                    .OrderBy(t => t.TaxCategory == "Taxable" ? 0 : 1)
                    .ThenBy(t => t.Rate)
                    .FirstOrDefault();
                if (promote is not null) promote.IsDefault = true;
            }

            await db.SaveChangesAsync();
            await LoadAsync();
            StartNew();
            Snackbar.ShowOk(wasDefault
                ? "Tax rate removed and default re-assigned."
                : "Tax rate removed.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete tax rate");
            Snackbar.ShowError($"Could not delete: {ex.Message}");
        }
    }

    private async Task<bool> Confirm(string title, string body, string yes)
    {
        var result = await DialogService.ShowMessageBoxAsync(title, body, yesText: yes, cancelText: "Cancel");
        return result == true;
    }

    private void GoNext() => Nav.NavigateTo(Onboarding.RouteFor(OnboardingStep.Products));

    // VM with nullable wrappers for non-nullable decimals so MudNumericField
    // can represent "cleared" without silently saving 0.
    private sealed class TaxVm
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public decimal Rate { get; set; }
        public decimal? RateNullable
        {
            get => _rateBlank ? null : Rate;
            set { Rate = value ?? 0; _rateBlank = value is null; }
        }
        private bool _rateBlank = true;

        public decimal CessRate { get; set; }
        public decimal? CessRateNullable
        {
            get => _cessBlank ? null : CessRate;
            set { CessRate = value ?? 0; _cessBlank = value is null; }
        }
        private bool _cessBlank = true;

        public string? CessType { get; set; }
        public bool IsTaxInclusive { get; set; }
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
        public string? HsnCode { get; set; }
        public string TaxCategory { get; set; } = "Taxable";
        public bool IsDefault { get; set; }
        public int SortOrder { get; set; }
        public bool IsActive { get; set; } = true;
        public DateTime CreatedAt { get; set; } = DateTime.UtcNow;

        public decimal CgstRate => Rate / 2;
        public decimal SgstRate => Rate / 2;

        public static TaxVm From(TaxRate t) => new()
        {
            Id = t.Id,
            Name = t.Name,
            Rate = t.Rate,
            _rateBlank = false,
            CessRate = t.CessRate,
            _cessBlank = t.CessRate == 0,
            CessType = t.CessType,
            IsTaxInclusive = t.IsTaxInclusive,
            MinPrice = t.MinPrice,
            MaxPrice = t.MaxPrice,
            HsnCode = t.HsnCode,
            TaxCategory = string.IsNullOrWhiteSpace(t.TaxCategory) ? "Taxable" : t.TaxCategory,
            IsDefault = t.IsDefault,
            SortOrder = t.SortOrder,
            IsActive = t.IsActive,
            CreatedAt = t.CreatedAt,
        };

        public TaxRate ToEntity() => new()
        {
            Id = Id,
            Name = Name,
            Rate = Rate,
            CessRate = CessRate,
            CessType = CessType,
            IsTaxInclusive = IsTaxInclusive,
            MinPrice = MinPrice,
            MaxPrice = MaxPrice,
            HsnCode = HsnCode,
            TaxCategory = TaxCategory,
            IsDefault = IsDefault,
            SortOrder = SortOrder,
            IsActive = IsActive,
            CreatedAt = CreatedAt,
        };

        public void ApplyTo(TaxRate t)
        {
            t.Name = Name;
            t.Rate = Rate;
            t.CessRate = CessRate;
            t.CessType = CessType;
            t.IsTaxInclusive = IsTaxInclusive;
            t.MinPrice = MinPrice;
            t.MaxPrice = MaxPrice;
            t.HsnCode = HsnCode;
            t.TaxCategory = TaxCategory;
            t.IsDefault = IsDefault;
            t.SortOrder = SortOrder;
            t.IsActive = IsActive;
        }
    }
}
