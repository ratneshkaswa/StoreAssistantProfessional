@page "/onboarding/vendor"
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Logging
@using StoreAssistantProfessional.Components.Shared
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISetupService Setup
@inject IOnboardingService Onboarding
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<VendorsPage> Logger

<PageTitle>Vendors — Setup</PageTitle>

<OnboardingShell Current="OnboardingStep.Vendor"
                 HeroIcon="@Icons.Material.Rounded.Handshake"
                 DecoIcon="@Icons.Material.Rounded.Handshake"
                 HeroHeading="Add your suppliers"
                 NextHint="Last step — almost done!"
                 BlockingReason="@BlockingReason"
                 ReadyMessage="Ready to finish — click Finish ✓."
                 HideHero="true">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4 sap-step-card" Style="min-height: 520px;">
                    <MudStack Spacing="3">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">Vendors (@_vendors.Count)</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Rounded.Add" OnClick="StartNew">Add</MudButton>
                        </MudStack>

                        <MudTextField Value="_search"
                                      ValueChanged="OnSearchChanged"
                                      T="string"
                                      Placeholder="Search by name, phone, GSTIN, city, email…"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Rounded.Search"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      DebounceInterval="200" />

                        <MudDivider />

                        @if (_loading)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                            </MudStack>
                        }
                        else if (_loadError is not null)
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                                Could not load vendors. @_loadError
                                <MudButton Class="ml-2" Size="Size.Small" Variant="Variant.Text" OnClick="ReloadAsync">Retry</MudButton>
                            </MudAlert>
                        }
                        else if (_filtered.Count == 0)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                                <MudIcon Icon="@Icons.Material.Rounded.Handshake" Color="Color.Secondary" Style="font-size: 48px;" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                    @(_vendors.Count == 0 ? "No vendors yet. Use the form on the right to add one." : "No matches.")
                                </MudText>
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Spacing="1">
                                @foreach (var v in _filtered)
                                {
                                    var isSel = _editing?.Id == v.Id;
                                    var item = v;
                                    <div class="@(isSel ? "sap-list-row sap-list-row-active" : "sap-list-row")"
                                         tabindex="0"
                                         role="button"
                                         aria-pressed="@(isSel ? "true" : "false")"
                                         @onclick="@(() => SelectExisting(item))"
                                         @onkeydown="@((KeyboardEventArgs e) => OnRowKey(e, item))">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@item.Name</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @(string.IsNullOrEmpty(item.Phone) ? "no phone" : item.Phone)
                                                @(string.IsNullOrEmpty(item.Gstin) ? "" : " · " + item.Gstin)
                                            </MudText>
                                        </MudStack>
                                    </div>
                                }
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudPaper Class="pa-4 sap-step-card" Style="min-height: 520px;">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.h6">@(_isNew ? "➕ Add vendor" : $"Edit · {_form.Name}")</MudText>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="8">
                                <MudTextField @bind-Value="_form.Name"
                                              Label="Vendor name *"
                                              Variant="Variant.Outlined"
                                              MaxLength="200"
                                              Immediate="true"
                                              AutoFocus="true"
                                              Error="@(_attempted && string.IsNullOrWhiteSpace(_form.Name))"
                                              ErrorText="Name is required."
                                              OnKeyDown="OnEnter" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Value="_form.Gstin"
                                              ValueChanged="OnGstinChanged"
                                              T="string"
                                              Label="GSTIN" Variant="Variant.Outlined" MaxLength="15" Immediate="true"
                                              Error="@(_attempted && (!IndianFormats.IsGstin(_form.Gstin) || !_form.IsPanGstinConsistent))"
                                              ErrorText="@GstinError" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Value="_form.Pan"
                                              ValueChanged="OnPanChanged"
                                              T="string"
                                              Label="PAN" Variant="Variant.Outlined" MaxLength="10" Immediate="true"
                                              Error="@(_attempted && (!IndianFormats.IsPan(_form.Pan) || !_form.IsPanGstinConsistent))"
                                              ErrorText="@PanError" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_form.Phone"
                                              Label="Phone" Variant="Variant.Outlined" MaxLength="20" Immediate="true"
                                              Error="@(_attempted && !IndianFormats.IsIndianPhone(_form.Phone))"
                                              ErrorText="10-digit mobile, optionally with +91." />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_form.AltPhone"
                                              Label="Alt phone" Variant="Variant.Outlined" MaxLength="20" Immediate="true"
                                              Error="@(_attempted && !IndianFormats.IsIndianPhone(_form.AltPhone))"
                                              ErrorText="10-digit mobile, optionally with +91." />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_form.Email"
                                              Label="Email" Variant="Variant.Outlined" MaxLength="200" Immediate="true"
                                              Error="@(_attempted && !IndianFormats.IsEmail(_form.Email))"
                                              ErrorText="Invalid email format." />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_form.Address" Label="Address" Variant="Variant.Outlined" MaxLength="300" />
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudTextField @bind-Value="_form.City" Label="City" Variant="Variant.Outlined" MaxLength="100" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="string" @bind-Value="_form.State"
                                           Label="State" Variant="Variant.Outlined" Clearable="true">
                                    <MudSelectItem Value="@((string?)null)">— Not set —</MudSelectItem>
                                    @foreach (var s in _stateOptions)
                                    {
                                        <MudSelectItem Value="@s.Name">@s.Code · @s.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="_form.Pincode"
                                              Label="Pincode" Variant="Variant.Outlined" MaxLength="6" Immediate="true"
                                              Error="@(_attempted && !IndianFormats.IsPincode(_form.Pincode))"
                                              ErrorText="6 digits, can't start with 0." />
                            </MudItem>

                            <MudItem xs="12"><MudText Typo="Typo.caption" Color="Color.Secondary">Bank</MudText></MudItem>
                            <MudItem xs="12" md="6"><MudTextField @bind-Value="_form.BankName" Label="Bank name" Variant="Variant.Outlined" MaxLength="200" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField @bind-Value="_form.AccountHolderName" Label="Account holder" Variant="Variant.Outlined" MaxLength="100" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField @bind-Value="_form.AccountNumber" Label="Account no." Variant="Variant.Outlined" MaxLength="20" /></MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Value="_form.IfscCode"
                                              ValueChanged="OnIfscChanged"
                                              T="string"
                                              Label="IFSC" Variant="Variant.Outlined" MaxLength="11" Immediate="true"
                                              Error="@(_attempted && !IndianFormats.IsIfsc(_form.IfscCode))"
                                              ErrorText="11 chars: 4 letters + 0 + 6 alphanum." />
                            </MudItem>

                            <MudItem xs="12"><MudText Typo="Typo.caption" Color="Color.Secondary">Payment terms &amp; opening balance</MudText></MudItem>
                            <MudItem xs="6" md="4">
                                <MudNumericField T="int?" @bind-Value="_form.PaymentTermDays" Label="Days allowed" Variant="Variant.Outlined" Min="0" Max="365" HelperText="defaults to 30 if blank" />
                            </MudItem>
                            <MudItem xs="6" md="4">
                                <MudNumericField T="decimal?" @bind-Value="_form.CreditLimit" Label="Credit limit ₹" Variant="Variant.Outlined" Min="0" />
                            </MudItem>
                            <MudItem xs="6" md="4">
                                <MudNumericField T="decimal?" @bind-Value="_form.Balance" Label="Opening balance ₹" Variant="Variant.Outlined" HelperText="positive = we owe them" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_form.Notes" Label="Notes" Variant="Variant.Outlined" MaxLength="500" Lines="2" />
                            </MudItem>
                        </MudGrid>

                        <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                            @if (!_isNew)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="DeleteCurrent" Disabled="@_saving">Delete</MudButton>
                            }
                            <MudButton Variant="Variant.Text" OnClick="ResetWithConfirm" Disabled="@_saving">Cancel</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">
                                @if (_saving)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Saving…</span>
                                }
                                else
                                {
                                    <span>Save vendor</span>
                                }
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
        <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo(Onboarding.RouteFor(OnboardingStep.Products)))">‹ Back</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   OnClick="Finish"
                   Disabled="@(_vendors.Count == 0)">Finish ✓</MudButton>
    </MudStack>
</OnboardingShell>

@code {
    private List<Vendor> _vendors = new();
    private List<Vendor> _filtered = new();
    private VendorVm _form = new();
    private VendorVm? _formOriginal;     // X3 / V3: Cancel-revert snapshot
    private Vendor? _editing;
    private bool _isNew = true;
    private bool _attempted;
    private bool _saving;
    private bool _loading = true;
    private string? _loadError;
    private string _search = "";

    // Same state list used by FirmDetailsPage. Kept here for V21 (state dropdown
    // instead of free-text). Built from IndianFormats.StateNameFromCode.
    private static readonly (string Code, string Name)[] _stateOptions = BuildStateOptions();

    private static (string Code, string Name)[] BuildStateOptions()
    {
        var list = new List<(string Code, string Name)>();
        for (var i = 1; i <= 38; i++)
        {
            var code = i.ToString("D2");
            var name = IndianFormats.StateNameFromCode(code);
            if (name is not null) list.Add((code, name));
        }
        return list.ToArray();
    }

    private string GstinError
    {
        get
        {
            if (!IndianFormats.IsGstin(_form.Gstin)) return "Invalid GSTIN format.";
            if (!_form.IsPanGstinConsistent) return "GSTIN positions 3–12 must equal PAN.";
            return "";
        }
    }

    private string PanError
    {
        get
        {
            if (!IndianFormats.IsPan(_form.Pan)) return "Invalid PAN format.";
            if (!_form.IsPanGstinConsistent) return "PAN must equal GSTIN positions 3–12.";
            return "";
        }
    }

    private void OnGstinChanged(string? v)
    {
        _form.Gstin = string.IsNullOrEmpty(v) ? v : v.ToUpperInvariant();
        // V28 + F1: auto-fill PAN from GSTIN (positions 3-12) when PAN is blank.
        var derived = IndianFormats.PanFromGstin(_form.Gstin);
        if (derived is not null && string.IsNullOrWhiteSpace(_form.Pan))
            _form.Pan = derived;
    }

    private void OnPanChanged(string? v) =>
        _form.Pan = string.IsNullOrEmpty(v) ? v : v.ToUpperInvariant();

    private void OnIfscChanged(string? v) =>
        _form.IfscCode = string.IsNullOrEmpty(v) ? v : v.ToUpperInvariant();

    private string? BlockingReason
    {
        get
        {
            if (_loading) return null;
            if (_vendors.Count == 0) return "Add at least one vendor to continue.";
            return null;
        }
    }

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_form.Name) &&
        _form.Name.Length <= 200 &&
        IndianFormats.IsGstin(_form.Gstin) &&
        IndianFormats.IsPan(_form.Pan) &&
        _form.IsPanGstinConsistent &&        // V28
        IndianFormats.IsIndianPhone(_form.Phone) &&
        IndianFormats.IsIndianPhone(_form.AltPhone) &&
        IndianFormats.IsEmail(_form.Email) &&
        IndianFormats.IsPincode(_form.Pincode) &&
        IndianFormats.IsIfsc(_form.IfscCode);

    protected override async Task OnInitializedAsync()
    {
        if (!Setup.IsComplete) { Nav.NavigateTo("/setup", replace: true); return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _vendors = await db.Vendors.AsNoTracking().Where(v => v.IsActive).OrderBy(v => v.Name).ToListAsync();
            ApplyFilter();
        }
        catch (Exception ex)
        {
            // V3 / V7: don't crash the WebView on a DB load error.
            Logger.LogError(ex, "Failed to load vendors");
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Task ReloadAsync() => LoadAsync();

    private void OnSearchChanged(string s)
    {
        _search = s ?? "";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            _filtered = _vendors;
            return;
        }
        var qRaw = _search.Trim();
        var qPhone = IndianFormats.StripPhone(qRaw);
        _filtered = _vendors.Where(v =>
            Match(v.Name, qRaw) ||
            Match(v.Gstin, qRaw) ||
            Match(v.City, qRaw) ||
            Match(v.Email, qRaw) ||
            (qPhone.Length > 0 && (
                IndianFormats.StripPhone(v.Phone ?? "").Contains(qPhone, StringComparison.Ordinal) ||
                IndianFormats.StripPhone(v.AltPhone ?? "").Contains(qPhone, StringComparison.Ordinal)
            ))
        ).ToList();
    }

    private static bool Match(string? field, string q) =>
        !string.IsNullOrEmpty(field) && field.Contains(q, StringComparison.OrdinalIgnoreCase);

    private void StartNew()
    {
        _form = new VendorVm { PaymentTermDays = 30, IsActive = true };
        _formOriginal = null;
        _editing = null;
        _isNew = true;
        _attempted = false;
    }

    private void SelectExisting(Vendor v)
    {
        _editing = v;
        _form = VendorVm.From(v);
        _formOriginal = VendorVm.From(v);   // X3 / V3: snapshot for Cancel-revert
        _isNew = false;
        _attempted = false;
    }

    private void OnRowKey(KeyboardEventArgs e, Vendor v)
    {
        if (e.Key is "Enter" or " ") SelectExisting(v);
    }

    private async Task ResetWithConfirm()
    {
        // X3 / V3: Cancel reverts an in-progress edit on an existing vendor
        // back to the loaded values. Only fall through to a fresh form when
        // we're entering a new vendor (no original to revert to).
        if (_formOriginal is not null && !_isNew)
        {
            _form = _formOriginal;
            _formOriginal = VendorVm.From(_editing!);   // re-snapshot
            _attempted = false;
            return;
        }

        // Only confirm if there's actual content the user might lose.
        if (HasUnsavedContent())
        {
            var ok = await Confirm("Discard changes?",
                "The current form will be cleared.", "Discard");
            if (!ok) return;
        }
        StartNew();
    }

    private bool HasUnsavedContent() =>
        !string.IsNullOrWhiteSpace(_form.Name) ||
        !string.IsNullOrWhiteSpace(_form.Phone) ||
        !string.IsNullOrWhiteSpace(_form.Gstin) ||
        !string.IsNullOrWhiteSpace(_form.Email);

    private async Task OnEnter(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (!_saving && IsValid) await Save();
    }

    private async Task Save()
    {
        _attempted = true;
        if (!IsValid)
        {
            Snackbar.ShowWarning(FirstInvalidReason());
            return;
        }

        // V1 / V11: canonicalize phone numbers via StripPhone so two visits with
        // the same number entered as "+91 98xxx-xxxxx" and "98xxxxxxxxx" round-
        // trip to the same stored 10-digit form. V2: trim every text field.
        _form.Name = _form.Name.Trim();
        _form.Gstin = NormalizeUpper(_form.Gstin);
        _form.Pan = NormalizeUpper(_form.Pan);
        _form.IfscCode = NormalizeUpper(_form.IfscCode);
        _form.Phone = NormalizePhone(_form.Phone);
        _form.AltPhone = NormalizePhone(_form.AltPhone);
        _form.Email = NormalizeLower(_form.Email);
        _form.Address = TrimToNull(_form.Address);
        _form.City = TrimToNull(_form.City);
        _form.State = TrimToNull(_form.State);
        _form.Pincode = TrimToNull(_form.Pincode);
        _form.BankName = TrimToNull(_form.BankName);
        _form.AccountHolderName = TrimToNull(_form.AccountHolderName);
        _form.AccountNumber = TrimToNull(_form.AccountNumber);
        _form.Notes = TrimToNull(_form.Notes);

        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // Soft duplicate detection on phone or GSTIN — warn but don't block.
            var phoneDigits = string.IsNullOrWhiteSpace(_form.Phone) ? null : IndianFormats.StripPhone(_form.Phone);
            if (phoneDigits is not null && phoneDigits.Length > 0)
            {
                var dup = _vendors.FirstOrDefault(v =>
                    v.Id != _form.Id &&
                    IndianFormats.StripPhone(v.Phone ?? "") == phoneDigits);
                if (dup is not null)
                {
                    var ok = await Confirm("Vendor with this phone exists",
                        $"\"{dup.Name}\" already has phone {dup.Phone}. Save anyway?", "Save anyway");
                    if (!ok) return;
                }
            }
            if (!string.IsNullOrWhiteSpace(_form.Gstin))
            {
                var dup = _vendors.FirstOrDefault(v =>
                    v.Id != _form.Id &&
                    string.Equals(v.Gstin, _form.Gstin, StringComparison.OrdinalIgnoreCase));
                if (dup is not null)
                {
                    var ok = await Confirm("Vendor with this GSTIN exists",
                        $"\"{dup.Name}\" already has GSTIN {dup.Gstin}. Save anyway?", "Save anyway");
                    if (!ok) return;
                }
            }

            int newId = _form.Id;
            if (_isNew || _form.Id == 0)
            {
                var entity = _form.ToEntity();
                entity.CreatedAt = DateTime.UtcNow;
                entity.UpdatedAt = DateTime.UtcNow;
                db.Vendors.Add(entity);
                await db.SaveChangesAsync();
                newId = entity.Id;
            }
            else
            {
                var existing = await db.Vendors.FirstOrDefaultAsync(v => v.Id == _form.Id);
                if (existing is null)
                {
                    Snackbar.Add("Record was deleted elsewhere.", Severity.Warning);
                    await LoadAsync();
                    StartNew();
                    return;
                }
                _form.ApplyTo(existing);
                existing.UpdatedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
            }

            await LoadAsync();
            var saved = _vendors.FirstOrDefault(v => v.Id == newId);
            if (saved is not null) SelectExisting(saved);
            else StartNew();
            _attempted = false;     // X2: clear sticky errors after a clean save
            Snackbar.ShowOk("Vendor saved.");
        }
        catch (DbUpdateException ex)
        {
            Logger.LogError(ex, "Failed to save vendor (DB)");
            Snackbar.ShowError($"Could not save: {ex.InnerException?.Message ?? ex.Message}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save vendor");
            Snackbar.ShowError($"Could not save: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    // Walk validators in priority order — same shape as Tax/Products.
    private string FirstInvalidReason()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) return "Vendor name is required.";
        if (_form.Name.Length > 200) return "Vendor name is too long (200 chars max).";
        if (!IndianFormats.IsGstin(_form.Gstin)) return "GSTIN format is invalid.";
        if (!IndianFormats.IsPan(_form.Pan)) return "PAN format is invalid.";
        if (!_form.IsPanGstinConsistent) return "PAN must equal GSTIN positions 3–12.";
        if (!IndianFormats.IsIndianPhone(_form.Phone)) return "Phone format is invalid.";
        if (!IndianFormats.IsIndianPhone(_form.AltPhone)) return "Alt phone format is invalid.";
        if (!IndianFormats.IsEmail(_form.Email)) return "Email format is invalid.";
        if (!IndianFormats.IsPincode(_form.Pincode)) return "Pincode is invalid.";
        if (!IndianFormats.IsIfsc(_form.IfscCode)) return "IFSC format is invalid.";
        return "Form has errors — fix the highlighted fields.";
    }

    private async Task DeleteCurrent()
    {
        if (_editing is null) return;

        await using var db = await DbFactory.CreateDbContextAsync();

        // V27: check open inward parcels and purchase returns before soft-
        // deleting. We don't block, because the vendor *was* legitimately a
        // supplier on those rows, but we ask the user to confirm so the
        // implication is explicit. (VendorId lives on InwardParcel, not
        // InwardEntry — the parcel is the unit a single vendor ships.)
        var parcelCount = await db.InwardParcels.AsNoTracking()
            .CountAsync(p => p.VendorId == _editing.Id);
        var returnCount = await db.PurchaseReturns.AsNoTracking()
            .CountAsync(r => r.VendorId == _editing.Id);
        var historyTotal = parcelCount + returnCount;
        var bodyExtra = historyTotal > 0
            ? $" {historyTotal} historical record{(historyTotal == 1 ? "" : "s")} reference this vendor — reports will still show the deleted name."
            : "";

        var ok = await Confirm($"Delete vendor \"{_editing.Name}\"?",
            $"It will be soft-deleted and won't appear in lists.{bodyExtra}", "Delete");
        if (!ok) return;

        try
        {
            var existing = await db.Vendors.FirstOrDefaultAsync(v => v.Id == _editing.Id);
            if (existing is not null)
            {
                existing.IsActive = false;
                existing.UpdatedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
            }
            await LoadAsync();
            StartNew();
            Snackbar.ShowOk("Vendor removed.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete vendor");
            Snackbar.ShowError($"Could not delete: {ex.Message}");
        }
    }

    private async Task<bool> Confirm(string title, string body, string yes)
    {
        var result = await DialogService.ShowMessageBoxAsync(title, body, yesText: yes, cancelText: "Cancel");
        return result == true;
    }

    private static string? NormalizeUpper(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim().ToUpperInvariant();

    private static string? NormalizeLower(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim().ToLowerInvariant();

    private static string? NormalizePhone(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : (IndianFormats.StripPhone(s) is var d && d.Length > 0 ? d : s.Trim());

    private static string? TrimToNull(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    // X12 / R2: route through the celebration page first instead of dumping
    // the user straight onto Billing.
    private void Finish() => Nav.NavigateTo("/onboarding/done");

    private sealed class VendorVm
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Phone { get; set; }
        public string? AltPhone { get; set; }
        public string? Email { get; set; }
        public string? Gstin { get; set; }
        public string? Pan { get; set; }   // V28: PAN field (Vendor entity has no Pan column today,
                                            // so this is form-side only — used purely for the GSTIN
                                            // consistency check. Could promote to a real column later.)
        public string? Address { get; set; }
        public string? City { get; set; }
        public string? State { get; set; }
        public string? Pincode { get; set; }
        public string? BankName { get; set; }
        public string? AccountHolderName { get; set; }
        public string? AccountNumber { get; set; }
        public string? IfscCode { get; set; }
        public decimal? Balance { get; set; }
        public int? PaymentTermDays { get; set; }
        public decimal? CreditLimit { get; set; }
        public string? Notes { get; set; }
        public bool IsActive { get; set; } = true;
        public DateTime CreatedAt { get; set; } = DateTime.UtcNow;

        // V28: same shape as FirmVm.IsPanGstinConsistent. PAN is embedded in
        // GSTIN[2..12]; mismatch indicates a typo. Defers to shape errors.
        public bool IsPanGstinConsistent
        {
            get
            {
                if (string.IsNullOrWhiteSpace(Gstin) || string.IsNullOrWhiteSpace(Pan)) return true;
                var g = Gstin.Trim().ToUpperInvariant();
                var p = Pan.Trim().ToUpperInvariant();
                if (g.Length != 15 || p.Length != 10) return true;
                return g.Substring(2, 10) == p;
            }
        }

        public static VendorVm From(Vendor v) => new()
        {
            Id = v.Id,
            Name = v.Name,
            Phone = v.Phone,
            AltPhone = v.AltPhone,
            Email = v.Email,
            Gstin = v.Gstin,
            Address = v.Address,
            City = v.City,
            State = v.State,
            Pincode = v.Pincode,
            BankName = v.BankName,
            AccountHolderName = v.AccountHolderName,
            AccountNumber = v.AccountNumber,
            IfscCode = v.IfscCode,
            Balance = v.Balance,
            PaymentTermDays = v.PaymentTermDays,
            CreditLimit = v.CreditLimit,
            Notes = v.Notes,
            IsActive = v.IsActive,
            CreatedAt = v.CreatedAt,
        };

        public Vendor ToEntity() => new()
        {
            Id = Id,
            Name = Name,
            Phone = Phone,
            AltPhone = AltPhone,
            Email = Email,
            Gstin = Gstin,
            Address = Address,
            City = City,
            State = State,
            Pincode = Pincode,
            BankName = BankName,
            AccountHolderName = AccountHolderName,
            AccountNumber = AccountNumber,
            IfscCode = IfscCode,
            Balance = Balance ?? 0,
            PaymentTermDays = PaymentTermDays ?? 30,
            CreditLimit = CreditLimit ?? 0,
            Notes = Notes,
            IsActive = IsActive,
            CreatedAt = CreatedAt,
        };

        public void ApplyTo(Vendor v)
        {
            v.Name = Name;
            v.Phone = Phone;
            v.AltPhone = AltPhone;
            v.Email = Email;
            v.Gstin = Gstin;
            v.Address = Address;
            v.City = City;
            v.State = State;
            v.Pincode = Pincode;
            v.BankName = BankName;
            v.AccountHolderName = AccountHolderName;
            v.AccountNumber = AccountNumber;
            v.IfscCode = IfscCode;
            // V8 / V9 / V10: when editing, preserve the previously-stored numeric
            // value if the user cleared the field. ToEntity (new-row path) still
            // falls back to defaults — the field-cleared semantic only matters
            // here, where there's an existing value worth keeping.
            if (Balance.HasValue) v.Balance = Balance.Value;
            if (PaymentTermDays.HasValue) v.PaymentTermDays = PaymentTermDays.Value;
            if (CreditLimit.HasValue) v.CreditLimit = CreditLimit.Value;
            v.Notes = Notes;
            v.IsActive = IsActive;
        }
    }
}
