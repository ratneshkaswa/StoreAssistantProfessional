@page "/onboarding/products"
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Logging
@using StoreAssistantProfessional.Components.Shared
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISetupService Setup
@inject IOnboardingService Onboarding
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<ProductsPage> Logger

<PageTitle>Products — Setup</PageTitle>

<OnboardingShell Current="OnboardingStep.Products" Bare="true">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 sap-step-card" Style="min-height: 540px;">
                    <MudStack Spacing="3">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">Products (@_products.Count)</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Rounded.Add" OnClick="StartNew">Add</MudButton>
                        </MudStack>

                        <MudTextField Value="_search"
                                      ValueChanged="OnSearchChanged"
                                      T="string"
                                      Placeholder="Search by name, SKU, barcode, HSN, category, notes…"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Rounded.Search"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      DebounceInterval="200" />

                        <MudButton Size="Size.Small"
                                   Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Rounded.AutoAwesome"
                                   OnClick="AddSample"
                                   Disabled="@(_saving || _taxes.Count == 0)">
                            Add a sample product
                        </MudButton>

                        <MudDivider />

                        @if (_loading)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                            </MudStack>
                        }
                        else if (_loadError is not null)
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                                Could not load products. @_loadError
                                <MudButton Class="ml-2" Size="Size.Small" Variant="Variant.Text" OnClick="ReloadAsync">Retry</MudButton>
                            </MudAlert>
                        }
                        else if (_filtered.Count == 0)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                                <MudIcon Icon="@Icons.Material.Rounded.Inventory2" Color="Color.Secondary" Style="font-size: 48px;" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                    @(_products.Count == 0 ? "No products yet. Use the form on the right to add one." : "No matches.")
                                </MudText>
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Spacing="1">
                                @foreach (var p in _filtered)
                                {
                                    var isSel = _editing?.Id == p.Id;
                                    var item = p;
                                    <div class="@(isSel ? "sap-list-row sap-list-row-active" : "sap-list-row")"
                                         tabindex="0"
                                         role="button"
                                         aria-pressed="@(isSel ? "true" : "false")"
                                         @onclick="@(() => SelectExisting(item))"
                                         @onkeydown="@((KeyboardEventArgs e) => OnRowKey(e, item))">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@item.Name</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @(string.IsNullOrEmpty(item.Sku) ? "no SKU" : item.Sku)
                                                · ₹@item.SalePrice.ToString("0.##")
                                                · stock @item.StockQty.ToString("0.###")
                                            </MudText>
                                        </MudStack>
                                    </div>
                                }
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 sap-step-card" Style="min-height: 540px;">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.h6">@(_isNew ? "➕ Add product" : $"Edit · {_form.Name}")</MudText>

                        @if (_taxes.Count == 0)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true">
                                Add at least one tax rate first — go back to step 2.
                            </MudAlert>
                        }

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="8">
                                <MudTextField @bind-Value="_form.Name"
                                              Label="Product name *"
                                              Variant="Variant.Outlined"
                                              MaxLength="200"
                                              Immediate="true"
                                              AutoFocus="true"
                                              Error="@(_attempted && string.IsNullOrWhiteSpace(_form.Name))"
                                              ErrorText="Name is required."
                                              OnKeyDown="OnEnter" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="_form.Category"
                                              Label="Category" Variant="Variant.Outlined" MaxLength="100"
                                              HelperText="e.g. Shirts, Sarees, Kurtas" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="_form.Sku"
                                              Label="SKU" Variant="Variant.Outlined" MaxLength="50"
                                              HelperText="auto-generated if blank" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="_form.Barcode" Label="Barcode" Variant="Variant.Outlined" MaxLength="100" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="_form.HsnCode"
                                              Label="HSN" Variant="Variant.Outlined" MaxLength="8" Immediate="true"
                                              Error="@(_attempted && !IndianFormats.IsHsn(_form.HsnCode))"
                                              ErrorText="2–8 digits." />
                            </MudItem>

                            <MudItem xs="12">
                                <MudSelect T="int?" @bind-Value="_form.TaxRateId"
                                           Label="Tax rate *" Variant="Variant.Outlined"
                                           Error="@(_attempted && _form.TaxRateId is null)"
                                           ErrorText="Pick a tax rate.">
                                    @foreach (var t in _taxesForDropdown)
                                    {
                                        var taxId = t.Id;
                                        var suffix = !t.IsActive ? " · (deleted)"
                                                    : t.IsDefault ? " · default" : "";
                                        var label = $"{t.Name} ({t.Rate:0.##}%){suffix}";
                                        <MudSelectItem T="int?" Value="@((int?)taxId)">@label</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12"><MudText Typo="Typo.caption" Color="Color.Secondary">Pricing</MudText></MudItem>
                            <MudItem xs="6" md="3">
                                <MudNumericField T="decimal?" @bind-Value="_form.Mrp"
                                                 Label="MRP ₹ *" Variant="Variant.Outlined" Min="0"
                                                 Error="@(_attempted && (_form.Mrp is null || _form.Mrp <= 0))"
                                                 ErrorText="MRP must be > 0." />
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudNumericField T="decimal?" @bind-Value="_form.SalePrice"
                                                 Label="Sale ₹ *" Variant="Variant.Outlined" Min="0"
                                                 Error="@(_attempted && !SalePriceValid)"
                                                 ErrorText="@SalePriceError" />
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudNumericField T="decimal?" @bind-Value="_form.Cost" Label="Cost ₹" Variant="Variant.Outlined" Min="0" />
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudNumericField T="decimal?" @bind-Value="_form.StockQty" Label="Opening stock" Variant="Variant.Outlined" Min="0" />
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudNumericField T="decimal?" @bind-Value="_form.ReorderLevel" Label="Reorder level" Variant="Variant.Outlined" Min="0" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_form.Notes" Label="Notes" Variant="Variant.Outlined" MaxLength="500" Lines="2" />
                            </MudItem>
                        </MudGrid>

                        <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                            @if (!_isNew)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="DeleteCurrent" Disabled="@_saving">Delete</MudButton>
                            }
                            <MudButton Variant="Variant.Text" OnClick="ResetWithConfirm" Disabled="@_saving">Cancel</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@(_saving || _taxes.Count == 0)">
                                @if (_saving)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Saving…</span>
                                }
                                else
                                {
                                    <span>Save product</span>
                                }
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
        <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo(Onboarding.RouteFor(OnboardingStep.Tax)))">‹ Back</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   OnClick="GoNext"
                   Disabled="@(_products.Count == 0)">Next ›</MudButton>
    </MudStack>
</OnboardingShell>

@code {
    private List<Product> _products = new();
    private List<Product> _filtered = new();
    private List<TaxRate> _taxes = new();
    // Same as _taxes but with the (possibly soft-deleted) tax that the
    // currently-edited product references, marked inactive. Lets MudSelect
    // render the existing selection instead of a silent blank.
    private List<TaxRate> _taxesForDropdown = new();
    private ProductVm _form = new();
    private ProductVm? _formOriginal;   // Cancel-revert snapshot (X3 / P7)
    private Product? _editing;
    private bool _isNew = true;
    private bool _attempted;
    private bool _saving;
    private bool _loading = true;
    private string? _loadError;
    private string _search = "";

    private string? BlockingReason
    {
        get
        {
            if (_loading) return null;
            if (_taxes.Count == 0) return "Add a tax rate first (step 2).";
            if (_products.Count == 0) return "Add at least one product to continue.";
            return null;
        }
    }

    private bool SalePriceValid =>
        _form.SalePrice is > 0 &&
        (_form.Mrp is null || _form.SalePrice <= _form.Mrp);

    private string SalePriceError =>
        _form.SalePrice is null or <= 0
            ? "Sale price must be > 0."
            : "Sale price cannot exceed MRP.";

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_form.Name) &&
        _form.Name.Length <= 200 &&
        _form.TaxRateId is not null &&
        _form.Mrp is > 0 &&
        SalePriceValid &&
        // P19: server-side negative-paste guard (UI Min=0 is JS-only).
        (_form.Cost is null or >= 0m) &&
        (_form.StockQty is null or >= 0m) &&
        (_form.ReorderLevel is null or >= 0m) &&
        IndianFormats.IsHsn(_form.HsnCode);

    protected override async Task OnInitializedAsync()
    {
        if (!Setup.IsComplete) { Nav.NavigateTo("/setup", replace: true); return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _products = await db.Products.AsNoTracking().Where(p => p.IsActive).OrderBy(p => p.Name).ToListAsync();
            // SQLite can't ORDER BY decimal — pull rows ordered on the bool
            // (IsDefault) and sort the decimal Rate client-side.
            var taxRows = await db.TaxRates.AsNoTracking().Where(t => t.IsActive).ToListAsync();
            _taxes = taxRows.OrderByDescending(t => t.IsDefault).ThenBy(t => t.Rate).ToList();
            _taxesForDropdown = _taxes.ToList();
            ApplyFilter();

            // Default the form's tax rate to the configured default if available.
            if (_form.TaxRateId is null)
                _form.TaxRateId = _taxes.FirstOrDefault(t => t.IsDefault)?.Id ?? _taxes.FirstOrDefault()?.Id;
        }
        catch (Exception ex)
        {
            // P9: don't crash the WebView on a DB load error.
            Logger.LogError(ex, "Failed to load products");
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Task ReloadAsync() => LoadAsync();

    // P2 / P20: when the user opens a product whose TaxRateId points to a
    // soft-deleted tax, that tax isn't in `_taxes` (which is filtered to
    // IsActive=true). Without it in the dropdown's option list, MudSelect
    // can't render the selected label, so the field looks blank.
    // Inject the orphan as an inactive entry with a "(deleted)" suffix.
    private async Task EnsureSelectedTaxVisibleAsync(int? taxId)
    {
        if (taxId is null) return;
        if (_taxes.Any(t => t.Id == taxId)) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var orphan = await db.TaxRates.AsNoTracking()
            .FirstOrDefaultAsync(t => t.Id == taxId);
        if (orphan is null) return;

        _taxesForDropdown = _taxes.Concat(new[] { orphan }).ToList();
    }

    private void OnSearchChanged(string s)
    {
        _search = s ?? "";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            _filtered = _products;
            return;
        }
        var q = _search.Trim();
        _filtered = _products.Where(p =>
            Match(p.Name, q) ||
            Match(p.Sku, q) ||
            Match(p.Barcode, q) ||
            Match(p.Category, q) ||
            Match(p.HsnCode, q) ||
            Match(p.Notes, q)
        ).ToList();
    }

    private static bool Match(string? field, string q) =>
        !string.IsNullOrEmpty(field) && field.Contains(q, StringComparison.OrdinalIgnoreCase);

    private void StartNew()
    {
        _form = new ProductVm
        {
            IsActive = true,
            TaxRateId = _taxes.FirstOrDefault(t => t.IsDefault)?.Id ?? _taxes.FirstOrDefault()?.Id,
        };
        _formOriginal = null;
        _editing = null;
        _isNew = true;
        _attempted = false;
    }

    private async Task SelectExisting(Product p)
    {
        _editing = p;
        _form = ProductVm.From(p);
        _formOriginal = ProductVm.From(p);   // X3 / P7: snapshot for Cancel-revert
        _isNew = false;
        _attempted = false;
        await EnsureSelectedTaxVisibleAsync(_form.TaxRateId);
    }

    private async Task OnRowKey(KeyboardEventArgs e, Product p)
    {
        if (e.Key is "Enter" or " ") await SelectExisting(p);
    }

    private async Task ResetWithConfirm()
    {
        // X3 / P7: when editing an existing row, Cancel reverts to the loaded
        // values instead of wiping the form. For new rows, Cancel still clears.
        if (_formOriginal is not null && !_isNew)
        {
            _form = _formOriginal;
            _formOriginal = ProductVm.From(_editing!);   // re-snapshot for next Cancel
            _attempted = false;
            return;
        }

        if (HasUnsavedContent())
        {
            var ok = await Confirm("Discard changes?",
                "The current form will be cleared.", "Discard");
            if (!ok) return;
        }
        StartNew();
    }

    private bool HasUnsavedContent() =>
        !string.IsNullOrWhiteSpace(_form.Name) ||
        !string.IsNullOrWhiteSpace(_form.Sku) ||
        _form.Mrp is not null ||
        _form.SalePrice is not null;

    private async Task OnEnter(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (!_saving && IsValid) await Save();
    }

    private async Task AddSample()
    {
        if (_taxes.Count == 0) return;
        var defaultTaxId = _taxes.FirstOrDefault(t => t.IsDefault)?.Id ?? _taxes[0].Id;
        var suffix = Guid.NewGuid().ToString("N")[..6].ToUpperInvariant();

        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // P14: avoid name-collisions when sample is clicked rapidly. Compute
            // a name based on the GUID suffix instead of `_products.Count + 1`,
            // which used a stale local count and could collide on race.
            var name = $"Sample product {suffix}";
            var p = new Product
            {
                Name = name,
                Sku = $"SAMPLE-{suffix}",
                Mrp = 100m,
                SalePrice = 100m,
                Cost = 60m,
                StockQty = 10,
                TaxRateId = defaultTaxId,
                IsActive = true,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow,
            };
            db.Products.Add(p);
            await db.SaveChangesAsync();
            await LoadAsync();

            // P22: a sample insert shouldn't leave whatever the user was editing
            // half-typed in the form — clear it so they aren't confused.
            StartNew();
            Snackbar.ShowOk($"Added {p.Name}.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to add sample product");
            Snackbar.ShowError($"Could not add: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Save()
    {
        _attempted = true;
        if (!IsValid)
        {
            Snackbar.ShowWarning(FirstInvalidReason());
            return;
        }

        _form.Name = _form.Name.Trim();

        // P1 / P12: SKU rules differ between new and edit.
        //   - New row + blank: auto-generate.
        //   - Edit + blank: preserve the previously-saved SKU (don't silently
        //     replace with a new auto-generated one — barcodes already printed
        //     would no longer scan).
        //   - Otherwise: trim, uppercase, and reject anything outside [A-Z0-9-_].
        if (string.IsNullOrWhiteSpace(_form.Sku))
        {
            if (_isNew || _formOriginal is null)
            {
                _form.Sku = $"SKU-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}";
            }
            else
            {
                _form.Sku = _formOriginal.Sku;   // P1: preserve on edit
            }
        }
        else
        {
            var sku = _form.Sku.Trim().ToUpperInvariant();
            // P6 / P17: clamp SKU to [A-Z0-9-_]. Anything else (spaces, slashes,
            // punctuation) breaks barcode/label pipelines downstream.
            if (!System.Text.RegularExpressions.Regex.IsMatch(sku, @"^[A-Z0-9_-]+$"))
            {
                Snackbar.ShowError("SKU may only contain letters, digits, hyphen, and underscore.");
                return;
            }
            _form.Sku = sku;
        }

        _form.Barcode = string.IsNullOrWhiteSpace(_form.Barcode) ? null : _form.Barcode.Trim();
        _form.Category = string.IsNullOrWhiteSpace(_form.Category) ? null : _form.Category.Trim();
        _form.HsnCode = string.IsNullOrWhiteSpace(_form.HsnCode) ? null : _form.HsnCode.Trim();
        _form.Notes = string.IsNullOrWhiteSpace(_form.Notes) ? null : _form.Notes.Trim();

        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // P3: validate the chosen TaxRateId still exists and is active —
            // otherwise EF will surface an FK violation as a generic save error.
            if (_form.TaxRateId is int tid &&
                !await db.TaxRates.AnyAsync(t => t.Id == tid && t.IsActive))
            {
                Snackbar.ShowError("The selected tax rate has been deleted. Pick another.");
                return;
            }

            // Friendly pre-check on SKU uniqueness against active rows only
            // (the unique index is now filtered to IsActive=1).
            var skuTaken = await db.Products
                .Where(p => p.IsActive && p.Sku == _form.Sku && p.Id != _form.Id)
                .AnyAsync();
            if (skuTaken)
            {
                Snackbar.ShowError($"SKU '{_form.Sku}' is already in use.");
                return;
            }

            int newId = _form.Id;
            if (_isNew || _form.Id == 0)
            {
                var entity = _form.ToEntity();
                entity.CreatedAt = DateTime.UtcNow;
                entity.UpdatedAt = DateTime.UtcNow;
                db.Products.Add(entity);
                await db.SaveChangesAsync();
                newId = entity.Id;
            }
            else
            {
                var existing = await db.Products.FirstOrDefaultAsync(p => p.Id == _form.Id);
                if (existing is null)
                {
                    Snackbar.Add("Record was deleted elsewhere.", Severity.Warning);
                    await LoadAsync();
                    StartNew();
                    return;
                }
                _form.ApplyTo(existing);
                existing.UpdatedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
            }

            await LoadAsync();
            var saved = _products.FirstOrDefault(p => p.Id == newId);
            if (saved is not null) await SelectExisting(saved);
            else StartNew();
            _attempted = false;
            Snackbar.ShowOk("Product saved.");
        }
        catch (DbUpdateException ex) when (ex.InnerException?.Message?.Contains("UNIQUE", StringComparison.OrdinalIgnoreCase) == true)
        {
            Snackbar.ShowError("That SKU is already in use.");
        }
        catch (DbUpdateException ex)
        {
            Logger.LogError(ex, "Failed to save product (DB)");
            Snackbar.ShowError($"Could not save: {ex.InnerException?.Message ?? ex.Message}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save product");
            Snackbar.ShowError($"Could not save: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    // Walk validators in priority order to surface the most actionable reason.
    private string FirstInvalidReason()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) return "Product name is required.";
        if (_form.Name.Length > 200) return "Product name is too long (200 chars max).";
        if (_form.TaxRateId is null) return "Pick a tax rate.";
        if (!(_form.Mrp is > 0)) return "MRP must be greater than 0.";
        if (!SalePriceValid) return SalePriceError;
        if (_form.Cost is < 0) return "Cost cannot be negative.";
        if (_form.StockQty is < 0) return "Stock cannot be negative.";
        if (_form.ReorderLevel is < 0) return "Reorder level cannot be negative.";
        if (!IndianFormats.IsHsn(_form.HsnCode)) return "HSN must be 2–8 digits.";
        return "Form has errors — fix the highlighted fields.";
    }

    private async Task DeleteCurrent()
    {
        if (_editing is null) return;
        var ok = await Confirm($"Delete \"{_editing.Name}\"?",
            "It will be soft-deleted and won't appear in lists.", "Delete");
        if (!ok) return;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Products.FirstOrDefaultAsync(p => p.Id == _editing.Id);
            if (existing is not null)
            {
                existing.IsActive = false;
                existing.UpdatedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
            }
            await LoadAsync();
            StartNew();
            Snackbar.ShowOk("Product removed.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete product");
            Snackbar.ShowError($"Could not delete: {ex.Message}");
        }
    }

    private async Task<bool> Confirm(string title, string body, string yes)
    {
        var result = await DialogService.ShowMessageBoxAsync(title, body, yesText: yes, cancelText: "Cancel");
        return result == true;
    }

    private void GoNext() => Nav.NavigateTo(Onboarding.RouteFor(OnboardingStep.Vendor));

    private sealed class ProductVm
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Sku { get; set; }
        public string? Barcode { get; set; }
        public string? Category { get; set; }
        public string? HsnCode { get; set; }
        public int? TaxRateId { get; set; }
        public decimal? Mrp { get; set; }
        public decimal? SalePrice { get; set; }
        public decimal? Cost { get; set; }
        public decimal? StockQty { get; set; }
        public decimal? ReorderLevel { get; set; }
        public string? Notes { get; set; }
        public bool IsActive { get; set; } = true;
        public DateTime CreatedAt { get; set; } = DateTime.UtcNow;

        public static ProductVm From(Product p) => new()
        {
            Id = p.Id,
            Name = p.Name,
            Sku = p.Sku,
            Barcode = p.Barcode,
            Category = p.Category,
            HsnCode = p.HsnCode,
            TaxRateId = p.TaxRateId,
            Mrp = p.Mrp,
            SalePrice = p.SalePrice,
            Cost = p.Cost == 0 ? null : p.Cost,
            StockQty = p.StockQty,
            ReorderLevel = p.ReorderLevel,
            Notes = p.Notes,
            IsActive = p.IsActive,
            CreatedAt = p.CreatedAt,
        };

        public Product ToEntity() => new()
        {
            Id = Id,
            Name = Name,
            Sku = Sku,
            Barcode = Barcode,
            Category = Category,
            HsnCode = HsnCode,
            TaxRateId = TaxRateId,
            Mrp = Mrp ?? 0,
            SalePrice = SalePrice ?? 0,
            Cost = Cost ?? 0,
            StockQty = StockQty ?? 0,
            ReorderLevel = ReorderLevel,
            Notes = Notes,
            IsActive = IsActive,
            CreatedAt = CreatedAt,
        };

        public void ApplyTo(Product p)
        {
            p.Name = Name;
            p.Sku = Sku;
            p.Barcode = Barcode;
            p.Category = Category;
            p.HsnCode = HsnCode;
            p.TaxRateId = TaxRateId;
            p.Mrp = Mrp ?? 0;
            p.SalePrice = SalePrice ?? 0;
            p.Cost = Cost ?? 0;
            p.StockQty = StockQty ?? 0;
            p.ReorderLevel = ReorderLevel;
            p.Notes = Notes;
            p.IsActive = IsActive;
        }
    }
}
