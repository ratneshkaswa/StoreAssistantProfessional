@page "/onboarding/firm"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISetupService Setup
@inject IOnboardingService Onboarding
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Firm details — Setup</PageTitle>

<OnboardingShell Current="OnboardingStep.Firm"
                 HeroIcon="@Icons.Material.Rounded.Storefront"
                 DecoIcon="@Icons.Material.Rounded.Storefront"
                 HeroHeading="Tell us about your firm"
                 NextHint="Next: tax rates and slabs."
                 BlockingReason="@BlockingReason"
                 ReadyMessage="Ready for taxes — click Next.">
    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="pa-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </MudStack>
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-5 sap-step-card">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Identity</MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="_firm.Name"
                                      Label="Firm name *"
                                      Variant="Variant.Outlined"
                                      MaxLength="200"
                                      Immediate="true"
                                      AutoFocus="true"
                                      Error="@(_attempted && string.IsNullOrWhiteSpace(_firm.Name))"
                                      ErrorText="Firm name is required."
                                      OnKeyDown="OnEnter" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudCheckBox T="bool" @bind-Value="_firm.IsCompositionScheme" Color="Color.Primary">
                            Composition scheme
                        </MudCheckBox>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField Value="_firm.Gstin"
                                      ValueChanged="OnGstinChanged"
                                      T="string"
                                      Label="GSTIN"
                                      Variant="Variant.Outlined"
                                      MaxLength="15"
                                      Immediate="true"
                                      Error="@(!IndianFormats.IsGstin(_firm.Gstin))"
                                      ErrorText="Invalid GSTIN format."
                                      HelperText="15 chars · auto-fills state from first 2 digits" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_firm.Pan"
                                      Label="PAN"
                                      Variant="Variant.Outlined"
                                      MaxLength="10"
                                      Immediate="true"
                                      Error="@(!IndianFormats.IsPan(_firm.Pan))"
                                      ErrorText="Invalid PAN format." />
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="_firm.StateName"
                                      Label="State"
                                      Variant="Variant.Outlined"
                                      MaxLength="100" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_firm.StateCode"
                                      Label="State code"
                                      Variant="Variant.Outlined"
                                      MaxLength="2"
                                      HelperText="e.g. 27 (auto-fills from GSTIN)" />
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-5 sap-step-card">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Financial year</MudText>
                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                    <MudText>FY starts on</MudText>
                    <MudSelect T="int" Value="_firm.FyStartDay" ValueChanged="OnFyDayChanged" Variant="Variant.Outlined" Dense="true" Style="width: 100px;">
                        @for (var d = 1; d <= DaysInFyMonth; d++)
                        {
                            var dd = d;
                            <MudSelectItem Value="dd">@dd</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="int" Value="_firm.FyStartMonth" ValueChanged="OnFyMonthChanged" Variant="Variant.Outlined" Dense="true" Style="width: 160px;">
                        @for (var m = 1; m <= 12; m++)
                        {
                            var mm = m;
                            <MudSelectItem Value="mm">@_monthNames[mm - 1]</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Current FY based on today: @CurrentFyLabel
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Standard India FY = 1 April. Change only if your books follow a different cycle.
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-5 sap-step-card">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Contact &amp; address</MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_firm.Phone"
                                      Label="Phone" Variant="Variant.Outlined" MaxLength="15" Immediate="true"
                                      Error="@(!IndianFormats.IsIndianPhone(_firm.Phone))"
                                      ErrorText="10-digit mobile, optionally with +91." />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_firm.AltPhone"
                                      Label="Alt phone" Variant="Variant.Outlined" MaxLength="15" Immediate="true"
                                      Error="@(!IndianFormats.IsIndianPhone(_firm.AltPhone))"
                                      ErrorText="10-digit mobile, optionally with +91." />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_firm.Email"
                                      Label="Email" Variant="Variant.Outlined" MaxLength="200" Immediate="true"
                                      Error="@(!IndianFormats.IsEmail(_firm.Email))"
                                      ErrorText="Invalid email format." />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_firm.AddressLine1" Label="Address line 1" Variant="Variant.Outlined" MaxLength="300" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_firm.AddressLine2" Label="Address line 2" Variant="Variant.Outlined" MaxLength="300" />
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="_firm.City" Label="City" Variant="Variant.Outlined" MaxLength="100" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_firm.Pincode"
                                      Label="Pincode" Variant="Variant.Outlined" MaxLength="6" Immediate="true"
                                      Error="@(!IndianFormats.IsPincode(_firm.Pincode))"
                                      ErrorText="6 digits, can't start with 0." />
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-5 sap-step-card">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Bank (for receipts)</MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.BankName" Label="Bank name" Variant="Variant.Outlined" MaxLength="200" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.AccountHolderName" Label="Account holder" Variant="Variant.Outlined" MaxLength="100" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.AccountNumber" Label="Account no." Variant="Variant.Outlined" MaxLength="20" /></MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_firm.IfscCode"
                                      Label="IFSC" Variant="Variant.Outlined" MaxLength="11" Immediate="true"
                                      Error="@(!IndianFormats.IsIfsc(_firm.IfscCode))"
                                      ErrorText="11 chars: 4 letters + 0 + 6 alphanum." />
                    </MudItem>
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.BranchName" Label="Branch" Variant="Variant.Outlined" MaxLength="200" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_firm.UpiId" Label="UPI ID" Variant="Variant.Outlined" MaxLength="100" /></MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-5 sap-step-card">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Invoice settings</MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="6" md="3">
                        <MudTextField @bind-Value="_firm.InvoicePrefix"
                                      Label="Prefix" Variant="Variant.Outlined" MaxLength="20" Immediate="true"
                                      Error="@(!IndianFormats.IsInvoicePrefix(_firm.InvoicePrefix))"
                                      ErrorText="Letters &amp; digits only." />
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudNumericField T="int?" @bind-Value="_firm.InvoiceStartNumberNullable" Label="Start #" Variant="Variant.Outlined" Min="1" />
                    </MudItem>
                    <MudItem xs="6" md="3"><MudTextField @bind-Value="_firm.InvoiceNumberPadding" Label="Padding" Variant="Variant.Outlined" MaxLength="10" /></MudItem>
                    <MudItem xs="6" md="3"><MudTextField @bind-Value="_firm.DateFormat" Label="Date format" Variant="Variant.Outlined" MaxLength="20" /></MudItem>
                    <MudItem xs="12">
                        <MudCheckBox T="bool" @bind-Value="_firm.ResetInvoiceOnFyRollover" Color="Color.Primary">
                            Reset invoice numbering on FY rollover
                        </MudCheckBox>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
            <MudButton OnClick="Save"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       Disabled="@(_saving || !IsValid)">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Saving…</span>
                }
                else
                {
                    <span>Save firm</span>
                }
            </MudButton>
            <MudButton OnClick="GoNext"
                       Variant="Variant.Filled"
                       Color="Color.Secondary"
                       Size="Size.Large"
                       Disabled="@(!_savedAtLeastOnce)">
                Next ›
            </MudButton>
        </MudStack>
    }
</OnboardingShell>

@code {
    private FirmVm _firm = new();
    private bool _attempted;
    private bool _saving;
    private bool _savedAtLeastOnce;
    private bool _loading = true;

    private static readonly string[] _monthNames =
    [
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
    ];

    private string? BlockingReason
    {
        get
        {
            if (_loading) return null;
            if (string.IsNullOrWhiteSpace(_firm.Name)) return "Enter your firm name.";
            if (!IndianFormats.IsGstin(_firm.Gstin)) return "Fix the GSTIN format.";
            if (!IndianFormats.IsPan(_firm.Pan)) return "Fix the PAN format.";
            if (!IndianFormats.IsIndianPhone(_firm.Phone)) return "Fix the phone number.";
            if (!IndianFormats.IsIndianPhone(_firm.AltPhone)) return "Fix the alt phone number.";
            if (!IndianFormats.IsEmail(_firm.Email)) return "Fix the email format.";
            if (!IndianFormats.IsPincode(_firm.Pincode)) return "Fix the pincode.";
            if (!IndianFormats.IsIfsc(_firm.IfscCode)) return "Fix the IFSC code.";
            if (!IndianFormats.IsInvoicePrefix(_firm.InvoicePrefix)) return "Invoice prefix: letters and digits only.";
            if (!_savedAtLeastOnce) return "Click Save firm to continue.";
            return null;
        }
    }

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_firm.Name) &&
        IndianFormats.IsGstin(_firm.Gstin) &&
        IndianFormats.IsPan(_firm.Pan) &&
        IndianFormats.IsIndianPhone(_firm.Phone) &&
        IndianFormats.IsIndianPhone(_firm.AltPhone) &&
        IndianFormats.IsEmail(_firm.Email) &&
        IndianFormats.IsPincode(_firm.Pincode) &&
        IndianFormats.IsIfsc(_firm.IfscCode) &&
        IndianFormats.IsInvoicePrefix(_firm.InvoicePrefix);

    private int DaysInFyMonth =>
        DateTime.DaysInMonth(DateTime.Today.Year, ClampMonth(_firm.FyStartMonth));

    protected override async Task OnInitializedAsync()
    {
        if (!Setup.IsComplete) { Nav.NavigateTo("/setup", replace: true); return; }

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Firms.AsNoTracking().FirstOrDefaultAsync();
            if (existing is not null)
            {
                _firm = FirmVm.From(existing);
                if (!string.IsNullOrWhiteSpace(_firm.Name)) _savedAtLeastOnce = true;
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnGstinChanged(string? v)
    {
        _firm.Gstin = v;
        var code = IndianFormats.StateCodeFromGstin(v);
        if (code is not null)
        {
            _firm.StateCode = code;
            var name = IndianFormats.StateNameFromCode(code);
            if (name is not null && string.IsNullOrWhiteSpace(_firm.StateName))
                _firm.StateName = name;
        }
    }

    private void OnFyMonthChanged(int m)
    {
        _firm.FyStartMonth = ClampMonth(m);
        // If the new month has fewer days than the chosen day, clamp the day too.
        var max = DateTime.DaysInMonth(DateTime.Today.Year, _firm.FyStartMonth);
        if (_firm.FyStartDay > max) _firm.FyStartDay = max;
    }

    private void OnFyDayChanged(int d) => _firm.FyStartDay = ClampDay(d, _firm.FyStartMonth);

    private static int ClampMonth(int m) => m is < 1 or > 12 ? 4 : m;

    private static int ClampDay(int d, int month)
    {
        var max = DateTime.DaysInMonth(DateTime.Today.Year, ClampMonth(month));
        return Math.Clamp(d, 1, max);
    }

    private string CurrentFyLabel
    {
        get
        {
            var today = DateTime.Today;
            var month = ClampMonth(_firm.FyStartMonth);
            var day = ClampDay(_firm.FyStartDay, month);
            var startThisYear = new DateTime(today.Year, month, day);
            var fyStart = today >= startThisYear ? startThisYear : startThisYear.AddYears(-1);
            var fyEnd = fyStart.AddYears(1).AddDays(-1);
            var label = $"{fyStart:dd MMM yyyy} → {fyEnd:dd MMM yyyy}";
            var span = fyStart.Year == fyEnd.Year ? $"FY {fyStart.Year}" : $"FY {fyStart.Year}-{(fyEnd.Year % 100):D2}";
            return $"{span} ({label})";
        }
    }

    private async Task OnEnter(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (!_saving && IsValid) await Save();
    }

    private async Task Save()
    {
        _attempted = true;
        if (!IsValid) return;

        _firm.Name = _firm.Name.Trim();
        _firm.Gstin = NormalizeUpper(_firm.Gstin);
        _firm.Pan = NormalizeUpper(_firm.Pan);
        _firm.IfscCode = NormalizeUpper(_firm.IfscCode);
        _firm.UpiId = _firm.UpiId?.Trim();
        _firm.InvoicePrefix = (_firm.InvoicePrefix ?? "INV").Trim().ToUpperInvariant();
        _firm.FyStartMonth = ClampMonth(_firm.FyStartMonth);
        _firm.FyStartDay = ClampDay(_firm.FyStartDay, _firm.FyStartMonth);

        if (Firm.ReservedInvoicePrefixes.Contains(_firm.InvoicePrefix))
        {
            Snackbar.Add($"Prefix '{_firm.InvoicePrefix}' is reserved (Quote/Proforma/Delivery challan/Cash receipt). Pick a different prefix (e.g. INV).", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Firms.FirstOrDefaultAsync();
            var entity = _firm.ToEntity();
            if (existing is null)
            {
                entity.Id = Firm.SingletonId;
                entity.CreatedAt = DateTime.UtcNow;
                entity.UpdatedAt = DateTime.UtcNow;
                db.Firms.Add(entity);
            }
            else
            {
                entity.Id = existing.Id;
                entity.CreatedAt = existing.CreatedAt;
                entity.UpdatedAt = DateTime.UtcNow;
                db.Entry(existing).CurrentValues.SetValues(entity);
            }
            await db.SaveChangesAsync();
            _savedAtLeastOnce = true;
            _attempted = false;
            ShowOk("Firm saved.");
        }
        catch (Exception ex)
        {
            ShowError($"Could not save: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private static string? NormalizeUpper(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim().ToUpperInvariant();

    private void ShowOk(string m) =>
        Snackbar.Add(m, Severity.Success, c => c.VisibleStateDuration = 3000);

    private void ShowError(string m) =>
        Snackbar.Add(m, Severity.Error, c => { c.ShowCloseIcon = true; c.VisibleStateDuration = 8000; });

    private void GoNext() => Nav.NavigateTo(Onboarding.RouteFor(OnboardingStep.Tax));

    // View-model wrapping Firm so we can expose nullable variants of non-nullable
    // numeric fields for Mud's NumericField (clearing the box yields null instead
    // of silent 0). Mapped back to the entity at save time.
    private sealed class FirmVm
    {
        public int Id { get; set; } = Firm.SingletonId;
        public string Name { get; set; } = "";
        public string? Gstin { get; set; }
        public string? Pan { get; set; }
        public string? StateCode { get; set; }
        public string? StateName { get; set; }
        public string? Phone { get; set; }
        public string? AltPhone { get; set; }
        public string? Email { get; set; }
        public string? AddressLine1 { get; set; }
        public string? AddressLine2 { get; set; }
        public string? City { get; set; }
        public string? Pincode { get; set; }
        public string? BankName { get; set; }
        public string? AccountHolderName { get; set; }
        public string? AccountNumber { get; set; }
        public string? IfscCode { get; set; }
        public string? BranchName { get; set; }
        public string? UpiId { get; set; }
        public string InvoicePrefix { get; set; } = "INV";
        public int InvoiceStartNumber { get; set; } = 1;
        public int? InvoiceStartNumberNullable
        {
            get => InvoiceStartNumber == 0 ? null : InvoiceStartNumber;
            set => InvoiceStartNumber = value ?? 1;
        }
        public int NextInvoiceNumber { get; set; } = 1;
        public string InvoiceNumberPadding { get; set; } = "0000";
        public bool ResetInvoiceOnFyRollover { get; set; } = true;
        public string DateFormat { get; set; } = "dd/MM/yyyy";
        public int FyStartDay { get; set; } = 1;
        public int FyStartMonth { get; set; } = 4;
        public bool IsCompositionScheme { get; set; }

        public static FirmVm From(Firm f) => new()
        {
            Id = f.Id,
            Name = f.Name ?? "",
            Gstin = f.Gstin,
            Pan = f.Pan,
            StateCode = f.StateCode,
            StateName = f.StateName,
            Phone = f.Phone,
            AltPhone = f.AltPhone,
            Email = f.Email,
            AddressLine1 = f.AddressLine1,
            AddressLine2 = f.AddressLine2,
            City = f.City,
            Pincode = f.Pincode,
            BankName = f.BankName,
            AccountHolderName = f.AccountHolderName,
            AccountNumber = f.AccountNumber,
            IfscCode = f.IfscCode,
            BranchName = f.BranchName,
            UpiId = f.UpiId,
            InvoicePrefix = string.IsNullOrWhiteSpace(f.InvoicePrefix) ? "INV" : f.InvoicePrefix,
            InvoiceStartNumber = f.InvoiceStartNumber <= 0 ? 1 : f.InvoiceStartNumber,
            NextInvoiceNumber = f.NextInvoiceNumber <= 0 ? 1 : f.NextInvoiceNumber,
            InvoiceNumberPadding = string.IsNullOrWhiteSpace(f.InvoiceNumberPadding) ? "0000" : f.InvoiceNumberPadding,
            ResetInvoiceOnFyRollover = f.ResetInvoiceOnFyRollover,
            DateFormat = string.IsNullOrWhiteSpace(f.DateFormat) ? "dd/MM/yyyy" : f.DateFormat,
            FyStartDay = f.FyStartDay is < 1 or > 31 ? 1 : f.FyStartDay,
            FyStartMonth = f.FyStartMonth is < 1 or > 12 ? 4 : f.FyStartMonth,
            IsCompositionScheme = f.IsCompositionScheme,
        };

        public Firm ToEntity() => new()
        {
            Id = Id,
            Name = Name,
            Gstin = Gstin,
            Pan = Pan,
            StateCode = StateCode,
            StateName = StateName,
            Phone = Phone,
            AltPhone = AltPhone,
            Email = Email,
            AddressLine1 = AddressLine1,
            AddressLine2 = AddressLine2,
            City = City,
            Pincode = Pincode,
            BankName = BankName,
            AccountHolderName = AccountHolderName,
            AccountNumber = AccountNumber,
            IfscCode = IfscCode,
            BranchName = BranchName,
            UpiId = UpiId,
            InvoicePrefix = InvoicePrefix,
            InvoiceStartNumber = InvoiceStartNumber,
            NextInvoiceNumber = NextInvoiceNumber,
            InvoiceNumberPadding = InvoiceNumberPadding,
            ResetInvoiceOnFyRollover = ResetInvoiceOnFyRollover,
            DateFormat = DateFormat,
            FyStartDay = FyStartDay,
            FyStartMonth = FyStartMonth,
            IsCompositionScheme = IsCompositionScheme,
        };
    }
}
