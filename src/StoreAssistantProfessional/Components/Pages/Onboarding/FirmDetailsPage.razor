@page "/onboarding/firm"
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Logging
@using StoreAssistantProfessional.Components.Shared
@implements IAsyncDisposable
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISetupService Setup
@inject IOnboardingService Onboarding
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<FirmDetailsPage> Logger

<PageTitle>@PageTitleText</PageTitle>

@* NavigationLock blocks @onclick-driven navigation (the OnboardingProgress
   chip jumps, mostly) when the form has unsaved valid edits. The browser-
   back / app-shell route exit isn't covered here; Blazor's NavigationLock
   doesn't intercept hash-changes from the host. *@
<NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigation" />

<OnboardingShell Current="OnboardingStep.Firm"
                 HeroIcon="@Icons.Material.Rounded.Storefront"
                 DecoIcon="@Icons.Material.Rounded.Storefront"
                 HeroHeading="@HeroHeading"
                 NextHint="Next: tax rates."
                 BlockingReason="@BlockingReason"
                 ReadyMessage="@ReadyMessage"
                 HideHero="true">

    @if (_loading)
    {
        <div role="status" aria-live="polite" aria-atomic="true">
            <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" aria-label="Loading firm details" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading firm details…</MudText>
            </MudStack>
        </div>
    }
    else if (_loadError is not null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            Could not load firm details. @_loadError
            <MudButton Class="ml-2" Size="Size.Small" Variant="Variant.Text" OnClick="ReloadAsync">Retry</MudButton>
        </MudAlert>
    }
    else
    {
        <div @onkeydown="OnPageKeyDown" class="sap-firm-page">

            @* Firm name plate — banner sets context and offers the rename
               affordance. Heading semantics: <h2> for screen readers
               (OnboardingShell carries the visually-hidden h1), styled as
               serif h5 visually. *@
            <div class="sap-firm-plate">
                <MudText Typo="Typo.overline" Class="sap-firm-plate-label">Firm</MudText>
                @if (_isRenamingFirm)
                {
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End" Class="mt-1">
                        <MudTextField @ref="_nameField"
                                      @bind-Value="_firm.Name"
                                      Label="Firm name"
                                      Placeholder="@(_firmNameOriginal ?? "")"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="200"
                                      Immediate="true"
                                      Error="@(IsRenamedNameInvalid)"
                                      ErrorText="@RenamedNameError"
                                      UserAttributes="@_firmNameAttrs"
                                      OnKeyDown="OnRenameKeyDown" />
                        @* Cancel-on-left, primary-on-right matches Material
                           Design + Windows muscle memory for cancel/confirm. *@
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   OnClick="CancelRenaming">Cancel</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                   OnClick="DoneRenaming"
                                   Disabled="@IsRenamedNameInvalid">Done</MudButton>
                    </MudStack>
                }
                else
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="sap-firm-plate-row">
                        @{
                            var hasName = !string.IsNullOrWhiteSpace(_firm.Name);
                        }
                        <h2 class="@(hasName ? "sap-firm-plate-name" : "sap-firm-plate-name is-empty")"
                            aria-label="@(hasName ? null : "Firm name not yet set")"
                            style="margin: 0; font-size: 1.5rem;">
                            @(hasName ? _firm.Name : "Click the pencil to name your firm")
                        </h2>
                        <MudTooltip Text="@PencilTooltip" Placement="Placement.Right">
                            <MudIconButton @ref="_pencilButton"
                                           Size="Size.Small" Icon="@Icons.Material.Rounded.Edit"
                                           OnClick="StartRenaming"
                                           aria-label="@PencilTooltip" />
                        </MudTooltip>
                    </MudStack>
                    @if (_showSeedHint)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="sap-firm-plate-hint">
                            From your initial setup. Click the pencil to rename.
                        </MudText>
                    }
                }
            </div>

            @* Two-column form. Left: Identity + Bank. Right: Contact +
               Invoice. Numbered overlines on each section give the reading
               order an explicit anchor (top-left → bottom-left → top-right →
               bottom-right matches DOM tab order). *@
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    @{
                        var identityLocked = _locked || _saving;
                    }
                    <MudPaper Elevation="1" Class="pa-4 sap-step-card">
                        <MudStack Spacing="3">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Rounded.Storefront" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.h6">1 · Identity</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    @if (identityLocked && _locked)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Locked</MudChip>
                                    }
                                    <MudCheckBox T="bool" @bind-Value="_firm.IsCompositionScheme" Color="Color.Primary"
                                                 Disabled="@identityLocked" Dense="true">
                                        Composition scheme
                                    </MudCheckBox>
                                </MudStack>
                            </MudStack>

                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <MudTextField Value="_firm.Gstin"
                                                  ValueChanged="OnGstinChanged"
                                                  T="string"
                                                  Label="GSTIN"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  MaxLength="15"
                                                  Immediate="true"
                                                  Error="@(_attempted && (!IndianFormats.IsGstin(_firm.Gstin) || !_firm.IsPanGstinConsistent))"
                                                  ErrorText="@GstinError"
                                                  HelperText="15 chars. State + PAN auto-fill from this."
                                                  UserAttributes="@_acOff"
                                                  Disabled="@identityLocked" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Value="_firm.Pan"
                                                  ValueChanged="OnPanChanged"
                                                  T="string"
                                                  Label="PAN"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  MaxLength="10"
                                                  Immediate="true"
                                                  Error="@(_attempted && (!IndianFormats.IsPan(_firm.Pan) || !_firm.IsPanGstinConsistent))"
                                                  ErrorText="@PanError"
                                                  HelperText="Format: AAAAA9999A. Must match GSTIN positions 3–12."
                                                  UserAttributes="@_acOff"
                                                  Disabled="@identityLocked" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudAutocomplete T="(string Code, string Name)?"
                                                     Value="_selectedState"
                                                     ValueChanged="OnStateSelected"
                                                     SearchFunc="SearchStatesAsync"
                                                     ToStringFunc="@(s => s is null ? "" : $"{s.Value.Name} · {s.Value.Code}")"
                                                     Label="State"
                                                     Variant="Variant.Outlined"
                                                     Margin="Margin.Dense"
                                                     Clearable="true"
                                                     Disabled="@identityLocked"
                                                     ResetValueOnEmptyText="true"
                                                     HelperText="Search by state name or code (e.g. 'Maharashtra' or '27')." />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                                        <MudText Typo="Typo.body2">FY starts on</MudText>
                                        <MudSelect T="int" Value="_firm.FyStartDay" ValueChanged="OnFyDayChanged"
                                                   Label="Day"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   Style="min-width: 5.6rem;"
                                                   Disabled="@identityLocked">
                                            @for (var d = 1; d <= DaysInFyMonth; d++)
                                            {
                                                var dd = d;
                                                <MudSelectItem Value="dd">@dd</MudSelectItem>
                                            }
                                        </MudSelect>
                                        <MudSelect T="int" Value="_firm.FyStartMonth" ValueChanged="OnFyMonthChanged"
                                                   Label="Month"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   Style="min-width: 9.4rem;"
                                                   Disabled="@identityLocked">
                                            @for (var m = 1; m <= 12; m++)
                                            {
                                                var mm = m;
                                                <MudSelectItem Value="mm">@_monthNames[mm - 1]</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudStack>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @CurrentFyLabel
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Standard India FY = 1 April. Change only if your books follow a different cycle.
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>

                    @* Left column · Bank for receipts *@
                    <MudPaper Elevation="1" Class="pa-4 sap-step-card sap-firm-card-stacked">
                        <MudStack Spacing="3">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.AccountBalance" Color="Color.Primary" Size="Size.Small" />
                                <MudText Typo="Typo.h6">3 · Bank</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">· for receipts</MudText>
                            </MudStack>
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_firm.BankName" Label="Bank name"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="200"
                                                  UserAttributes="@_attrSpellCheckOff"
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_firm.AccountHolderName" Label="Account holder name"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="100"
                                                  UserAttributes="@_attrSpellCheckOff"
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_firm.AccountNumber" Label="Account number"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="20"
                                                  UserAttributes="@_acOff"
                                                  Error="@(_attempted && BankInfoIncomplete && string.IsNullOrWhiteSpace(_firm.AccountNumber))"
                                                  ErrorText="Required when other bank fields are filled."
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Value="_firm.IfscCode"
                                                  ValueChanged="OnIfscChanged"
                                                  T="string"
                                                  Label="IFSC" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="11"
                                                  Immediate="true"
                                                  Error="@((_attempted && !IndianFormats.IsIfsc(_firm.IfscCode)) || (_attempted && BankInfoIncomplete && string.IsNullOrWhiteSpace(_firm.IfscCode)))"
                                                  ErrorText="@IfscError"
                                                  HelperText="Format: 4 letters + 0 + 6 alphanumeric."
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_firm.BranchName" Label="Branch name"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="200"
                                                  UserAttributes="@_attrSpellCheckOff"
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_firm.UpiId" Label="UPI ID"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="100"
                                                  UserAttributes="@_acOff"
                                                  Disabled="@_saving" />
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                @* Right column · Contact & address + Invoice settings *@
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="1" Class="pa-4 sap-step-card">
                        <MudStack Spacing="3">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Rounded.Phone" Color="Color.Primary" Size="Size.Small" />
                                <MudText Typo="Typo.h6">2 · Contact &amp; address</MudText>
                            </MudStack>
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_firm.Phone"
                                                  Label="Phone" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="20"
                                                  Immediate="true" InputType="InputType.Telephone"
                                                  Error="@(_attempted && !IndianFormats.IsIndianPhone(_firm.Phone))"
                                                  ErrorText="10-digit mobile, optionally with +91."
                                                  UserAttributes="@_acTel"
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_firm.AltPhone"
                                                  Label="Alternate phone" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="20"
                                                  Immediate="true" InputType="InputType.Telephone"
                                                  Error="@(_attempted && !IndianFormats.IsIndianPhone(_firm.AltPhone))"
                                                  ErrorText="10-digit mobile, optionally with +91."
                                                  UserAttributes="@_acTelAlt"
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_firm.Email"
                                                  Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="200"
                                                  Immediate="true" InputType="InputType.Email"
                                                  Error="@(_attempted && !IndianFormats.IsEmail(_firm.Email))"
                                                  ErrorText="Invalid email format."
                                                  UserAttributes="@_acEmail"
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_firm.AddressLine1" Label="Address line 1"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="300"
                                                  HelperText="Building / street / area"
                                                  UserAttributes="@_acAddress1Spellcheck"
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_firm.AddressLine2" Label="Address line 2"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="300"
                                                  HelperText="Locality / landmark (optional)"
                                                  UserAttributes="@_acAddress2Spellcheck"
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12" md="8">
                                    <MudTextField @bind-Value="_firm.City" Label="City" Variant="Variant.Outlined"
                                                  Margin="Margin.Dense" MaxLength="100"
                                                  UserAttributes="@_acCitySpellcheck"
                                                  Disabled="@_saving" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    @* Pincode uses inputmode=numeric instead of InputType.Number so
                                       the browser doesn't render up/down spinner arrows on a value
                                       that has no meaningful "next number" semantic. *@
                                    <MudTextField @bind-Value="_firm.Pincode"
                                                  Label="Pincode" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="6"
                                                  Immediate="true"
                                                  Error="@(_attempted && !IndianFormats.IsPincode(_firm.Pincode))"
                                                  ErrorText="6 digits, can't start with 0."
                                                  UserAttributes="@_acPostalNumeric"
                                                  Disabled="@_saving" />
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="1" Class="pa-4 sap-step-card sap-firm-card-stacked">
                        <MudStack Spacing="3">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.h6">4 · Invoice</MudText>
                                </MudStack>
                                @if (_locked)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                        Locked — bills issued
                                    </MudChip>
                                }
                            </MudStack>
                            <MudGrid Spacing="3">
                                <MudItem xs="6" md="3">
                                    <MudTextField Value="_firm.InvoicePrefix"
                                                  ValueChanged="OnInvoicePrefixChanged"
                                                  T="string"
                                                  Label="Prefix" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="20"
                                                  Immediate="true"
                                                  Error="@(_attempted && !_firm.IsInvoicePrefixValid)"
                                                  ErrorText="@InvoicePrefixError"
                                                  HelperText="Letters & digits, e.g. INV"
                                                  UserAttributes="@_attrPrefixRequired"
                                                  Disabled="@(_locked || _saving)" />
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    @* Format="0" prevents the en-IN locale from grouping the bill
                                       number with a comma (e.g. "1,000") in the input itself —
                                       the value flows into "INV-XXXX" downstream where commas
                                       would be wrong. *@
                                    <MudNumericField T="int?" @bind-Value="_firm.InvoiceStartNumberNullable"
                                                     Label="Start #" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     Min="1" Max="9999999"
                                                     Format="0"
                                                     Disabled="@(_locked || _saving)" />
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    <MudSelect T="string" @bind-Value="_firm.InvoiceNumberPadding"
                                               Label="Padding" Variant="Variant.Outlined" Margin="Margin.Dense"
                                               Disabled="@(_locked || _saving)">
                                        @foreach (var p in FirmVm.AllowedPaddings)
                                        {
                                            var pp = p;
                                            <MudSelectItem Value="@pp">@pp (@(pp.Length) digits)</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    <MudSelect T="string" @bind-Value="_firm.DateFormat"
                                               Label="Date format" Variant="Variant.Outlined" Margin="Margin.Dense"
                                               HelperText="Used on bills, receipts, reports."
                                               Disabled="@_saving">
                                        @foreach (var df in FirmVm.AllowedDateFormats)
                                        {
                                            var dff = df;
                                            <MudSelectItem Value="@dff">@dff (@DateTime.Today.ToString(dff))</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudCheckBox T="bool" @bind-Value="_firm.ResetInvoiceOnFyRollover"
                                                 Color="Color.Primary" Disabled="@(_locked || _saving)" Dense="true">
                                        Reset invoice numbering on FY rollover
                                    </MudCheckBox>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-8">
                                        On the FY start date, restart from Start # (e.g., back to @InvoiceFirstExample).
                                    </MudText>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Examples: <strong>@InvoiceFirstExample</strong>, <strong>@InvoiceSecondExample</strong>, <strong>@InvoiceThirdExample</strong>
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @* Sticky action bar — `.sap-firm-actions` fixes it to viewport
               bottom on tall pages so Save / Continue stay reachable. *@
            <div class="sap-firm-actions">
                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0" Class="mr-auto">
                        @if (_isDirty)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning">
                                <MudIcon Icon="@Icons.Material.Rounded.EditNote" Size="Size.Small" Class="mr-1" />Unsaved changes
                            </MudText>
                        }
                        else if (LastSavedLabel is not null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Color="Color.Success" Size="Size.Small" Class="mr-1" />@LastSavedLabel
                            </MudText>
                        }
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Ctrl+S to save · Ctrl+↩ to save &amp; continue
                        </MudText>
                    </MudStack>
                    <MudButton OnClick="SaveAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Rounded.Save"
                               Style="min-width: 160px;"
                               Disabled="@(_saving || !_firm.IsValid || !_isDirty)">
                        @if (_saving && !_continueAfterSave)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Saving…</span>
                        }
                        else
                        {
                            <span>@SaveLabel</span>
                        }
                    </MudButton>
                    <MudButton OnClick="SaveAndContinueAsync"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               EndIcon="@Icons.Material.Rounded.ArrowForward"
                               Style="min-width: 200px;"
                               Disabled="@(!CanContinue)">
                        @if (_saving && _continueAfterSave)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Saving…</span>
                        }
                        else
                        {
                            <span>Continue</span>
                        }
                    </MudButton>
                </MudStack>
            </div>
        </div>
    }
</OnboardingShell>

@code {
    private FirmVm _firm = new();
    private bool _attempted;
    private bool _saving;
    private bool _continueAfterSave;
    private bool _savedAtLeastOnce;
    private bool _loading = true;
    private bool _locked;
    private string? _loadError;
    private bool _focusOnNextRender;
    private bool _isRenamingFirm;
    private string? _firmNameOriginal;
    private string _seedFirmName = "";          // The name fetched from setup.json (or empty)
    private MudTextField<string>? _nameField;
    private MudIconButton? _pencilButton;
    private DateTime? _lastSavedAt;
    private int _loadedFyStartDay;
    private int _loadedFyStartMonth;

    // For dirty tracking — JSON snapshot of the saved state. Compared against
    // a fresh serialise of `_firm` on each render to drive the "unsaved
    // changes" affordance and the Save button enablement.
    private string _savedSnapshot = "";

    // Set true when the user is exiting rename mode and we want focus to
    // land on the pencil button (the "click again to rename" affordance).
    private bool _focusPencilOnNextRender;

    // Tracks whether we've already shown the "auto-filled from GSTIN" toast
    // this session so we don't bug the user with it on every keystroke.
    private bool _gstinAutoFillToastShown;

    // Periodic timer that refreshes the "Saved Xs ago" caption while the
    // page is open. Disposed in DisposeAsync.
    private CancellationTokenSource? _refreshCts;

    private string HeroHeading => _locked ? "Firm details" : "Set up your firm";

    private string PageTitleText =>
        string.IsNullOrWhiteSpace(_firm.Name)
            ? "Firm details — Setup"
            : $"{_firm.Name} · Firm details";

    private string PencilTooltip =>
        string.IsNullOrWhiteSpace(_firm.Name) ? "Add firm name" : "Rename firm";

    private bool _showSeedHint =>
        !_savedAtLeastOnce
        && !string.IsNullOrWhiteSpace(_seedFirmName)
        && _firm.Name == _seedFirmName;

    private static readonly string[] _monthNames =
    [
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
    ];

    // Pre-sort by name so the Autocomplete's dropdown reads as users think —
    // alphabetical by state name, with the code as a trailing reference.
    private static readonly (string Code, string Name)[] _stateOptionsAlpha =
        BuildStateOptions().OrderBy(s => s.Name, StringComparer.OrdinalIgnoreCase).ToArray();

    // The Autocomplete's "selected value" form — kept in sync with _firm.StateCode.
    private (string Code, string Name)? _selectedState;

    private static readonly Dictionary<string, object> _acOff = new() { ["autocomplete"] = "off" };
    private static readonly Dictionary<string, object> _acTel = new() { ["autocomplete"] = "tel" };
    private static readonly Dictionary<string, object> _acTelAlt = new() { ["autocomplete"] = "tel-national" };
    private static readonly Dictionary<string, object> _acEmail = new() { ["autocomplete"] = "email" };
    // Address / city / postal need an additional `spellcheck="false"` so the
    // browser's red-underline doesn't decorate proper-noun-heavy fields.
    private static readonly Dictionary<string, object> _acAddress1Spellcheck =
        new() { ["autocomplete"] = "address-line1", ["spellcheck"] = "false" };
    private static readonly Dictionary<string, object> _acAddress2Spellcheck =
        new() { ["autocomplete"] = "address-line2", ["spellcheck"] = "false" };
    private static readonly Dictionary<string, object> _acCitySpellcheck =
        new() { ["autocomplete"] = "address-level2", ["spellcheck"] = "false" };
    private static readonly Dictionary<string, object> _acPostalNumeric =
        new() { ["autocomplete"] = "postal-code", ["inputmode"] = "numeric" };
    private static readonly Dictionary<string, object> _attrSpellCheckOff =
        new() { ["spellcheck"] = "false" };
    private static readonly Dictionary<string, object> _firmNameAttrs =
        new() { ["autocomplete"] = "organization", ["spellcheck"] = "false", ["aria-required"] = "true" };
    private static readonly Dictionary<string, object> _attrPrefixRequired =
        new() { ["aria-required"] = "true" };

    private int DaysInFyMonth =>
        DateTime.DaysInMonth(2024, ClampMonth(_firm.FyStartMonth));

    private string CurrentFyLabel => _firm.GetFyForToday(DateTime.Today).Label;

    private bool _isDirty => _savedAtLeastOnce && CurrentSnapshot() != _savedSnapshot;

    private bool CanContinue =>
        !_saving && _firm.IsValid;

    private string SaveLabel => _savedAtLeastOnce ? "Save changes" : "Save firm";

    private string ReadyMessage
    {
        get
        {
            if (!_savedAtLeastOnce) return "Ready to save.";
            if (_isDirty) return "You have unsaved changes — click Save changes.";
            return "Firm saved — click Continue.";
        }
    }

    private string InvoiceFirstExample => FormatInvoice(_locked ? Math.Max(_firm.NextInvoiceNumber, 1)
                                                                : Math.Max(_firm.InvoiceStartNumber, 1));
    private string InvoiceSecondExample => FormatInvoice((_locked ? Math.Max(_firm.NextInvoiceNumber, 1)
                                                                  : Math.Max(_firm.InvoiceStartNumber, 1)) + 1);
    private string InvoiceThirdExample => FormatInvoice((_locked ? Math.Max(_firm.NextInvoiceNumber, 1)
                                                                 : Math.Max(_firm.InvoiceStartNumber, 1)) + 2);

    private string FormatInvoice(int n)
    {
        var prefix = string.IsNullOrWhiteSpace(_firm.InvoicePrefix) ? "INV" : _firm.InvoicePrefix.Trim().ToUpperInvariant();
        var pad = FirmVm.AllowedPaddings.Contains(_firm.InvoiceNumberPadding) ? _firm.InvoiceNumberPadding : "0000";
        return $"{prefix}-{n.ToString(pad)}";
    }

    private string GstinError
    {
        get
        {
            if (!IndianFormats.IsGstin(_firm.Gstin)) return "Invalid GSTIN format.";
            if (!_firm.IsPanGstinConsistent) return "GSTIN positions 3–12 must equal PAN.";
            return "";
        }
    }

    private string PanError
    {
        get
        {
            if (!IndianFormats.IsPan(_firm.Pan)) return "Format: AAAAA9999A.";
            if (!_firm.IsPanGstinConsistent) return "PAN must equal GSTIN positions 3–12.";
            return "";
        }
    }

    private string IfscError
    {
        get
        {
            if (!IndianFormats.IsIfsc(_firm.IfscCode)) return "11 chars: 4 letters + 0 + 6 alphanumeric.";
            if (BankInfoIncomplete && string.IsNullOrWhiteSpace(_firm.IfscCode))
                return "Required when other bank fields are filled.";
            return "";
        }
    }

    private string InvoicePrefixError
    {
        get
        {
            var p = (_firm.InvoicePrefix ?? "").Trim().ToUpperInvariant();
            if (string.IsNullOrEmpty(p)) return "Prefix is required.";
            if (!IndianFormats.IsInvoicePrefix(p)) return "Letters & digits only.";
            if (Firm.ReservedInvoicePrefixes.Contains(p))
                return $"'{p}' is reserved for Quote/Proforma/Delivery challan/Cash receipt.";
            return "";
        }
    }

    private bool BankInfoIncomplete => !_firm.IsBankInfoConsistent;

    private bool IsRenamedNameInvalid =>
        string.IsNullOrWhiteSpace(_firm.Name) || _firm.Name.Trim().Length is < 2 or > 200;

    private string RenamedNameError =>
        string.IsNullOrWhiteSpace(_firm.Name) ? "Firm name is required."
        : _firm.Name.Trim().Length < 2 ? "At least 2 characters."
        : _firm.Name.Trim().Length > 200 ? "At most 200 characters."
        : "";

    // Used by the OnboardingShell's blocker line. First-priority issue wins.
    // Gated on `_attempted` for shape errors so the page doesn't shout
    // immediately on first visit; cross-field issues (composition without
    // GSTIN, bank-info-incomplete) are immediate so the user sees the
    // structural inconsistency they just created.
    private string? BlockingReason
    {
        get
        {
            if (_loading) return null;
            if (string.IsNullOrWhiteSpace(_firm.Name)) return "Firm name is required.";
            if (_attempted)
            {
                if (!IndianFormats.IsGstin(_firm.Gstin)) return "Invalid GSTIN format.";
                if (!IndianFormats.IsPan(_firm.Pan)) return "PAN format: AAAAA9999A.";
                if (!_firm.IsPanGstinConsistent) return "PAN must match GSTIN positions 3–12.";
                if (!IndianFormats.IsIndianPhone(_firm.Phone) || !IndianFormats.IsIndianPhone(_firm.AltPhone))
                    return "Phone: 10-digit mobile, optionally with +91.";
                if (!IndianFormats.IsEmail(_firm.Email)) return "Invalid email format.";
                if (!IndianFormats.IsPincode(_firm.Pincode)) return "Pincode: 6 digits, can't start with 0.";
                if (!IndianFormats.IsIfsc(_firm.IfscCode)) return "IFSC: 4 letters + 0 + 6 alphanumeric.";
                if (!_firm.IsInvoicePrefixValid) return InvoicePrefixError;
            }
            if (_firm.CompositionWithoutGstin) return "Composition scheme requires a GSTIN.";
            if (BankInfoIncomplete) return "Bank: Account number and IFSC are required together (or leave both blank).";
            return null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Setup.IsComplete) { Nav.NavigateTo("/setup", replace: true); return; }
        await LoadAsync();
        StartLastSavedRefresh();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusOnNextRender && _nameField is not null)
        {
            _focusOnNextRender = false;
            try { await _nameField.FocusAsync(); }
            catch { /* WebView2 timing — focus is best-effort */ }
        }
        if (_focusPencilOnNextRender && _pencilButton is not null)
        {
            _focusPencilOnNextRender = false;
            // MudIconButton doesn't expose FocusAsync as cleanly; the queued
            // focus is best-effort and silently ignored on failure.
            try { await Task.Yield(); /* let the render flush */ }
            catch { }
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Firms.AsNoTracking().FirstOrDefaultAsync();
            if (existing is not null)
            {
                _firm = FirmVm.From(existing);
                if (!string.IsNullOrWhiteSpace(_firm.Name)) _savedAtLeastOnce = true;
            }
            else if (!string.IsNullOrWhiteSpace(Setup.Current?.FirmName))
            {
                // Seed the firm name from setup.json so the page acknowledges
                // what the user already typed during PIN setup, instead of
                // greeting them with an empty required field.
                _firm.Name = Setup.Current.FirmName;
                _seedFirmName = _firm.Name;
            }
            _firmNameOriginal = _firm.Name;
            _loadedFyStartDay = _firm.FyStartDay;
            _loadedFyStartMonth = _firm.FyStartMonth;
            _locked = await db.Bills.AsNoTracking().AnyAsync();
            _firm.Normalize();

            // Sync the selected-state autocomplete value with the loaded code.
            if (!string.IsNullOrWhiteSpace(_firm.StateCode))
            {
                _selectedState = _stateOptionsAlpha.FirstOrDefault(s => s.Code == _firm.StateCode);
            }

            _savedSnapshot = CurrentSnapshot();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load firm details");
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
            _focusOnNextRender = false;
        }
    }

    private void StartLastSavedRefresh()
    {
        // Refresh the "Saved Xs ago" caption every 30s so the relative-time
        // text doesn't go stale. Cancelled in DisposeAsync.
        _refreshCts?.Cancel();
        _refreshCts?.Dispose();
        var cts = new CancellationTokenSource();
        _refreshCts = cts;
        _ = RunRefreshLoopAsync(cts.Token);
    }

    private async Task RunRefreshLoopAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(30), token);
                if (_lastSavedAt is not null)
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException) { /* expected on disposal */ }
    }

    public async ValueTask DisposeAsync()
    {
        _refreshCts?.Cancel();
        _refreshCts?.Dispose();
        await ValueTask.CompletedTask;
    }

    private string CurrentSnapshot() => JsonSerializer.Serialize(_firm);

    private string? LastSavedLabel
    {
        get
        {
            if (_lastSavedAt is null) return null;
            var now = DateTime.UtcNow;
            var ago = now - _lastSavedAt.Value;
            if (ago.TotalSeconds < 5) return "Saved just now";
            if (ago.TotalMinutes < 1) return $"Saved {(int)ago.TotalSeconds}s ago";
            if (ago.TotalMinutes < 60) return $"Saved {(int)ago.TotalMinutes}m ago";
            // Older than an hour: include the date so it's unambiguous.
            var local = _lastSavedAt.Value.ToLocalTime();
            return ago.TotalHours < 24
                ? $"Saved at {local:HH:mm}"
                : $"Saved on {local:dd MMM} at {local:HH:mm}";
        }
    }

    private Task ReloadAsync() => LoadAsync();

    private void StartRenaming()
    {
        _firmNameOriginal = _firm.Name;
        _isRenamingFirm = true;
        _focusOnNextRender = true;
    }

    private void DoneRenaming()
    {
        if (IsRenamedNameInvalid) return;
        _firm.Name = _firm.Name.Trim();
        _firmNameOriginal = _firm.Name;
        _isRenamingFirm = false;
        _focusPencilOnNextRender = true;
    }

    private void CancelRenaming()
    {
        _firm.Name = _firmNameOriginal ?? "";
        _isRenamingFirm = false;
        _focusPencilOnNextRender = true;
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        // Enter commits the rename if valid; Escape cancels. Keeps focus
        // discipline tight without reaching for the mouse.
        if (e.Key == "Enter" && !IsRenamedNameInvalid)
        {
            DoneRenaming();
        }
        else if (e.Key == "Escape")
        {
            CancelRenaming();
        }
        await Task.CompletedTask;
    }

    private void OnGstinChanged(string? v)
    {
        var oldGstin = _firm.Gstin;
        _firm.Gstin = string.IsNullOrEmpty(v) ? v : v.ToUpperInvariant();

        var code = IndianFormats.StateCodeFromGstin(_firm.Gstin);
        var stateChanged = false;
        if (code is not null)
        {
            if (_firm.StateCode != code)
            {
                _firm.StateCode = code;
                _firm.StateName = IndianFormats.StateNameFromCode(code);
                _selectedState = _stateOptionsAlpha.FirstOrDefault(s => s.Code == code);
                stateChanged = true;
            }
        }
        else if (string.IsNullOrWhiteSpace(_firm.Gstin))
        {
            _firm.StateCode = null;
            _firm.StateName = null;
            _selectedState = null;
        }

        var derivedPan = IndianFormats.PanFromGstin(_firm.Gstin);
        var panFilled = false;
        if (derivedPan is not null && string.IsNullOrWhiteSpace(_firm.Pan))
        {
            _firm.Pan = derivedPan;
            panFilled = true;
        }

        // First-time-this-session info toast so the magic isn't silent. Shown
        // only when something was actually auto-derived (avoids noise on a
        // partial GSTIN that doesn't yet resolve a state code).
        if (!_gstinAutoFillToastShown && (stateChanged || panFilled))
        {
            _gstinAutoFillToastShown = true;
            Snackbar.Add("State and PAN derived from GSTIN — change them if needed.",
                Severity.Info, c => c.VisibleStateDuration = 4000);
        }
    }

    private void OnPanChanged(string? v) =>
        _firm.Pan = string.IsNullOrEmpty(v) ? v : v.ToUpperInvariant();

    private void OnIfscChanged(string? v) =>
        _firm.IfscCode = string.IsNullOrEmpty(v) ? v : v.ToUpperInvariant();

    private void OnInvoicePrefixChanged(string? v) =>
        _firm.InvoicePrefix = string.IsNullOrEmpty(v) ? "" : v.ToUpperInvariant();

    private void OnStateSelected((string Code, string Name)? value)
    {
        _selectedState = value;
        _firm.StateCode = value?.Code;
        _firm.StateName = value?.Name;
    }

    private async Task<IEnumerable<(string Code, string Name)?>> SearchStatesAsync(string? value, CancellationToken ct)
    {
        await Task.CompletedTask;
        IEnumerable<(string Code, string Name)> source = _stateOptionsAlpha;
        if (!string.IsNullOrWhiteSpace(value))
        {
            var v = value.Trim();
            source = source.Where(s =>
                s.Name.Contains(v, StringComparison.OrdinalIgnoreCase) ||
                s.Code.StartsWith(v, StringComparison.Ordinal));
        }
        return source.Cast<(string Code, string Name)?>();
    }

    private void OnFyMonthChanged(int m)
    {
        _firm.FyStartMonth = ClampMonth(m);
        var max = DateTime.DaysInMonth(2024, _firm.FyStartMonth);
        if (_firm.FyStartDay > max) _firm.FyStartDay = max;
    }

    private void OnFyDayChanged(int d) => _firm.FyStartDay = ClampDay(d, _firm.FyStartMonth);

    private static int ClampMonth(int m) => m is < 1 or > 12 ? 4 : m;

    private static int ClampDay(int d, int month) =>
        Math.Clamp(d, 1, DateTime.DaysInMonth(2024, ClampMonth(month)));

    private async Task OnPageKeyDown(KeyboardEventArgs e)
    {
        // Ctrl+S during rename mode commits the rename (Enter handler) +
        // saves the form. Block it here so a half-typed rename can't sneak
        // through — user must Done the rename first.
        if (e.CtrlKey && (e.Key is "s" or "S" || e.Key == "Enter"))
        {
            if (_isRenamingFirm)
            {
                Snackbar.Add("Finish renaming first (press Enter to confirm or Escape to cancel).",
                    Severity.Info, c => c.VisibleStateDuration = 3000);
                return;
            }
        }
        if (e.CtrlKey && e.Key is "s" or "S")
        {
            if (_saving) return;
            if (!_firm.IsValid)
            {
                Snackbar.Add(BlockingReason ?? "Form has errors — fix them and try again.", Severity.Warning);
                _attempted = true;
                return;
            }
            await SaveAsync();
        }
        else if (e.CtrlKey && e.Key == "Enter")
        {
            if (_saving) return;
            if (!_firm.IsValid)
            {
                Snackbar.Add(BlockingReason ?? "Form has errors — fix them and try again.", Severity.Warning);
                _attempted = true;
                return;
            }
            await SaveAndContinueAsync();
        }
    }

    private Task SaveAsync() => SaveCoreAsync(continueAfter: false);

    private Task SaveAndContinueAsync() => SaveCoreAsync(continueAfter: true);

    private async Task SaveCoreAsync(bool continueAfter)
    {
        _attempted = true;
        if (!_firm.IsValid) return;

        // FY day/month change after bills exist retroactively reclassifies
        // every existing bill. Confirm before committing.
        if (_savedAtLeastOnce && _locked &&
            (_firm.FyStartDay != _loadedFyStartDay || _firm.FyStartMonth != _loadedFyStartMonth))
        {
            var confirmed = await DialogService.ShowMessageBoxAsync(
                "Change financial year?",
                "Bills have already been issued. Changing the FY start date will reclassify every existing bill into a different financial year for reports. Continue?",
                yesText: "Change FY",
                cancelText: "Cancel");
            if (confirmed != true) return;
        }

        // Skip the no-op path: if Continue is clicked with no dirty changes,
        // jump straight to the next step.
        if (continueAfter && _savedAtLeastOnce && !_isDirty)
        {
            Nav.NavigateTo(Onboarding.RouteFor(OnboardingStep.Tax));
            return;
        }

        _saving = true;
        _continueAfterSave = continueAfter;
        try
        {
            _firm.Normalize();

            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Firms.FirstOrDefaultAsync();
            var hasBills = await db.Bills.AnyAsync();

            // Sync NextInvoiceNumber to InvoiceStartNumber while no bills have
            // been issued — otherwise the user's "Start #" choice would be
            // ignored. Once bills exist, leave NextInvoiceNumber alone.
            if (!hasBills) _firm.NextInvoiceNumber = _firm.InvoiceStartNumber;

            var entity = _firm.ToEntity();
            if (existing is null)
            {
                entity.Id = Firm.SingletonId;
                entity.CreatedAt = DateTime.UtcNow;
                entity.UpdatedAt = DateTime.UtcNow;
                db.Firms.Add(entity);
            }
            else
            {
                entity.Id = existing.Id;
                entity.CreatedAt = existing.CreatedAt;
                entity.UpdatedAt = DateTime.UtcNow;
                db.Entry(existing).CurrentValues.SetValues(entity);
            }
            await db.SaveChangesAsync();

            _savedAtLeastOnce = true;
            _attempted = false;
            _lastSavedAt = DateTime.UtcNow;
            _savedSnapshot = CurrentSnapshot();
            _loadedFyStartDay = _firm.FyStartDay;
            _loadedFyStartMonth = _firm.FyStartMonth;
            Snackbar.Add("Firm saved.", Severity.Success, c => c.VisibleStateDuration = 3000);

            if (continueAfter)
            {
                Nav.NavigateTo(Onboarding.RouteFor(OnboardingStep.Tax));
            }
        }
        catch (DbUpdateException ex)
        {
            Logger.LogError(ex, "Failed to save firm (DB)");
            Snackbar.Add($"Could not save: {ex.InnerException?.Message ?? ex.Message}", Severity.Error,
                c => { c.ShowCloseIcon = true; c.VisibleStateDuration = 8000; });
        }
        catch (IOException ex)
        {
            Logger.LogError(ex, "Failed to save firm (IO)");
            Snackbar.Add($"Disk error: {ex.Message}", Severity.Error,
                c => { c.ShowCloseIcon = true; c.VisibleStateDuration = 8000; });
        }
        catch (UnauthorizedAccessException ex)
        {
            Logger.LogError(ex, "Failed to save firm (permissions)");
            Snackbar.Add($"Permission denied: {ex.Message}", Severity.Error,
                c => { c.ShowCloseIcon = true; c.VisibleStateDuration = 8000; });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save firm");
            Snackbar.Add("Could not save firm details. Please try again.", Severity.Error,
                c => { c.ShowCloseIcon = true; c.VisibleStateDuration = 8000; });
        }
        finally
        {
            _saving = false;
            _continueAfterSave = false;
        }
    }

    // Blocks programmatic navigation (OnboardingProgress chip clicks) when
    // there are unsaved valid changes. The user gets a confirm prompt; on
    // dismiss the navigation is cancelled.
    private async Task OnBeforeInternalNavigation(LocationChangingContext context)
    {
        if (!_isDirty) return;
        // Only confirm when navigating away from this page.
        if (context.TargetLocation.Contains("/onboarding/firm", StringComparison.OrdinalIgnoreCase)) return;

        var go = await DialogService.ShowMessageBoxAsync(
            "Discard unsaved changes?",
            "You have unsaved changes that will be lost if you leave now.",
            yesText: "Leave anyway",
            cancelText: "Stay");
        if (go != true) context.PreventNavigation();
    }

    private static (string Code, string Name)[] BuildStateOptions()
    {
        var list = new List<(string Code, string Name)>();
        for (var i = 1; i <= 38; i++)
        {
            var code = i.ToString("D2");
            var name = IndianFormats.StateNameFromCode(code);
            if (name is not null) list.Add((code, name));
        }
        return list.ToArray();
    }
}
