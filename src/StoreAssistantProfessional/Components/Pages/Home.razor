@page "/"
@inject ISetupService Setup
@inject IOnboardingService Onboarding
@inject NavigationManager Nav

<PageTitle>Loading…</PageTitle>

<MudContainer Class="mt-12">
    <MudStack AlignItems="AlignItems.Center" Spacing="2">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">Opening your store…</MudText>
    </MudStack>
</MudContainer>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (!Setup.IsComplete)
        {
            Nav.NavigateTo("/setup", replace: true);
            return;
        }

        var step = await Onboarding.CurrentStepAsync();
        if (step != OnboardingStep.Done)
        {
            Nav.NavigateTo(Onboarding.RouteFor(step), replace: true);
            return;
        }

        Nav.NavigateTo("/billing", replace: true);
    }
}
